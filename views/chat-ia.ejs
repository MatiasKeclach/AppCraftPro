<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Chat IA</title>
  <link rel="stylesheet" href="/css/chat-ia.css">
</head>
<body>
  <h1>Hola <%= username %>! Bienvenido al chat IA</h1>

  <div class="chat-container">
    <div id="chat-box"></div>
    <input type="text" id="chat-input" placeholder="Escribí algo...">
    <button id="send-btn">Enviar</button>
  </div>

  <script src="/js/chat-ia.js" defer></script>
</body>
</html>