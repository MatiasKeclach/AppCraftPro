<!DOCTYPE html><html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Gestión de Usuarios</title>  <style>
    :root {
      --bg: #0b1220;
      --card: #0f172a;
      --text: #e5e7eb;
      --muted: #94a3b8;
      --primary: #6366f1;
      --border: #1e293b;
      --accent: #22c55e;
    }

    body.light {
      --bg: #f1f5f9;
      --card: #ffffff;
      --text: #0f172a;
      --muted: #64748b;
      --primary: #4f46e5;
      --border: #e2e8f0;
      --accent: #16a34a;
    }

    body {
      margin: 0;
      font-family: "Segoe UI", Roboto, sans-serif;
      background: radial-gradient(circle at 20% 0%, #0f172a 0%, #020617 60%);
      color: var(--text);
      transition: 0.25s;
    }

    body.light {
      background: linear-gradient(180deg, #f8fafc, #e2e8f0);
    }

    .container {
      max-width: 1150px;
      margin: auto;
      padding: 28px 18px 60px;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 22px;
      flex-wrap: wrap;
      gap: 12px;
    }

    .title {
      font-size: 24px;
      font-weight: 600;
      letter-spacing: .3px;
    }

    .subtitle {
      font-size: 13px;
      color: var(--muted);
      margin-top: 2px;
    }

    .actions {
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .btn {
      border: 1px solid var(--border);
      padding: 9px 14px;
      border-radius: 10px;
      cursor: pointer;
      font-weight: 500;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: .18s;
      background: var(--card);
      color: var(--text);
    }

    .btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 18px rgba(0,0,0,.25);
    }

    .btn-primary {
      background: linear-gradient(135deg, #6366f1, #4f46e5);
      color: #fff;
      border: none;
    }

    .theme-btn {
      width: 38px;
      height: 38px;
      border-radius: 10px;
      justify-content: center;
      font-size: 16px;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 22px;
      box-shadow: 0 20px 40px rgba(0,0,0,.35);
    }

    .welcome {
      font-size: 14px;
      color: var(--muted);
      margin-bottom: 14px;
    }

    .welcome b {
      color: var(--text);
      font-weight: 600;
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
      margin-bottom: 18px;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    label {
      font-size: 12px;
      color: var(--muted);
    }

    input, select {
      background: transparent;
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 9px 11px;
      color: var(--text);
      font-size: 14px;
      outline: none;
    }

    input:focus, select:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 2px rgba(99,102,241,.25);
    }

    .footer {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      margin-top: 8px;
      flex-wrap: wrap;
    }

    .users-section {
      margin-top: 28px;
    }

    .section-header h2 {
      margin: 0 0 10px;
      font-size: 18px;
      font-weight: 600;
    }

    .table-wrapper {
      overflow-x: auto;
      border-radius: 12px;
      border: 1px solid var(--border);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }

    th, td {
      padding: 10px 12px;
      border-bottom: 1px solid var(--border);
      text-align: left;
    }

    th {
      background: rgba(255,255,255,0.03);
      font-weight: 600;
      color: var(--muted);
    }

    .role-badge {
      padding: 3px 8px;
      border-radius: 8px;
      font-size: 12px;
      background: rgba(99,102,241,.15);
      color: #a5b4fc;
    }

    .btn-table {
      border: none;
      background: transparent;
      color: var(--muted);
      cursor: pointer;
      margin-right: 6px;
      font-size: 13px;
    }

    .btn-table:hover {
      color: var(--text);
    }

    .flash {
      animation: flashRow 1.2s ease;
    }

    @keyframes flashRow {
      0% { background: rgba(34,197,94,.25); }
      100% { background: transparent; }
    }

    @media (max-width: 768px) {
      .form-grid { grid-template-columns: 1fr; }
      .title { font-size: 20px; }
    }
  </style></head><body>
  <div class="container">
    <div class="topbar">
      <div>
        <div class="title">Gestión de Usuarios</div>
        <div class="subtitle">Administración y control de accesos</div>
      </div><div class="actions">
    <button id="themeBtn" class="btn theme-btn" aria-label="Tema">🌙</button>
    <button class="btn" onclick="window.location.href='/panel'">← Panel</button>
  </div>
</div>

<div class="card">
  <div class="welcome" id="welcomeText">Bienvenido —</div>

  <form id="userForm">
    <div class="form-grid">
      <div class="field">
        <label>Nombre</label>
        <input name="nombre" required />
      </div>

      <div class="field">
        <label>Apellido</label>
        <input name="apellido" required />
      </div>

      <div class="field">
        <label>Email</label>
        <input type="email" name="email" required />
      </div>

      <div class="field">
        <label>Username</label>
        <input name="username" required />
      </div>

      <div class="field">
        <label>Password</label>
        <input type="password" name="password" required />
      </div>

      <div class="field">
        <label>Rol</label>
        <select name="rol" required>
          <option value="">Seleccionar</option>
          <option value="superadmin">Super Admin</option>
          <option value="admin">Admin</option>
          <option value="colaborador">Colaborador</option>
          <option value="usuario">Usuario</option>
        </select>
      </div>
    </div>

    <div class="footer">
      <button type="button" class="btn" onclick="window.location.href='/dashboard'">Cancelar</button>
      <button type="submit" class="btn btn-primary">Crear Usuario</button>
    </div>
  </form>

  <div class="users-section">
    <div class="section-header">
      <h2>Usuarios existentes</h2>
    </div>

    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>Usuario</th>
            <th>Nombre</th>
            <th>Email</th>
            <th>Rol</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody id="usersTableBody"></tbody>
      </table>
    </div>
  </div>
</div>

  </div>  <script>
  const themeBtn = document.getElementById("themeBtn");

  function applyTheme(theme) {
    if (theme === "light") document.body.classList.add("light");
    else document.body.classList.remove("light");
    localStorage.setItem("theme", theme);
    themeBtn.textContent = theme === "dark" ? "☀️" : "🌙";
  }

  (function initTheme() {
    const saved = localStorage.getItem("theme") || "dark";
    applyTheme(saved);
  })();

  themeBtn.addEventListener("click", () => {
    const current = document.body.classList.contains("light") ? "light" : "dark";
    applyTheme(current === "dark" ? "light" : "dark");
  });

  // --------- CRUD USUARIOS ---------

  async function loadUsers() {
    const res = await fetch("/panel/users");
    if (!res.ok) return;
    const users = await res.json();

    const tbody = document.getElementById("usersTableBody");
    tbody.innerHTML = "";
    users.forEach(addUserToTable);
  }

  function addUserToTable(user) {
    const tbody = document.getElementById("usersTableBody");

    const row = document.createElement("tr");
    row.innerHTML = `
      <td>${user.username}</td>
      <td>-</td>
      <td>-</td>
      <td><span class="role-badge">${user.role}</span></td>
      <td>
        <button class="btn-table" onclick="openEdit(${user.id})">Editar</button>
        <button class="btn-table" onclick="deleteUser(${user.id}, '${user.username}')">Eliminar</button>
      </td>
    `;

    tbody.prepend(row);
  }

  // --------- CREAR ---------

  document.getElementById("userForm").addEventListener("submit", async e => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(e.target));

    const res = await fetch("/panel/users", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        username: data.username,
        password: data.password,
        role: data.rol
      })
    });

    if (!res.ok) {
      alert("Error al crear usuario");
      return;
    }

    e.target.reset();
    loadUsers();
  });

  // --------- ELIMINAR ---------

  async function deleteUser(id, username) {
    if (!confirm(`Eliminar usuario ${username}?`)) return;

    const res = await fetch(`/panel/users/${id}`, {
      method: "DELETE"
    });

    if (!res.ok) {
      alert("Error al eliminar");
      return;
    }

    loadUsers();
  }

  // --------- EDITAR ---------

  let editModal;
  let editForm;

  function ensureModal() {
    if (editModal) return;

    editModal = document.createElement("div");
    editModal.style.position = "fixed";
    editModal.style.inset = 0;
    editModal.style.background = "rgba(0,0,0,.6)";
    editModal.style.display = "none";
    editModal.style.alignItems = "center";
    editModal.style.justifyContent = "center";
    editModal.innerHTML = `
      <div style="background:var(--card);padding:22px;border-radius:14px;min-width:280px;max-width:420px;width:92%">
        <h3 style="margin-top:0">Editar usuario</h3>
        <form id="editUserForm">
          <input type="hidden" name="id" />

          <label>Username</label>
          <input name="username" />

          <label>Password (opcional)</label>
          <input name="password" type="password" placeholder="Dejar vacío para no cambiar" />

          <label>Rol</label>
          <select name="role">
            <option value="superadmin">Super Admin</option>
            <option value="admin">Admin</option>
            <option value="usuario">Usuario</option>
          </select>

          <div style="display:flex;gap:8px;margin-top:14px;justify-content:flex-end">
            <button type="button" class="btn" id="closeEdit">Cancelar</button>
            <button type="submit" class="btn btn-primary">Guardar</button>
          </div>
        </form>
      </div>
    `;

    document.body.appendChild(editModal);
    editForm = editModal.querySelector("#editUserForm");

    document.getElementById("closeEdit").onclick = () => {
      editModal.style.display = "none";
    };

    editModal.addEventListener("click", e => {
      if (e.target === editModal) editModal.style.display = "none";
    });

    editForm.addEventListener("submit", submitEdit);
  }

  async function openEdit(id) {
    ensureModal();

    const res = await fetch(`/panel/users/${id}`);
    if (!res.ok) {
      alert("No se pudo cargar usuario");
      return;
    }

    const user = await res.json();

    editForm.id.value = user.id;
    editForm.username.value = user.username;
    editForm.password.value = "";
    editForm.role.value = user.role;

    editModal.style.display = "flex";
  }

  async function submitEdit(e) {
    e.preventDefault();

    const data = Object.fromEntries(new FormData(editForm));
    const payload = {
      username: data.username,
      role: data.role
    };

    if (data.password && data.password.trim() !== "") {
      payload.password = data.password;
    }

    const res = await fetch(`/panel/users/${data.id}`, {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload)
    });

    if (!res.ok) {
      alert("Error al actualizar");
      return;
    }

    editModal.style.display = "none";
    loadUsers();
  }

  // init
  loadUsers();
</script></body>
</html>