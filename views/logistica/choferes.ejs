<!DOCTYPE html>
<html lang="es">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Choferes - Logística</title>

<link rel="stylesheet" href="/css/panel.css">


<style>

:root{

    --primary:#2563eb;
    --dark:#0f172a;
    --bg:#f1f5f9;
    --card:#ffffff;
    --border:#e2e8f0;
    --text:#334155;

}


*{

box-sizing:border-box;

}



body{

margin:0;

background:var(--bg);

font-family:Arial,Helvetica,sans-serif;

color:var(--text);

}




.header{

background:linear-gradient(135deg,#0f172a,#1e40af);

color:white;

padding:25px;

}



.header h2{

margin:0;

}



.header p{

margin-bottom:0;

opacity:.8;

}




.container{

max-width:1200px;

margin:auto;

padding:25px;

}





.box{

background:white;

padding:25px;

border-radius:18px;

margin-bottom:25px;

box-shadow:0 10px 25px rgba(0,0,0,.08);

border:1px solid var(--border);

}





.box h3{

margin-top:0;

color:var(--dark);

}





form{

display:flex;

flex-direction:column;

gap:15px;

}





input,
select{

width:100%;

padding:14px;

border-radius:12px;

border:1px solid #cbd5e1;

font-size:15px;

}





button{

background:var(--primary);

color:white;

border:none;

padding:13px 18px;

border-radius:12px;

cursor:pointer;

font-weight:bold;

font-size:15px;

}



button:hover{

opacity:.9;

}





.table-container{

overflow-x:auto;

}





table{

width:100%;

border-collapse:collapse;

min-width:800px;

}





th{

background:#f8fafc;

text-align:left;

}





th,
td{

padding:14px;

border-bottom:1px solid var(--border);

}





.btn-editar{

background:#16a34a;

color:white;

padding:8px 12px;

border-radius:8px;

text-decoration:none;

font-size:14px;

}





.btn-eliminar{

background:#dc2626;

color:white;

padding:8px 12px;

border-radius:8px;

text-decoration:none;

font-size:14px;

}





.estado{

padding:6px 12px;

border-radius:20px;

background:#dcfce7;

color:#166534;

font-size:13px;

font-weight:bold;

}





@media(min-width:768px){


form{

display:grid;

grid-template-columns:repeat(2,1fr);

}


button{

grid-column:span 2;

}


}





@media(max-width:600px){


.container{

padding:15px;

}


.box{

padding:18px;

}


}




</style>


</head>



<body>


<div class="header">


<h2>
🚚 Choferes Logística
</h2>


<p>
Usuario: <%= username %>
</p>


</div>




<div class="container">



<div class="box">


<h3>
➕ Nuevo chofer
</h3>



<form method="POST" action="/panel/logistica/choferes">



<input

name="nombre"

placeholder="Nombre y apellido"

required

>



<input

name="telefono"

placeholder="Teléfono"

>



<input

name="vehiculo"

placeholder="Vehículo"

>



<input

name="patente"

placeholder="Patente"

>



<select name="estado">


<option value="activo">
Activo
</option>


<option value="inactivo">
Inactivo
</option>


</select>



<button type="submit">

💾 Guardar chofer

</button>



</form>


</div>







<div class="box">


<h3>
📋 Choferes registrados
</h3>



<div class="table-container">


<table>


<thead>


<tr>

<th>ID</th>

<th>Nombre</th>

<th>Teléfono</th>

<th>Vehículo</th>

<th>Patente</th>

<th>Estado</th>

<th>Acciones</th>


</tr>


</thead>




<tbody>



<% choferes.forEach(chofer => { %>



<tr>


<td>
<%= chofer.id %>
</td>


<td>
<%= chofer.nombre %>
</td>


<td>
<%= chofer.telefono || "-" %>
</td>


<td>
<%= chofer.vehiculo || "-" %>
</td>


<td>
<%= chofer.patente || "-" %>
</td>



<td>

<span class="estado">

<%= chofer.estado %>

</span>

</td>



<td>


<a class="btn-editar"
href="/panel/logistica/choferes/editar/<%= chofer.id %>">

✏️ Editar

</a>



<a class="btn-eliminar"
href="/panel/logistica/choferes/eliminar/<%= chofer.id %>"
onclick="return confirm('¿Eliminar chofer?')">

🗑️ Eliminar

</a>


</td>



</tr>



<% }) %>



</tbody>



</table>



</div>


</div>




</div>



</body>


</html>