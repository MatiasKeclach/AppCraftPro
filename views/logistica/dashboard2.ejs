<!DOCTYPE html>
<html lang="es">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Logística - AppCraft Pro</title>

<link rel="stylesheet" href="/css/panel.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>

body{
    margin:0;
    background:#f5f6fa;
    font-family:Arial,Helvetica,sans-serif;
}

.header{
    background:#1e293b;
    color:white;
    padding:20px;
}

.container{

    max-width:1200px;
    margin:auto;
    padding:30px;

}

.grid{

    display:grid;

    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));

    gap:20px;

}

.card{

    background:white;

    border-radius:12px;

    padding:25px;

    cursor:pointer;

    transition:.25s;

    text-align:center;

    box-shadow:0 5px 15px rgba(0,0,0,.08);

}

.card:hover{

    transform:translateY(-5px);

}

.card i{

    font-size:50px;

    color:#2563eb;

    margin-bottom:20px;

}

h2{

margin-top:0;

}

</style>

</head>

<body>

<div class="header">

<h2>📦 Módulo Logística</h2>

<p>Bienvenido <%= username %></p>

</div>

<div class="container">

<div class="grid">

<div class="card" onclick="location.href='/panel/logistica/clientes'">

<i class="fas fa-users"></i>

<h3>Clientes</h3>

</div>

<div class="card" onclick="location.href='/panel/logistica/colectas'">


<div class="card">
<i class="fas fa-truck-loading"></i>
<h3>Colectas</h3>
</div>

<div class="card">
<i class="fas fa-box"></i>
<h3>Paquetes</h3>
</div>

<div class="card">
<i class="fas fa-truck"></i>
<h3>Choferes</h3>
</div>

<div class="card">
<i class="fas fa-clipboard-list"></i>
<h3>Asignaciones</h3>
</div>

<div class="card">
<i class="fas fa-chart-line"></i>
<h3>Reportes</h3>
</div>

</div>

</div>

</body>
</html>