<!DOCTYPE html>
<html lang="es">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Editar Cliente - Logística</title>

<link rel="stylesheet" href="/css/panel.css">


<style>

:root{

--primary:#2563eb;
--dark:#0f172a;
--bg:#f1f5f9;
--card:#ffffff;
--border:#e2e8f0;
--text:#334155;

}


*{
box-sizing:border-box;
}


body{

margin:0;

background:var(--bg);

font-family:Arial,Helvetica,sans-serif;

color:var(--text);

}



.header{

background:linear-gradient(135deg,#0f172a,#1e40af);

color:white;

padding:25px;

}



.container{

max-width:900px;

margin:auto;

padding:25px;

}



.card{

background:white;

padding:25px;

border-radius:18px;

box-shadow:0 10px 25px rgba(0,0,0,.08);

}



h2{

margin-top:0;

}



form{

display:flex;

flex-direction:column;

gap:15px;

}



input{

padding:14px;

border-radius:12px;

border:1px solid #cbd5e1;

font-size:15px;

}



input:focus{

outline:none;

border-color:#2563eb;

}



button{

padding:14px;

border:none;

border-radius:12px;

background:#2563eb;

color:white;

font-size:16px;

font-weight:bold;

cursor:pointer;

}



button:hover{

opacity:.9;

}



a{

display:block;

margin-top:15px;

text-align:center;

text-decoration:none;

color:#2563eb;

}



@media(max-width:600px){

.container{

padding:15px;

}

.card{

padding:18px;

}

}


</style>


</head>


<body>


<div class="header">

<h2>
✏️ Editar Cliente
</h2>

<p>
Usuario: <%= username %>
</p>

</div>



<div class="container">


<div class="card">


<form method="POST" action="/panel/logistica/clientes/editar/<%= cliente.id %>">


<input

name="nombre"

placeholder="Nombre del cliente"

value="<%= cliente.nombre %>"

required

>


<input

name="empresa"

placeholder="Empresa"

value="<%= cliente.empresa || '' %>"

>



<input

name="telefono"

placeholder="Teléfono"

value="<%= cliente.telefono || '' %>"

>



<input

type="email"

name="email"

placeholder="Email"

value="<%= cliente.email || '' %>"

>



<input

name="direccion"

placeholder="Dirección"

value="<%= cliente.direccion || '' %>"

>



<button type="submit">

💾 Guardar cambios

</button>


</form>



<a href="/panel/logistica/clientes">

⬅ Volver a clientes

</a>



</div>


</div>



</body>

</html>