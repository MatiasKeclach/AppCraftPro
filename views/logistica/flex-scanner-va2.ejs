<script
    src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js"
></script>

<script>


let stream = null;

let procesando = false;

let codigosEscaneados = [];


const video =
document.getElementById(
    "video"
);


const canvas =
document.getElementById(
    "canvas"
);


const iniciarCamara =
document.getElementById(
    "iniciarCamara"
);


const capturarEtiqueta =
document.getElementById(
    "capturarEtiqueta"
);


const detenerCamara =
document.getElementById(
    "detenerCamara"
);


const estado =
document.getElementById(
    "scannerEstado"
);


const procesandoBox =
document.getElementById(
    "procesando"
);


const progressBar =
document.getElementById(
    "progressBar"
);


const progressTexto =
document.getElementById(
    "progressTexto"
);


const resultado =
document.getElementById(
    "resultado"
);


const codigoBarras =
document.getElementById(
    "codigoBarras"
);


const duplicado =
document.getElementById(
    "duplicado"
);


const ocrTexto =
document.getElementById(
    "ocrTexto"
);


/* ==============================
INICIAR CAMARA
============================== */

iniciarCamara.addEventListener(
    "click",
    iniciarCamaraFuncion
);


async function iniciarCamaraFuncion(){


    try{


        stream =
        await navigator.mediaDevices
        .getUserMedia({

            video:{

                facingMode:{
                    ideal:"environment"
                },

                width:{
                    ideal:1920
                },

                height:{
                    ideal:1080
                }

            },

            audio:false

        });


        video.srcObject =
        stream;


        iniciarCamara.style.display =
        "none";


        capturarEtiqueta.style.display =
        "inline-block";


        detenerCamara.style.display =
        "inline-block";


        estado.innerHTML =
        "📷 Cámara activa. Enfocá toda la etiqueta.";


    }catch(error){


        console.error(error);


        alert(

            "No se pudo acceder a la cámara.\n\n"

            +

            error.message

        );

    }

}


/* ==============================
DETENER CAMARA
============================== */

detenerCamara.addEventListener(
    "click",
    detenerCamaraFuncion
);


function detenerCamaraFuncion(){


    if(stream){

        stream
        .getTracks()
        .forEach(
            track =>
            track.stop()
        );

    }


    stream =
    null;


    video.srcObject =
    null;


    iniciarCamara.style.display =
    "inline-block";


    capturarEtiqueta.style.display =
    "none";


    detenerCamara.style.display =
    "none";


    estado.innerHTML =
    "Cámara detenida";

}


/* ==============================
CAPTURAR ETIQUETA
============================== */

capturarEtiqueta.addEventListener(
    "click",
    capturarEtiquetaFuncion
);


async function capturarEtiquetaFuncion(){


    if(procesando){

        return;

    }


    if(!stream){

        alert(
            "Primero iniciá la cámara."
        );

        return;

    }


    const width =
    video.videoWidth;


    const height =
    video.videoHeight;


    if(!width || !height){

        alert(
            "La cámara todavía no está lista."
        );

        return;

    }


    canvas.width =
    width;


    canvas.height =
    height;


    const ctx =
    canvas.getContext(
        "2d"
    );


    ctx.drawImage(

        video,

        0,

        0,

        width,

        height

    );


    const imagen =
    canvas.toDataURL(
        "image/jpeg",
        0.95
    );


    detenerCamaraFuncion();


    await procesarOCR(
        imagen
    );

}


/* ==============================
OCR
============================== */

async function procesarOCR(
    imagen
){


    procesando =
    true;


    procesandoBox.style.display =
    "block";


    resultado.style.display =
    "none";


    progressBar.style.width =
    "5%";


    progressTexto.innerText =
    "Preparando OCR...";


    try{


        const worker =
        await Tesseract.createWorker(
            "spa",
            1,
            {

                logger:
                mensaje => {

                    if(
                        mensaje.status ===
                        "recognizing text"
                    ){

                        const porcentaje =
                        Math.round(
                            mensaje.progress *
                            100
                        );


                        progressBar.style.width =
                        porcentaje
                        +
                        "%";


                        progressTexto.innerText =

                        "Leyendo texto: "

                        +

                        porcentaje

                        +

                        "%";

                    }

                }

            }
        );


        progressTexto.innerText =
        "Analizando etiqueta completa...";


        const resultadoOCR =
        await worker.recognize(
            imagen
        );


        const texto =
        resultadoOCR.data.text
        ||
        "";


        await worker.terminate();


        progressBar.style.width =
        "100%";


        progressTexto.innerText =
        "✅ OCR terminado";


        console.log(
            "TEXTO OCR:",
            texto
        );


        ocrTexto.value =
        texto;


        analizarTexto(
            texto
        );


        generarCodigoInterno();


        resultado.style.display =
        "block";


        estado.innerHTML =
        "✅ Etiqueta analizada correctamente. Revisá los datos detectados.";


    }catch(error){


        console.error(
            "Error OCR:",
            error
        );


        alert(

            "Error realizando OCR:\n\n"

            +

            error.message

        );

    }finally{


        procesando =
        false;


    }

}


/* ==============================
GENERAR CODIGO INTERNO
============================== */

function generarCodigoInterno(){


    const numero =
    Date.now()
    .toString()
    .slice(-6);


    document
    .getElementById(
        "codigoInterno"
    )
    .innerText =

    "PKG-"

    +

    numero;

}


/* ==============================
ANALIZAR OCR
============================== */

function analizarTexto(
    texto
){


    const lineas =

    texto
    .split("\n")
    .map(
        linea =>
        linea.trim()
    )
    .filter(
        linea =>
        linea.length > 0
    );


    console.log(
        "LINEAS OCR:",
        lineas
    );


    /* ==============================
    TELEFONO
    ============================== */

    const telefonoEncontrado =

    texto.match(

        /(?:\+54\s?)?(?:9\s?)?(?:11\s?)?[\d\s\-]{7,15}/

    );


    if(
        telefonoEncontrado
    ){

        document
        .getElementById(
            "telefono"
        )
        .value =

        telefonoEncontrado[0]
        .trim();

    }


    /* ==============================
    CODIGO BARRAS
    ============================== */

    const numeros =

    texto.match(
        /\b\d{5,20}\b/g
    );


    if(
        numeros &&
        numeros.length
    ){

        const candidato =

        numeros
        .sort(
            (a,b) =>
            b.length -
            a.length
        )[0];


        codigoBarras.value =
        candidato;


        comprobarDuplicado(
            candidato
        );

    }


    /* ==============================
    FECHA
    ============================== */

    const fecha =

    texto.match(

        /\b\d{1,2}[\/\-]\d{1,2}[\/\-]\d{2,4}\b/

    );


    if(fecha){

        document
        .getElementById(
            "fechaEmision"
        )
        .value =

        fecha[0];

    }


    /* ==============================
    PESO
    ============================== */

    const peso =

    texto.match(

        /(\d+(?:[.,]\d+)?)\s*(kg|kgs|kilos)\b/i

    );


    if(peso){

        document
        .getElementById(
            "peso"
        )
        .value =

        peso[0];

    }


    /* ==============================
    BULTOS
    ============================== */

    const bultos =

    texto.match(

        /(?:bultos?|cantidad)\s*[:\-]?\s*(\d+)/i

    );


    if(bultos){

        document
        .getElementById(
            "bultos"
        )
        .value =

        bultos[1];

    }


    /* ==============================
    NUMERO DE BULTO
    ============================== */

    const numeroBulto =

    texto.match(

        /(?:bulto)\s*(\d+)\s*(?:de|\/)\s*(\d+)/i

    );


    if(numeroBulto){

        document
        .getElementById(
            "numeroBulto"
        )
        .value =

        numeroBulto[1]
        +
        " de "
        +
        numeroBulto[2];

    }


    /* ==============================
    REMITENTE
    ============================== */

    const remitente =

    buscarCampo(

        texto,

        [
            "remitente",
            "sender",
            "from"
        ]

    );


    if(remitente){

        document
        .getElementById(
            "remitente"
        )
        .value =

        remitente;

    }


    /* ==============================
    DESTINATARIO
    ============================== */

    const destinatario =

    buscarCampo(

        texto,

        [
            "destinatario",
            "consignatario",
            "recipient",
            "to"
        ]

    );


    if(destinatario){

        document
        .getElementById(
            "destinatario"
        )
        .value =

        destinatario;

    }


    /* ==============================
    DIRECCION
    ============================== */

    const direccion =

    buscarDireccion(
        lineas
    );


    if(direccion){

        document
        .getElementById(
            "direccion"
        )
        .value =

        direccion;

    }


    /* ==============================
    LOCALIDAD
    ============================== */

    const localidad =

    buscarLocalidad(
        lineas
    );


    if(localidad){

        document
        .getElementById(
            "localidad"
        )
        .value =

        localidad;

    }


    /* ==============================
    ZONA
    ============================== */

    const zona =

    buscarZona(
        lineas,
        localidad
    );


    if(zona){

        document
        .getElementById(
            "zona"
        )
        .value =

        zona;

    }


}


/* ==============================
BUSCAR CAMPO
============================== */

function buscarCampo(
    texto,
    etiquetas
){


    const lineas =

    texto
    .split("\n")
    .map(
        x =>
        x.trim()
    )
    .filter(Boolean);


    for(
        let i = 0;
        i < lineas.length;
        i++
    ){


        const linea =
        lineas[i]
        .toLowerCase();


        for(
            const etiqueta
            of etiquetas
        ){


            if(
                linea.includes(
                    etiqueta
                )
            ){


                let valor =

                lineas[i]
                .replace(
                    new RegExp(
                        etiqueta,
                        "i"
                    ),
                    ""
                )
                .replace(
                    /^[:\-\s]+/,
                    ""
                )
                .trim();


                if(
                    valor.length > 2
                ){

                    return valor;

                }


                if(
                    lineas[i+1]
                ){

                    return lineas[i+1];

                }

            }

        }

    }


    return "";

}


/* ==============================
BUSCAR DIRECCION
============================== */

function buscarDireccion(
    lineas
){


    const palabrasDireccion = [

        "calle",

        "avenida",

        "av.",

        "av ",

        "pasaje",

        "pje.",

        "boulevard",

        "ruta",

        "diagonal"

    ];


    for(
        const linea
        of lineas
    ){


        const minuscula =
        linea.toLowerCase();


        if(

            palabrasDireccion.some(
                palabra =>
                minuscula.includes(
                    palabra
                )
            )

        ){

            return linea;

        }


        if(
            /\d{3,5}/.test(
                linea
            )
            &&
            /[a-záéíóúñ]/i.test(
                linea
            )
        ){

            return linea;

        }

    }


    return "";

}


/* ==============================
BUSCAR LOCALIDAD
============================== */

function buscarLocalidad(
    lineas
){


    for(
        const linea
        of lineas
    ){


        const texto =
        linea.trim();


        if(
            /^caba$/i.test(
                texto
            )
        ){

            return "CABA";

        }


        if(
            /capital federal/i.test(
                texto
            )
        ){

            return "CABA";

        }


        if(
            /buenos aires/i.test(
                texto
            )
        ){

            return texto;

        }

    }


    return "";

}


/* ==============================
BUSCAR ZONA
============================== */

function buscarZona(
    lineas,
    localidad
){


    const ignorar = [

        "caba",

        "capital federal",

        "buenos aires",

        "argentina",

        "destinatario",

        "remitente",

        "teléfono",

        "telefono",

        "dirección",

        "direccion",

        "peso",

        "bultos",

        "orden",

        "fecha"

    ];


    for(
        const linea
        of lineas
    ){


        const texto =
        linea.trim();


        if(
            texto.length < 3
        ){

            continue;

        }


        if(
            ignorar.some(
                palabra =>
                texto
                .toLowerCase()
                .includes(
                    palabra
                )
            )
        ){

            continue;

        }


        if(
            localidad
            &&
            texto.toLowerCase()
            ===
            localidad.toLowerCase()
        ){

            continue;

        }


        /*
        
        Si la línea parece
        un nombre geográfico,
        la proponemos como zona.

        No usamos una lista cerrada.

        */

        if(

            /^[A-Za-zÁÉÍÓÚáéíóúÑñ\s]+$/
            .test(
                texto
            )

        ){

            return texto;

        }

    }


    return "";

}


/* ==============================
DUPLICADOS
============================== */

function comprobarDuplicado(
    codigo
){


    if(
        !codigo
    ){

        return;

    }


    const indice =

    codigosEscaneados
    .indexOf(
        codigo
    );


    if(
        indice !== -1
    ){

        duplicado.style.display =
        "block";


        estado.innerHTML =

        "⚠️ Código repetido. Este paquete ya fue escaneado en esta sesión.";

        return;

    }


    codigosEscaneados.push(
        codigo
    );


    duplicado.style.display =
    "none";


}


