<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{

    background:#f4f6f9;

    font-family:
    Arial,
    Helvetica,
    sans-serif;

    color:#1e293b;

}

.header{

    background:#1e293b;

    color:white;

    padding:22px;

    box-shadow:
    0 3px 15px
    rgba(0,0,0,.15);

}

.header h1{

    font-size:26px;

    margin-bottom:7px;

}

.header p{

    opacity:.85;

    font-size:14px;

}

.container{

    width:100%;

    max-width:1100px;

    margin:auto;

    padding:20px;

}

.back{

    display:inline-flex;

    align-items:center;

    gap:8px;

    margin-bottom:20px;

    text-decoration:none;

    color:#2563eb;

    font-weight:bold;

}

.panel{

    background:white;

    border-radius:16px;

    padding:25px;

    box-shadow:
    0 5px 20px
    rgba(0,0,0,.08);

    margin-bottom:20px;

}

.panel h2{

    font-size:20px;

    margin-bottom:20px;

}

label{

    display:block;

    font-weight:bold;

    margin-bottom:8px;

}

select{

    width:100%;

    padding:14px;

    border:1px solid #d1d5db;

    border-radius:10px;

    font-size:16px;

    background:white;

}

.scanner{

    margin-top:20px;

    background:#0f172a;

    border-radius:16px;

    padding:20px;

    text-align:center;

    color:white;

}

#video{

    width:100%;

    max-width:700px;

    margin:auto;

    display:block;

    border-radius:12px;

    background:#000;

}

.camera-wrapper{

    position:relative;

    width:100%;

    max-width:700px;

    margin:auto;

}

.scan-frame{

    position:absolute;

    top:10%;

    left:5%;

    width:90%;

    height:80%;

    border:3px solid #22c55e;

    border-radius:12px;

    pointer-events:none;

}

.btn{

    border:none;

    border-radius:10px;

    padding:14px 22px;

    font-size:16px;

    font-weight:bold;

    cursor:pointer;

    margin-top:15px;

    transition:.2s;

}

.btn:hover{

    transform:translateY(-2px);

}

.btn-primary{

    background:#2563eb;

    color:white;

}

.btn-success{

    background:#16a34a;

    color:white;

}

.btn-danger{

    background:#dc2626;

    color:white;

}

.btn-secondary{

    background:#64748b;

    color:white;

}

.estado{

    background:#f1f5f9;

    padding:15px;

    border-radius:10px;

    margin-top:15px;

    line-height:24px;

}

.codigo{

    font-size:22px;

    font-weight:bold;

    color:#2563eb;

    margin-top:5px;

}

.resultado{

    display:none;

}

.procesando{

    display:none;

    margin-top:20px;

    padding:20px;

    background:#eff6ff;

    border-radius:12px;

    text-align:center;

    color:#1d4ed8;

    font-weight:bold;

}

.progress-container{

    width:100%;

    height:12px;

    background:#e2e8f0;

    border-radius:20px;

    margin-top:15px;

    overflow:hidden;

}

.progress-bar{

    width:0%;

    height:100%;

    background:#2563eb;

    transition:width .3s;

}

.form-grid{

    display:grid;

    grid-template-columns:
    repeat(
        auto-fit,
        minmax(220px,1fr)
    );

    gap:15px;

}

input,
textarea{

    width:100%;

    padding:12px;

    border:1px solid #d1d5db;

    border-radius:9px;

    font-size:15px;

}

input:focus,
textarea:focus,
select:focus{

    outline:none;

    border-color:#2563eb;

    box-shadow:
    0 0 0 3px
    rgba(37,99,235,.12);

}

textarea{

    min-height:90px;

    resize:vertical;

}

.ocr-text{

    margin-top:20px;

}

.ocr-text textarea{

    min-height:220px;

    font-family:monospace;

    font-size:13px;

}

.duplicado{

    display:none;

    margin-top:15px;

    padding:15px;

    background:#fee2e2;

    color:#991b1b;

    border-radius:10px;

    font-weight:bold;

}

.captura-info{

    margin-top:15px;

    padding:12px;

    background:#1e293b;

    border-radius:10px;

    font-size:14px;

    line-height:22px;

}

#canvas{

    display:none;

}

@media(max-width:600px){

    .container{

        padding:12px;

    }

    .panel{

        padding:18px;

    }

    .header h1{

        font-size:22px;

    }

    .btn{

        width:100%;

    }

}

</style>

</head>

