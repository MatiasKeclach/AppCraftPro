        procesandoBox.style.display =
        "none";


        codigoBarras.value =
        "";


        ocrTexto.value =
        "";


        document
        .querySelectorAll(
            "#resultado input"
        )
        .forEach(
            input => {

                if(
                    input.id !==
                    "codigoBarras"
                ){

                    input.value =
                    "";

                }

            }
        );


        document
        .getElementById(
            "observaciones"
        )
        .value =
        "";


        document
        .getElementById(
            "codigoInterno"
        )
        .innerText =
        "Generando...";


        iniciarCamaraFuncion();

    }
);


