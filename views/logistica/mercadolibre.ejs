</div>

<!-- TOAST -->

<div
    id="toast"
    class="toast"
>
    Sincronización iniciada...
</div>

<script>

    // =====================================================
    // SINCRONIZAR MERCADO LIBRE
    // =====================================================

    async function sincronizar() {

        const button =
            document.getElementById(
                "syncButton"
            );

        const toast =
            document.getElementById(
                "toast"
            );


        button.disabled =
            true;


        button.innerHTML =

            '<i class="fas fa-spinner fa-spin"></i> Sincronizando...';


        toast.classList.add(
            "show"
        );


        try {

            const response =
                await fetch(
                    "/panel/logistica/mercadolibre/sincronizar",
                    {

                        method:
                            "POST",

                        headers: {

                            "Content-Type":
                                "application/json"

                        }

                    }
                );


            const data =
                await response.json();


            if (
                data.ok
            ) {

                toast.innerText =
                    data.mensaje ||
                    "Sincronización completada.";

            } else {

                toast.innerText =
                    data.mensaje ||
                    "No se pudo sincronizar.";

            }


        } catch (
            error
        ) {

            console.error(
                error
            );


            toast.innerText =
                "Error de conexión con el servidor.";

        }


        setTimeout(
            () => {

                toast.classList.remove(
                    "show"
                );

            },
            3500
        );


        button.disabled =
            false;


        button.innerHTML =

            '<i class="fas fa-rotate"></i> Sincronizar';

    }


    // =====================================================
    // CONSULTAR ESTADO
    // =====================================================

    async function cargarEstado() {

        try {

            const response =
                await fetch(
                    "/panel/logistica/mercadolibre/estado"
                );


            const data =
                await response.json();


            if (
                data.ok &&
                data.conectado
            ) {

                const badge =
                    document.getElementById(
                        "connectionStatus"
                    );


                const icon =
                    document.getElementById(
                        "statusIcon"
                    );


                const account =
                    document.getElementById(
                        "accountStatus"
                    );


                badge.classList.add(
                    "connected"
                );


                badge.innerHTML =

                    '<span class="status-dot"></span> Conectado';


                icon.classList.add(
                    "connected"
                );


                icon.innerHTML =

                    '<i class="fas fa-check"></i>';


                account.className =
                    "online";


                account.innerHTML =

                    '<i class="fas fa-circle-check"></i> Conectada';

            }

        } catch (
            error
        ) {

            console.error(
                "Error consultando estado:",
                error
            );

        }

    }


    // =====================================================
    // INICIAR
    // =====================================================

    document.addEventListener(
        "DOMContentLoaded",
        cargarEstado
    );

</script>

</body>

</html>
