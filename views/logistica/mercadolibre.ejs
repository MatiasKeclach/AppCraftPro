                <span>
                    Base de datos
                </span>

                <strong class="online">

                    <i class="fas fa-database"></i>

                    Persistente

                </strong>

            </div>



            <div class="integration-row">

                <span>
                    Cuenta conectada
                </span>

                <strong
                    id="accountStatus"
