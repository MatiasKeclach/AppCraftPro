<!-- =====================================================
     TOAST
====================================================== -->


<div
    id="toast"
    class="toast"
>
    Sistema listo.
</div>



<script>

/* =========================================================
   ESTADO GLOBAL
========================================================= */

let paquetesNuevos = [];



/* =========================================================
   TOAST
========================================================= */

function mostrarToast(mensaje){

    const toast =
        document.getElementById("toast");


    toast.innerText =
        mensaje;


    toast.classList.add("show");


    setTimeout(() => {

        toast.classList.remove("show");

    },3500);

}



/* =========================================================
   SINCRONIZAR MERCADO LIBRE
========================================================= */

async function sincronizar(){


    const button =
        document.getElementById("syncButton");


    const status =
        document.getElementById("syncStatus");


    button.disabled =
        true;


    button.innerHTML =

        '<i class="fas fa-spinner fa-spin"></i> Sincronizando...';


    status.innerHTML =

        '<i class="fas fa-spinner fa-spin"></i> Consultando Mercado Libre...';


    mostrarToast(
        "Sincronización iniciada..."
    );


    try{


        const response =
            await fetch(
                "/panel/logistica/mercadolibre/sincronizar",
                {

                    method:
                        "POST",

                    headers:{

                        "Content-Type":
                            "application/json"

                    }

                }
            );


        const data =
            await response.json();


        if(!response.ok){

            throw new Error(
                data.mensaje ||
                "Error de sincronización"
            );

        }


        if(data.ok){


            mostrarToast(

                data.mensaje ||

                "Sincronización completada."

            );


            status.innerHTML =

                '<i class="fas fa-circle-check"></i> Sincronización completada';


            if(
                data.nuevos &&
                Array.isArray(data.nuevos)
            ){

                cargarPaquetesNuevos(
                    data.nuevos
                );

            }else{

                cargarPaquetesNuevos();

            }


            cargarResumen();


        }else{


            throw new Error(

                data.mensaje ||

                "No se pudo sincronizar."

            );


        }


    }catch(error){


        console.error(
            "Error sincronizando:",
            error
        );


        status.innerHTML =

            '<i class="fas fa-circle-xmark"></i> Error de sincronización';


        mostrarToast(

            error.message ||

            "Error de conexión con el servidor."

        );


    }finally{


        button.disabled =
            false;


        button.innerHTML =

            '<i class="fas fa-rotate"></i> Sincronizar ahora';


    }


}



/* =========================================================
   CARGAR PAQUETES NUEVOS
========================================================= */

async function cargarPaquetesNuevos(
    datos = null
){


    try{


        let paquetes =
            datos;


        if(!paquetes){


            const response =
                await fetch(
                    "/panel/logistica/mercadolibre/nuevos"
                );


            const data =
                await response.json();


            if(
                data.ok &&
                Array.isArray(data.paquetes)
            ){

                paquetes =
                    data.paquetes;

            }else{

                paquetes =
                    [];

            }


        }


        paquetesNuevos =
            paquetes || [];


        renderizarPaquetesNuevos();


    }catch(error){


        console.error(
            "Error cargando paquetes nuevos:",
            error
        );


    }


}



/* =========================================================
   RENDER PAQUETES
========================================================= */

function renderizarPaquetesNuevos(){


    const section =
        document.getElementById(
            "newPackagesSection"
        );


    const body =
        document.getElementById(
            "newPackagesBody"
        );


    const count =
        document.getElementById(
            "newCount"
        );


    const newCounter =
        document.getElementById(
            "newShipments"
        );


    count.innerText =

        paquetesNuevos.length +

        (
            paquetesNuevos.length === 1

            ? " nuevo"

            : " nuevos"

        );


    newCounter.innerText =

        paquetesNuevos.length;


    if(
        !paquetesNuevos.length
    ){


        section.classList.add(
            "hidden"
        );


        body.innerHTML =
            "";


        return;


    }


    section.classList.remove(
        "hidden"
    );


    body.innerHTML =

        paquetesNuevos.map(

            (paquete,index) => {


                const codigo =

                    paquete.codigo_externo ||

                    paquete.codigo ||

                    paquete.shipment_id ||

                    "Sin código";


                const destinatario =

                    paquete.destinatario ||

                    paquete.receiver_name ||

                    "Sin destinatario";


                const direccion =

                    paquete.direccion ||

                    paquete.address ||

                    "Sin dirección";


                const localidad =

                    paquete.localidad ||

                    paquete.city ||

                    "-";


                return `

                <tr
                    data-search="
                        ${codigo}
                        ${destinatario}
                        ${direccion}
                        ${localidad}
                    "
                >

                    <td>

                        <input

                            type="checkbox"

                            class="package-check package-item"

                            value="${escapeHtml(
                                paquete.shipment_id ||
                                paquete.id ||
                                codigo
                            )}"

                            data-index="${index}"

                        >

                    </td>


                    <td>

                        <strong>

                            ${escapeHtml(codigo)}

                        </strong>

                    </td>


                    <td>

                        ${escapeHtml(destinatario)}

                    </td>


                    <td>

                        ${escapeHtml(direccion)}

                    </td>


                    <td>

                        ${escapeHtml(localidad)}

                    </td>


                    <td>

                        <span class="badge badge-flex">

                            <i class="fas fa-bolt"></i>

                            FLEX

                        </span>

                    </td>


                    <td>

                        <span class="badge badge-received">

                            Recibido

                        </span>

                    </td>


                </tr>

                `;


            }

        ).join("");


}



/* =========================================================
   SELECCIONAR TODOS
========================================================= */

function seleccionarTodos(){


    const master =
        document.getElementById(
            "selectAll"
        );


    const checks =
        document.querySelectorAll(
            ".package-item"
        );


    const estado =
        master.checked;


    checks.forEach(

        checkbox => {

            checkbox.checked =
                estado;

        }

    );


}



/* =========================================================
   ASIGNAR SELECCIONADOS
========================================================= */

async function asignarSeleccionados(){


    const clienteSelect =
        document.getElementById(
            "clienteSelect"
        );


    const clienteId =
        clienteSelect.value;


    if(!clienteId){

        mostrarToast(
            "Seleccioná un cliente antes de continuar."
        );

        return;

    }


    const seleccionados =

        Array.from(

            document.querySelectorAll(
                ".package-item:checked"
            )

        ).map(

            checkbox =>

                paquetesNuevos[
                    Number(
                        checkbox.dataset.index
                    )
                ]

        );


    if(
        !seleccionados.length
    ){

        mostrarToast(
            "Seleccioná al menos un paquete."
        );

        return;

    }


    try{


        mostrarToast(
            "Guardando paquetes..."
        );


        const response =

            await fetch(

                "/panel/logistica/mercadolibre/asignar",

                {

                    method:
                        "POST",

                    headers:{

                        "Content-Type":
                            "application/json"

                    },

                    body:

                        JSON.stringify({

                            cliente_id:
                                clienteId,

                            paquetes:
                                seleccionados

                        })

                }

            );


        const data =
            await response.json();


        if(!response.ok){

            throw new Error(

                data.mensaje ||

                "Error guardando paquetes"

            );

        }


        if(data.ok){


            mostrarToast(

                data.mensaje ||

                "Paquetes guardados correctamente."

            );


            paquetesNuevos =

                paquetesNuevos.filter(

                    paquete =>

                        !seleccionados.includes(
                            paquete
                        )

                );


            renderizarPaquetesNuevos();


            cargarResumen();


            clienteSelect.value =
                "";


            document.getElementById(
                "selectAll"
            ).checked =
                false;


        }else{


            throw new Error(

                data.mensaje ||

                "No se pudieron guardar los paquetes."

            );


        }


    }catch(error){


        console.error(
            error
        );


        mostrarToast(

            error.message ||

            "Error guardando paquetes."

        );


    }


}



/* =========================================================
   FILTRAR PAQUETES
========================================================= */

function filtrarPaquetes(){


    const search =

        document
        .getElementById(
            "packageSearch"
        )
        .value
        .toLowerCase()
        .trim();


    const rows =

        document.querySelectorAll(

            "#newPackagesBody tr"

        );


    rows.forEach(

        row => {


            const texto =

                row
                .dataset
                .search
                .toLowerCase();


            row.style.display =

                texto.includes(
                    search
                )

                ? ""

                : "none";


        }

    );


}



/* =========================================================
   CARGAR RESUMEN
========================================================= */

async function cargarResumen(){


    try{


        const response =

            await fetch(

                "/panel/logistica/mercadolibre/resumen"

            );


        const data =
            await response.json();


        if(
            !data.ok ||
            !Array.isArray(
                data.clientes
            )
        ){

            return;

        }


        const container =

            document.getElementById(
                "clientSummary"
            );


        if(
            !data.clientes.length
        ){

            container.innerHTML = `

                <div class="client-row">

                    <div class="client-info">

                        <div class="client-avatar">

                            —

                        </div>

                        <div>

                            <div class="client-name">

                                Sin movimientos todavía

                            </div>

                            <div class="client-meta">

                                Los paquetes clasificados aparecerán aquí.

                            </div>

                        </div>

                    </div>

                    <div class="client-count">

                        0

                    </div>

                </div>

            `;

            return;

        }


        container.innerHTML =

            data.clientes.map(

                cliente => `

                    <div class="client-row">

                        <div class="client-info">

                            <div class="client-avatar">

                                ${escapeHtml(

                                    (

                                        cliente.nombre ||

                                        "?"

                                    )

                                    .charAt(0)

                                    .toUpperCase()

                                )}

                            </div>

                            <div>

                                <div class="client-name">

                                    ${escapeHtml(

                                        cliente.nombre ||

                                        "Sin nombre"

                                    )}

                                </div>

                                <div class="client-meta">

                                    Paquetes recibidos hoy

                                </div>

                            </div>

                        </div>

                        <div class="client-count">

                            ${cliente.total || 0}

                        </div>

                    </div>

                `

            ).join("");


    }catch(error){


        console.error(

            "Error cargando resumen:",

            error

        );


    }


}



/* =========================================================
   ESTADO MERCADO LIBRE
========================================================= */

async function cargarEstado(){


    try{


        const response =

            await fetch(

                "/panel/logistica/mercadolibre/estado"

            );


        const data =

            await response.json();


        if(
            data.ok &&
            data.conectado
        ){


            const badge =

                document.getElementById(

                    "connectionStatus"

                );


            const icon =

                document.getElementById(

                    "statusIcon"

                );


            const account =

                document.getElementById(

                    "accountStatus"

                );


            badge.classList.add(
                "connected"
            );


            badge.innerHTML =

                '<span class="status-dot"></span> Conectado';


            icon.classList.add(
                "connected"
            );


            icon.innerHTML =

                '<i class="fas fa-check"></i>';


            account.className =
                "online";


            account.innerHTML =

                '<i class="fas fa-circle-check"></i> Conectada';


        }else{


            const badge =

                document.getElementById(

                    "connectionStatus"

                );


            badge.innerHTML =

                '<span class="status-dot"></span> No conectado';


        }


    }catch(error){


        console.error(

            "Error consultando estado:",

            error

        );


    }


}



/* =========================================================
   ESCAPE HTML
========================================================= */

function escapeHtml(
    value
){


    if(
        value === null ||
        value === undefined
    ){

        return "";

    }


    return String(value)

        .replace(
            /&/g,
            "&amp;"
        )

        .replace(
            /</g,
            "&lt;"
        )

        .replace(
            />/g,
            "&gt;"
        )

        .replace(
            /"/g,
            "&quot;"
        )

        .replace(
            /'/g,
            "&#039;"
        );

}



/* =========================================================
   INICIO
========================================================= */

document.addEventListener(

    "DOMContentLoaded",

    async () => {


        await cargarEstado();


        await cargarPaquetesNuevos();


        await cargarResumen();


    }

);



/* =========================================================
   ACTUALIZACIÓN AUTOMÁTICA
========================================================= */

setInterval(

    async () => {


        try{


            await cargarPaquetesNuevos();


            await cargarResumen();


        }catch(error){


            console.error(
                "Actualización automática:",
                error
            );


        }


    },

    60000

);

</script>


