            </div>

        </div>


        <div class="stat-card">

            <div class="stat-top">

                <div>

                    <div class="stat-label">
                        Pendientes
                    </div>

                    <div class="stat-value">
                        <%= pendingShipments || 0 %>
                    </div>

                </div>

                <div class="stat-icon">

                    <i class="fas fa-clock"></i>

                </div>

            </div>

        </div>


        <div class="stat-card">

            <div class="stat-top">

                <div>

                    <div class="stat-label">
                        Importados hoy
                    </div>

                    <div class="stat-value">
                        <%= importedToday || 0 %>
                    </div>

                </div>

                <div class="stat-icon">

                    <i class="fas fa-cloud-arrow-down"></i>

                </div>

            </div>

        </div>


        <div class="stat-card">

            <div class="stat-top">

                <div>

                    <div class="stat-label">
                        Última sincronización
                    </div>

                    <div
                        class="stat-value"
                        style="font-size:18px"
                    >

                        <%= lastSync || "Nunca" %>

