    </section>


    <!-- =================================================
         INTEGRATION STATUS
    ================================================== -->

    <section
        class="panel-card"
        style="margin-top:22px"
    >

        <div class="panel-header">

            <h3>
                Estado de integración
            </h3>

            <span>
                AppCraftPro
            </span>

        </div>


        <div class="integration-list">


            <div class="integration-row">

                <span>
                    API Mercado Libre
                </span>

                <strong class="online">

                    <i class="fas fa-circle-check"></i>

                    Disponible

                </strong>

            </div>


            <div class="integration-row">

                <span>
                    OAuth
                </span>

                <strong class="online">

                    <i class="fas fa-circle-check"></i>

                    Configurado

                </strong>

            </div>


            <div class="integration-row">

                <span>
                    Webhook
                </span>

                <strong class="online">

                    <i class="fas fa-circle-check"></i>

                    Activo

                </strong>

            </div>


            <div class="integration-row">

                <span>
                    Cuenta conectada
                </span>

                <strong
                    id="accountStatus"
                    class="offline"
                >

                    <i class="fas fa-circle-xmark"></i>

                    No conectada

                </strong>

            </div>


        </div>

    </section>


</main>
