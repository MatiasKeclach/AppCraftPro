</div>

<!-- =====================================================
     TOAST
====================================================== -->

<div
    id="toast"
    class="toast"
></div>

<script>

/* ============================================================
   ESTADO GLOBAL DEL FRONT
============================================================ */

const ML = {

    sincronizando: false,

    estadoCargando: false,

    ultimaSincronizacion: null

};


/* ============================================================
   ELEMENTOS
============================================================ */

const elementos = {

    syncButton:
        document.getElementById("syncButton"),

    refreshButton:
        document.getElementById("refreshButton"),

    toast:
        document.getElementById("toast"),

    connectionStatus:
        document.getElementById("connectionStatus"),

    statusIcon:
        document.getElementById("statusIcon"),

    accountName:
        document.getElementById("accountName"),

    accountStatus:
        document.getElementById("accountStatus"),

    totalShipments:
        document.getElementById("totalShipments"),

    pendingShipments:
        document.getElementById("pendingShipments"),

    importedToday:
        document.getElementById("importedToday"),

    lastSync:
        document.getElementById("lastSync"),

    loadingState:
        document.getElementById("loadingState"),

    emptyState:
        document.getElementById("emptyState"),

    shipmentsContainer:
        document.getElementById("shipmentsContainer"),

    shipmentsBody:
        document.getElementById("shipmentsBody"),

    shipmentCounter:
        document.getElementById("shipmentCounter")

};


/* ============================================================
   TOAST
============================================================ */

let toastTimer = null;


function mostrarToast(
    mensaje,
    tipo = "normal"
) {

    if (!elementos.toast) {
        return;
    }

    clearTimeout(toastTimer);

    elementos.toast.innerText =
        mensaje || "Operación completada.";

    elementos.toast.className =
        "toast show";

    if (
        tipo === "success" ||
        tipo === "error"
    ) {

        elementos.toast.classList.add(
            tipo
        );

    }

    toastTimer =
        setTimeout(
            () => {

                elementos.toast.classList.remove(
                    "show"
                );

            },
            4000
        );

}


/* ============================================================
   FORMATEAR FECHA
============================================================ */

function formatearFecha(
    fecha
) {

    if (!fecha) {

        return "Nunca";

    }

    try {

        return new Intl.DateTimeFormat(
            "es-AR",
            {

                dateStyle:
                    "short",

                timeStyle:
                    "short"

            }
        ).format(
            new Date(fecha)
        );

    } catch {

        return fecha;

    }

}


/* ============================================================
   CAMBIAR ESTADO VISUAL
============================================================ */

function actualizarEstadoVisual(
    conectado,
    cuenta = null
) {

    const badge =
        elementos.connectionStatus;

    const icon =
        elementos.statusIcon;

    const account =
        elementos.accountStatus;

    if (
        conectado
    ) {

        badge.className =
            "status-badge connected";

        badge.innerHTML =
            `
            <span class="status-dot"></span>
            Conectado
            `;


        icon.className =
            "status-icon connected";

        icon.innerHTML =
            `
            <i class="fas fa-check"></i>
            `;


        account.className =
            "online";

        account.innerHTML =
            `
            <i class="fas fa-circle-check"></i>
            Conectada
            `;


        if (
            cuenta
        ) {

            const nickname =
                cuenta.nickname ||
                "";

            const firstName =
                cuenta.firstName ||
                "";

            const lastName =
                cuenta.lastName ||
                "";

            const nombre =
                nickname ||
                `${firstName} ${lastName}`.trim();


            if (
                nombre
            ) {

                elementos.accountName.innerHTML =
                    `
                    <i class="fas fa-user"></i>
                    Cuenta conectada: ${escaparHTML(nombre)}
                    `;

                elementos.accountName.classList.add(
                    "visible"
                );

            }

        }

        return;

    }


    badge.className =
        "status-badge";

    badge.innerHTML =
        `
        <span class="status-dot"></span>
        No conectado
        `;


    icon.className =
        "status-icon";

    icon.innerHTML =
        `
        <i class="fas fa-link"></i>
        `;


    account.className =
        "offline";

    account.innerHTML =
        `
        <i class="fas fa-circle-xmark"></i>
        No conectada
        `;


    elementos.accountName.innerText =
        "";

    elementos.accountName.classList.remove(
        "visible"
    );

}


/* ============================================================
   ESCAPAR HTML
   Evita insertar texto inseguro en la tabla
============================================================ */

function escaparHTML(
    valor
) {

    if (
        valor === null ||
        valor === undefined
    ) {

        return "";

    }

    return String(valor)
        .replace(
            /&/g,
            "&amp;"
        )
        .replace(
            /</g,
            "&lt;"
        )
        .replace(
            />/g,
            "&gt;"
        )
        .replace(
            /"/g,
            "&quot;"
        )
        .replace(
            /'/g,
            "&#039;"
        );

}


/* ============================================================
   ACTUALIZAR KPI
============================================================ */

function actualizarKPIs(
    data
) {

    if (!data) {
        return;
    }


    if (
        data.totalShipments !== undefined
    ) {

        elementos.totalShipments.innerText =
            Number(
                data.totalShipments
            ) || 0;

    }


    if (
        data.pendingShipments !== undefined
    ) {

        elementos.pendingShipments.innerText =
            Number(
                data.pendingShipments
            ) || 0;

    }


    if (
        data.importedToday !== undefined
    ) {

        elementos.importedToday.innerText =
            Number(
                data.importedToday
            ) || 0;

    }


    if (
        data.lastSync
    ) {

        elementos.lastSync.innerText =
            formatearFecha(
                data.lastSync
            );

    }

}


/* ============================================================
   RENDERIZAR ENVÍOS
   Preparado para cuando el backend devuelva:
   data.envios
   o
   data.shipments
============================================================ */

function renderizarEnvios(
    envios
) {

    if (
        !Array.isArray(envios) ||
        envios.length === 0
    ) {

        elementos.shipmentsContainer.classList.remove(
            "visible"
        );

        elementos.emptyState.style.display =
            "flex";

        elementos.shipmentCounter.innerText =
            "Sin envíos";

        return;

    }


    elementos.emptyState.style.display =
        "none";


    elementos.shipmentsContainer.classList.add(
        "visible"
    );


    elementos.shipmentCounter.innerText =
        `${envios.length} envío${envios.length === 1 ? "" : "s"}`;


    elementos.shipmentsBody.innerHTML =
        envios
            .map(
                envio => {

                    const codigo =
                        envio.codigo_externo ||
                        envio.codigo ||
                        envio.shipment_id ||
                        envio.id ||
                        "-";


                    const destinatario =
                        envio.destinatario ||
                        envio.receiver_name ||
                        envio.nombre_destinatario ||
                        "-";


                    const direccion =
                        envio.direccion ||
                        envio.address ||
                        envio.shipping_address ||
                        "-";


                    const localidad =
                        envio.localidad ||
                        envio.city ||
                        envio.ciudad ||
                        "-";


                    const estado =
                        envio.estado ||
                        envio.status ||
                        envio.status_name ||
                        "Pendiente";


                    return `

                    <tr>

                        <td>

                            <span class="shipment-code">

                                ${escaparHTML(codigo)}

                            </span>

                        </td>

                        <td>
                            ${escaparHTML(destinatario)}
                        </td>

                        <td>
                            ${escaparHTML(direccion)}
                        </td>

                        <td>
                            ${escaparHTML(localidad)}
                        </td>

                        <td>

                            <span class="shipment-status">

                                ${escaparHTML(estado)}

                            </span>

                        </td>

                    </tr>

                    `;

                }
            )
            .join("");

}


/* ============================================================
   CARGAR ESTADO MERCADO LIBRE
============================================================ */

async function cargarEstado(
    mostrarMensaje = false
) {

    if (
        ML.estadoCargando
    ) {

        return;

    }


    ML.estadoCargando =
        true;


    if (
        elementos.refreshButton
    ) {

        elementos.refreshButton.disabled =
            true;

        elementos.refreshButton.innerHTML =
            `
            <i class="fas fa-spinner fa-spin"></i>
            Consultando...
            `;

    }


    try {

        const response =
            await fetch(
                "/panel/logistica/mercadolibre/estado",
                {

                    method:
                        "GET",

                    headers: {

                        "Accept":
                            "application/json"

                    },

                    cache:
                        "no-store"

                }
            );


        const data =
            await response.json();


        if (
            !response.ok
        ) {

            throw new Error(
                data.mensaje ||
                "No se pudo consultar el estado."
            );

        }


        actualizarEstadoVisual(

            data.conectado === true,

            data.cuenta || null

        );


        if (
            data.totalShipments !== undefined ||
            data.pendingShipments !== undefined ||
            data.importedToday !== undefined
        ) {

            actualizarKPIs(
                data
            );

        }


        if (
            Array.isArray(
                data.envios
            )
        ) {

            renderizarEnvios(
                data.envios
            );

        }


        if (
            mostrarMensaje
        ) {

            mostrarToast(
                data.conectado
                    ? "Mercado Libre está conectado correctamente."
                    : "La cuenta de Mercado Libre no está conectada.",
                data.conectado
                    ? "success"
                    : "normal"
            );

        }


    } catch (
        error
    ) {

        console.error(
            "Error consultando estado Mercado Libre:",
            error
        );


        actualizarEstadoVisual(
            false
        );


        if (
            mostrarMensaje
        ) {

            mostrarToast(
                "No se pudo consultar el estado de Mercado Libre.",
                "error"
            );

        }

    } finally {

        ML.estadoCargando =
            false;


        if (
            elementos.refreshButton
        ) {

            elementos.refreshButton.disabled =
                false;

            elementos.refreshButton.innerHTML =
                `
                <i class="fas fa-arrows-rotate"></i>
                Actualizar
                `;

        }

    }

}


/* ============================================================
   SINCRONIZAR
============================================================ */

async function sincronizar() {

    if (
        ML.sincronizando
    ) {

        return;

    }


    ML.sincronizando =
        true;


    const button =
        elementos.syncButton;


    const textoOriginal =
        `
        <i class="fas fa-rotate"></i>
        Sincronizar
        `;


    button.disabled =
        true;


    button.innerHTML =
        `
        <i class="fas fa-spinner fa-spin"></i>
        Sincronizando...
        `;


    elementos.loadingState.classList.add(
        "visible"
    );


    elementos.emptyState.style.display =
        "none";


    try {

        const response =
            await fetch(
                "/panel/logistica/mercadolibre/sincronizar",
                {

                    method:
                        "POST",

                    headers: {

                        "Content-Type":
                            "application/json",

                        "Accept":
                            "application/json"

                    },

                    body:
                        JSON.stringify({})

                }
            );


        let data =
            null;


        try {

            data =
                await response.json();

        } catch {

            data =
                {};

        }


        /* =================================================
           SESIÓN VENCIDA
        ================================================= */

        if (
            response.status === 401
        ) {

            actualizarEstadoVisual(
                false
            );


            mostrarToast(
                data.mensaje ||
                "La sesión de Mercado Libre expiró. Volvé a conectar la cuenta.",
                "error"
            );


            return;

        }


        /* =================================================
           ERROR GENERAL
        ================================================= */

        if (
            !response.ok ||
            data.ok === false
        ) {

            throw new Error(

                data.mensaje ||
                "No se pudo completar la sincronización."

            );

        }


        /* =================================================
           ACTUALIZAR CUENTA
        ================================================= */

        actualizarEstadoVisual(

            true,

            data.cuenta || null

        );


        /* =================================================
           ACTUALIZAR KPI
        ================================================= */

        actualizarKPIs(
            data
        );


        /* =================================================
           ACTUALIZAR ÚLTIMA SINCRONIZACIÓN
        ================================================= */

        const ahora =
            new Date();


        elementos.lastSync.innerText =
            formatearFecha(
                ahora
            );


        ML.ultimaSincronizacion =
            ahora;


        /* =================================================
           MOSTRAR ENVÍOS
        ================================================= */

        const envios =
            Array.isArray(
                data.envios
            )
                ? data.envios
                : Array.isArray(
                    data.shipments
                )
                    ? data.shipments
                    : null;


        if (
            envios
        ) {

            renderizarEnvios(
                envios
            );

        }


        /* =================================================
           MENSAJE
        ================================================= */

        mostrarToast(

            data.mensaje ||
            "Sincronización completada correctamente.",

            "success"

        );


        /* =================================================
           VOLVER A CONSULTAR ESTADO
        ================================================= */

        await cargarEstado(
            false
        );


    } catch (
        error
    ) {

        console.error(
            "Error sincronizando Mercado Libre:",
            error
        );


        mostrarToast(

            error.message ||
            "Error de conexión con el servidor.",

            "error"

        );


    } finally {

        ML.sincronizando =
            false;


        elementos.loadingState.classList.remove(
            "visible"
        );


        button.disabled =
            false;


        button.innerHTML =
            textoOriginal;

    }

}


/* ============================================================
   INICIO
============================================================ */

document.addEventListener(

    "DOMContentLoaded",

    async () => {

        await cargarEstado(
            false
        );

    }

);


/* ============================================================
   AUTO ACTUALIZACIÓN
   Cada 60 segundos consulta el estado.
============================================================ */

setInterval(

    () => {

        if (
            !ML.sincronizando &&
            !ML.estadoCargando
        ) {

            cargarEstado(
                false
            );

        }

    },

    60000

);

</script>

