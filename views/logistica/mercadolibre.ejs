
<!DOCTYPE html>
<html lang="es">

<head>

<meta charset="UTF-8">

<meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
>

<title>
    Mercado Libre | AppCraftPro Logistics
</title>

<link
    rel="stylesheet"
    href="/css/panel.css"
>

<link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
>

<style>

/* =========================================================
   APPCRAFTPRO LOGISTICS
   MERCADO LIBRE COMMAND CENTER
========================================================= */

:root{

    --primary:#2563eb;
    --primary-dark:#1d4ed8;

    --success:#16a34a;
    --warning:#d97706;
    --danger:#dc2626;

    --dark:#0f172a;
    --dark-2:#1e293b;

    --text:#172033;
    --muted:#64748b;

    --border:#e5e7eb;

    --bg:#f5f7fb;

    --card:#ffffff;

    --shadow:
        0 10px 35px
        rgba(15,23,42,.06);

    --radius:18px;

}


/* =========================================================
   RESET
========================================================= */

*{

    margin:0;

    padding:0;

    box-sizing:border-box;

}


body{

    font-family:
        Inter,
        Arial,
        Helvetica,
        sans-serif;

    background:
        var(--bg);

    color:
        var(--text);

}


/* =========================================================
   WRAPPER
========================================================= */

.ml-wrapper{

    min-height:
        100vh;

}


/* =========================================================
   HEADER
========================================================= */

.ml-header{

    background:

        radial-gradient(
            circle at top right,
            rgba(37,99,235,.30),
            transparent 35%
        ),

        linear-gradient(
            135deg,
            #0f172a,
            #1e293b
        );

    color:
        white;

    padding:
        24px 35px;

    display:
        flex;

    align-items:
        center;

    justify-content:
        space-between;

    gap:
        20px;

    box-shadow:
        0 8px 30px
        rgba(15,23,42,.18);

}


.header-left{

    display:
        flex;

    align-items:
        center;

    gap:
        16px;

}


.ml-logo{

    width:
        58px;

    height:
        58px;

    border-radius:
        16px;

    display:
        flex;

    align-items:
        center;

    justify-content:
        center;

    background:
        #ffe600;

    color:
        #111827;

    font-size:
        26px;

    box-shadow:
        0 10px 25px
        rgba(0,0,0,.25);

}


.header-title h1{

    font-size:
        24px;

    margin-bottom:
        5px;

}


.header-title p{

    color:
        #cbd5e1;

    font-size:
        13px;

}


.header-actions{

    display:
        flex;

    align-items:
        center;

    gap:
        10px;

    flex-wrap:
        wrap;

}


/* =========================================================
   BUTTONS
========================================================= */

.btn{

    border:
        none;

    border-radius:
        11px;

    padding:
        11px 17px;

    cursor:
        pointer;

    text-decoration:
        none;

    display:
        inline-flex;

    align-items:
        center;

    justify-content:
        center;

    gap:
        8px;

    font-size:
        13px;

    font-weight:
        700;

    transition:
        .2s ease;

}


.btn:hover{

    transform:
        translateY(-2px);

}


.btn-back{

    background:
        rgba(255,255,255,.08);

    color:
        white;

    border:
        1px solid
        rgba(255,255,255,.15);

}


.btn-connect{

    background:
        #ffe600;

    color:
        #111827;

}


.btn-sync{

    background:
        var(--primary);

    color:
        white;

}


.btn-sync:hover{

    background:
        var(--primary-dark);

}


.btn-sync:disabled{

    opacity:
        .6;

    cursor:
        not-allowed;

    transform:
        none;

}


.btn-success{

    background:
        var(--success);

    color:
        white;

}


.btn-secondary{

    background:
        #f1f5f9;

    color:
        #334155;

}


/* =========================================================
   CONTENT
========================================================= */

.ml-content{

    max-width:
        1550px;

    margin:
        0 auto;

    padding:
        30px;

}


/* =========================================================
   BREADCRUMB
========================================================= */

.breadcrumb{

    display:
        flex;

    align-items:
        center;

    gap:
        8px;

    color:
        var(--muted);

    font-size:
        13px;

    margin-bottom:
        22px;

}


.breadcrumb a{

    color:
        var(--primary);

    text-decoration:
        none;

}


/* =========================================================
   CONNECTION
========================================================= */

.connection-card{

    background:
        var(--card);

    border-radius:
        var(--radius);

    padding:
        22px;

    display:
        flex;

    align-items:
        center;

    justify-content:
        space-between;

    gap:
        20px;

    margin-bottom:
        24px;

    border:
        1px solid
        var(--border);

    box-shadow:
        var(--shadow);

}


.connection-info{

    display:
        flex;

    align-items:
        center;

    gap:
        16px;

}


.status-icon{

    width:
        52px;

    height:
        52px;

    border-radius:
        14px;

    display:
        flex;

    align-items:
        center;

    justify-content:
        center;

    font-size:
        21px;

    background:
        #fef3c7;

    color:
        var(--warning);

}


.status-icon.connected{

    background:
        #dcfce7;

    color:
        var(--success);

}


.connection-info h2{

    font-size:
        18px;

    margin-bottom:
        5px;

}


.connection-info p{

    color:
        var(--muted);

    font-size:
        13px;

}


.status-badge{

    display:
        inline-flex;

    align-items:
        center;

    gap:
        7px;

    margin-top:
        8px;

    padding:
        6px 11px;

    border-radius:
        999px;

    font-size:
        11px;

    font-weight:
        700;

    background:
        #fef3c7;

    color:
        #92400e;

}


.status-badge.connected{

    background:
        #dcfce7;

    color:
        #166534;

}


.status-dot{

    width:
        7px;

    height:
        7px;

    border-radius:
        50%;

    background:
        currentColor;

}


/* =========================================================
   KPI
========================================================= */

.stats-grid{

    display:
        grid;

    grid-template-columns:
        repeat(4, minmax(0,1fr));

    gap:
        16px;

    margin-bottom:
        24px;

}


.stat-card{

    background:
        var(--card);

    border:
        1px solid
        var(--border);

    border-radius:
        16px;

    padding:
        20px;

    box-shadow:
        var(--shadow);

}


.stat-top{

    display:
        flex;

    justify-content:
        space-between;

    align-items:
        center;

}


.stat-label{

    color:
        var(--muted);

    font-size:
        12px;

    margin-bottom:
        6px;

}


.stat-value{

    font-size:
        27px;

    font-weight:
        800;

    color:
        #0f172a;

}


.stat-icon{

    width:
        43px;

    height:
        43px;

    border-radius:
        12px;

    display:
        flex;

    align-items:
        center;

    justify-content:
        center;

    background:
        #eff6ff;

    color:
        var(--primary);

}


/* =========================================================
   SYNC CENTER
========================================================= */

.sync-center{

    background:

        linear-gradient(
            135deg,
            #ffffff,
            #f8fafc
        );

    border:
        1px solid
        var(--border);

    border-radius:
        var(--radius);

    padding:
        25px;

    margin-bottom:
        24px;

    box-shadow:
        var(--shadow);

}


.sync-header{

    display:
        flex;

    align-items:
        center;

    justify-content:
        space-between;

    gap:
        15px;

    margin-bottom:
        20px;

}


.sync-header h3{

    font-size:
        18px;

}


.sync-header p{

    color:
        var(--muted);

    font-size:
        13px;

    margin-top:
        5px;

}


.sync-status{

    display:
        flex;

    align-items:
        center;

    gap:
        8px;

    font-size:
        12px;

    color:
        var(--muted);

}


.sync-status i{

    color:
        var(--success);

}


/* =========================================================
   NEW PACKAGES
========================================================= */

.new-packages{

    background:
        var(--card);

    border:
        1px solid
        #bfdbfe;

    border-radius:
        var(--radius);

    padding:
        25px;

    margin-bottom:
        24px;

    box-shadow:
        0 10px 35px
        rgba(37,99,235,.08);

}


.new-packages-header{

    display:
        flex;

    justify-content:
        space-between;

    align-items:
        center;

    gap:
        15px;

    margin-bottom:
        20px;

}


.new-packages-title{

    display:
        flex;

    align-items:
        center;

    gap:
        12px;

}


.new-packages-icon{

    width:
        43px;

    height:
        43px;

    border-radius:
        12px;

    display:
        flex;

    align-items:
        center;

    justify-content:
        center;

    background:
        #dbeafe;

    color:
        var(--primary);

}


.new-packages-title h3{

    font-size:
        18px;

}


.new-packages-title p{

    font-size:
        12px;

    color:
        var(--muted);

    margin-top:
        4px;

}


.new-count{

    background:
        #dbeafe;

    color:
        #1d4ed8;

    padding:
        8px 13px;

    border-radius:
        999px;

    font-size:
        12px;

    font-weight:
        800;

}


/* =========================================================
   ASSIGN BAR
========================================================= */

.assign-bar{

    display:
        flex;

    align-items:
        center;

    gap:
        12px;

    flex-wrap:
        wrap;

    padding:
        15px;

    background:
        #f8fafc;

    border:
        1px solid
        #e2e8f0;

    border-radius:
        13px;

    margin-bottom:
        18px;

}


.assign-bar label{

    font-size:
        12px;

    font-weight:
        700;

    color:
        #334155;

}


.client-select{

    min-width:
        240px;

    padding:
        10px 12px;

    border:
        1px solid
        #cbd5e1;

    border-radius:
        9px;

    background:
        white;

    font-size:
        13px;

    outline:
        none;

}


.client-select:focus{

    border-color:
        var(--primary);

    box-shadow:
        0 0 0 3px
        rgba(37,99,235,.1);

}


/* =========================================================
   TOOLBAR
========================================================= */

.table-toolbar{

    display:
        flex;

    align-items:
        center;

    justify-content:
        space-between;

    gap:
        12px;

    flex-wrap:
        wrap;

    margin-bottom:
        15px;

}


.search-box{

    position:
        relative;

    flex:
        1;

    min-width:
        250px;

}


.search-box i{

    position:
        absolute;

    left:
        13px;

    top:
        50%;

    transform:
        translateY(-50%);

    color:
        #94a3b8;

}


.search-box input{

    width:
        100%;

    padding:
        11px 12px 11px 38px;

    border:
        1px solid
        #cbd5e1;

    border-radius:
        10px;

    outline:
        none;

    font-size:
        13px;

}


.search-box input:focus{

    border-color:
        var(--primary);

}


/* =========================================================
   TABLE
========================================================= */

.table-container{

    overflow-x:
        auto;

    border:
        1px solid
        var(--border);

    border-radius:
        13px;

}


.packages-table{

    width:
        100%;

    border-collapse:
        collapse;

    min-width:
        950px;

}


.packages-table th{

    background:
        #f8fafc;

    color:
        #64748b;

    font-size:
        11px;

    text-transform:
        uppercase;

    letter-spacing:
        .04em;

    padding:
        13px;

    text-align:
        left;

    border-bottom:
        1px solid
        var(--border);

}


.packages-table td{

    padding:
        13px;

    border-bottom:
        1px solid
        #f1f5f9;

    font-size:
        12px;

}


.packages-table tr:last-child td{

    border-bottom:
        none;

}


.packages-table tr:hover{

    background:
        #f8fafc;

}


/* =========================================================
   CHECKBOX
========================================================= */

.package-check{

    width:
        16px;

    height:
        16px;

    cursor:
        pointer;

}


/* =========================================================
   BADGES
========================================================= */

.badge{

    display:
        inline-flex;

    align-items:
        center;

    gap:
        5px;

    padding:
        5px 9px;

    border-radius:
        999px;

    font-size:
        10px;

    font-weight:
        800;

}


.badge-flex{

    background:
        #fef3c7;

    color:
        #92400e;

}


.badge-received{

    background:
        #dbeafe;

    color:
        #1d4ed8;

}


.badge-assigned{

    background:
        #ede9fe;

    color:
        #6d28d9;

}


.badge-delivered{

    background:
        #dcfce7;

    color:
        #166534;

}


/* =========================================================
   MAIN GRID
========================================================= */

.main-grid{

    display:
        grid;

    grid-template-columns:
        2fr 1fr;

    gap:
        22px;

}


.panel-card{

    background:
        var(--card);

    border:
        1px solid
        var(--border);

    border-radius:
        var(--radius);

    padding:
        25px;

    box-shadow:
        var(--shadow);

}


.panel-header{

    display:
        flex;

    justify-content:
        space-between;

    align-items:
        center;

    margin-bottom:
        20px;

}


.panel-header h3{

    font-size:
        17px;

}


.panel-header span{

    font-size:
        11px;

    color:
        var(--muted);

}


/* =========================================================
   CLIENT SUMMARY
========================================================= */

.client-summary{

    display:
        flex;

    flex-direction:
        column;

    gap:
        10px;

}


.client-row{

    display:
        flex;

    justify-content:
        space-between;

    align-items:
        center;

    padding:
        13px;

    background:
        #f8fafc;

    border:
        1px solid
        #e2e8f0;

    border-radius:
        11px;

}


.client-info{

    display:
        flex;

    align-items:
        center;

    gap:
        10px;

}


.client-avatar{

    width:
        35px;

    height:
        35px;

    border-radius:
        10px;

    display:
        flex;

    align-items:
        center;

    justify-content:
        center;

    background:
        #dbeafe;

    color:
        var(--primary);

    font-weight:
        800;

    font-size:
        12px;

}


.client-name{

    font-weight:
        700;

    font-size:
        13px;

}


.client-meta{

    color:
        var(--muted);

    font-size:
        10px;

    margin-top:
        3px;

}


.client-count{

    font-size:
        18px;

    font-weight:
        800;

    color:
        var(--primary);

}


/* =========================================================
   ACTIONS
========================================================= */

.actions-list{

    display:
        flex;

    flex-direction:
        column;

    gap:
        10px;

}


.action{

    display:
        flex;

    align-items:
        center;

    gap:
        12px;

    padding:
        13px;

    border-radius:
        11px;

    background:
        #f8fafc;

    border:
        1px solid
        #e2e8f0;

    text-decoration:
        none;

    color:
        #1e293b;

    transition:
        .2s;

}


.action:hover{

    background:
        #f1f5f9;

    transform:
        translateX(3px);

}


.action-icon{

    width:
        37px;

    height:
        37px;

    border-radius:
        10px;

    display:
        flex;

    align-items:
        center;

    justify-content:
        center;

    background:
        #eff6ff;

    color:
        var(--primary);

}


.action strong{

    display:
        block;

    font-size:
        13px;

    margin-bottom:
        3px;

}


.action small{

    color:
        var(--muted);

    font-size:
        11px;

}


/* =========================================================
   INTEGRATION
========================================================= */

.integration-list{

    display:
        flex;

    flex-direction:
        column;

    gap:
        14px;

}


.integration-row{

    display:
        flex;

    align-items:
        center;

    justify-content:
        space-between;

    padding-bottom:
        13px;

    border-bottom:
        1px solid
        #f1f5f9;

}


.integration-row:last-child{

    border-bottom:
        none;

    padding-bottom:
        0;

}


.integration-row span:first-child{

    color:
        var(--muted);

    font-size:
        12px;

}


.integration-row strong{

    font-size:
        12px;

}


.online{

    color:
        var(--success);

}


.offline{

    color:
        var(--danger);

}


/* =========================================================
   TOAST
========================================================= */

.toast{

    position:
        fixed;

    right:
        25px;

    bottom:
        25px;

    background:
        #0f172a;

    color:
        white;

    padding:
        14px 18px;

    border-radius:
        12px;

    box-shadow:
        0 15px 40px
        rgba(0,0,0,.2);

    transform:
        translateY(120px);

    opacity:
        0;

    transition:
        .3s;

    z-index:
        9999;

    font-size:
        13px;

}


.toast.show{

    transform:
        translateY(0);

    opacity:
        1;

}


/* =========================================================
   RESPONSIVE
========================================================= */

@media(max-width:1100px){

    .stats-grid{

        grid-template-columns:
            repeat(2,1fr);

    }

    .main-grid{

        grid-template-columns:
            1fr;

    }

}


@media(max-width:700px){

    .ml-header{

        padding:
            20px;

        flex-direction:
            column;

        align-items:
            flex-start;

    }

    .header-actions{

        width:
            100%;

    }

    .header-actions .btn{

        flex:
            1;

    }

    .ml-content{

        padding:
            18px;

    }

    .connection-card{

        flex-direction:
            column;

        align-items:
            flex-start;

    }

    .stats-grid{

        grid-template-columns:
            1fr;

    }

    .sync-header{

        flex-direction:
            column;

        align-items:
            flex-start;

    }

}


/* =========================================================
   HIDDEN
========================================================= */

.hidden{

    display:
        none !important;

}

</style>

</head>


<body>


<div class="ml-wrapper">


<!-- =====================================================
     HEADER
====================================================== -->

<header class="ml-header">


    <div class="header-left">


        <div class="ml-logo">

            <i class="fas fa-boxes-stacked"></i>

        </div>


        <div class="header-title">

            <h1>
                Centro de Operaciones Logísticas
            </h1>

            <p>
                Mercado Libre · Flex · Recepción · Distribución
            </p>

        </div>


    </div>



    <div class="header-actions">


        <a
            href="/panel/logistica"
            class="btn btn-back"
        >

            <i class="fas fa-arrow-left"></i>

            Logística

        </a>



        <button
            id="syncButton"
            class="btn btn-sync"
            onclick="sincronizar()"
        >

            <i class="fas fa-rotate"></i>

            Sincronizar ahora

        </button>


    </div>


</header>



<!-- =====================================================
     CONTENT
====================================================== -->

<main class="ml-content">


    <!-- BREADCRUMB -->


    <div class="breadcrumb">

        <a href="/panel">
            Panel
        </a>

        <i class="fas fa-chevron-right"></i>

        <a href="/panel/logistica">
            Logística
        </a>

        <i class="fas fa-chevron-right"></i>

        <span>
            Mercado Libre
        </span>

    </div>



    <!-- =================================================
         CONNECTION
    ================================================== -->


    <section class="connection-card">


        <div class="connection-info">


            <div
                id="statusIcon"
                class="status-icon"
            >

                <i class="fas fa-link"></i>

            </div>



            <div>

                <h2>
                    Integración Mercado Libre
                </h2>

                <p>
                    AppCraftPro monitorea y registra
                    automáticamente tus operaciones logísticas.
                </p>


                <span
                    id="connectionStatus"
                    class="status-badge"
                >

                    <span class="status-dot"></span>

                    Verificando conexión...

                </span>


            </div>


        </div>



        <a
            href="/panel/logistica/mercadolibre/conectar"
            class="btn btn-connect"
        >

            <i class="fas fa-plug"></i>

            Administrar conexión

        </a>


    </section>



    <!-- =================================================
         KPI
    ================================================== -->


    <section class="stats-grid">


        <div class="stat-card">

            <div class="stat-top">

                <div>

                    <div class="stat-label">
                        Envíos registrados
                    </div>

                    <div
                        id="totalShipments"
                        class="stat-value"
                    >
                        <%= totalShipments || 0 %>
                    </div>

