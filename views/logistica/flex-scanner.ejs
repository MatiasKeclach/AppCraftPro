<script>


// =====================================================
// VARIABLES
// =====================================================

let stream = null;

let procesando = false;

let scannerActivo = false;

let ultimoCodigo = "";

let ultimoTexto = "";

let capturasEstables = 0;

let intervaloCaptura = null;


// =====================================================
// ELEMENTOS
// =====================================================

const video =
document.getElementById("video");

const canvas =
document.getElementById("canvas");

const iniciar =
document.getElementById("iniciarScanner");

const detener =
document.getElementById("detenerScanner");

const estado =
document.getElementById("scannerEstado");

const resultado =
document.getElementById("resultado");

const progreso =
document.getElementById("progreso");

const progressFill =
document.getElementById("progressFill");

const progressText =
document.getElementById("progressText");

const textoOCR =
document.getElementById("textoOCR");


// =====================================================
// SONIDOS
// =====================================================

function sonidoOK(){

    try{

        const audio =
        new AudioContext();

        const oscillator =
        audio.createOscillator();

        const gain =
        audio.createGain();

        oscillator.connect(gain);

        gain.connect(
            audio.destination
        );

        oscillator.frequency.value =
        900;

        oscillator.type =
        "sine";

        gain.gain.setValueAtTime(
            .3,
            audio.currentTime
        );

        gain.gain.exponentialRampToValueAtTime(
            .01,
            audio.currentTime + .4
        );

        oscillator.start();

        oscillator.stop(
            audio.currentTime + .4
        );

    }catch(e){}

}


function sonidoError(){

    try{

        const audio =
        new AudioContext();

        const oscillator =
        audio.createOscillator();

        const gain =
        audio.createGain();

        oscillator.connect(gain);

        gain.connect(
            audio.destination
        );

        oscillator.frequency.value =
        180;

        oscillator.type =
        "square";

        gain.gain.setValueAtTime(
            .3,
            audio.currentTime
        );

        gain.gain.exponentialRampToValueAtTime(
            .01,
            audio.currentTime + .5
        );

        oscillator.start();

        oscillator.stop(
            audio.currentTime + .5
        );

    }catch(e){}

}


// =====================================================
// GENERAR CODIGO INTERNO
// =====================================================

function generarCodigoInterno(){

    const numero =
    Math.floor(
        100000 +
        Math.random() * 900000
    );

    return "PKG-" + numero;

}


// =====================================================
// FECHA RECEPCION
// =====================================================

function fechaActual(){

    const ahora =
    new Date();

    return ahora.toLocaleString(
        "es-AR"
    );

}


// =====================================================
// ABRIR CAMARA
// =====================================================

iniciar.addEventListener(
"click",
async function(){

    try{

        stream =
        await navigator.mediaDevices
        .getUserMedia({

            video:{
                facingMode:{
                    ideal:"environment"
                },

                width:{
                    ideal:1280
                },

                height:{
                    ideal:720
                }

            },

            audio:false

        });


        video.srcObject =
        stream;


        scannerActivo =
        true;

        procesando =
        false;

        capturasEstables =
        0;


        iniciar.style.display =
        "none";

        detener.style.display =
        "inline-block";


        estado.innerHTML =
        "📷 Cámara activa. Apuntá a la etiqueta completa.";


        intervaloCaptura =
        setInterval(

            capturarImagen,

            3500

        );


    }catch(error){

        console.error(error);

        alert(
            "No se pudo abrir la cámara: "
            +
            error.message
        );

    }

});


// =====================================================
// DETENER CAMARA
// =====================================================

detener.addEventListener(
"click",
detenerScanner
);


function detenerScanner(){

    scannerActivo =
    false;


    if(intervaloCaptura){

        clearInterval(
            intervaloCaptura
        );

        intervaloCaptura =
        null;

    }


    if(stream){

        stream
        .getTracks()
        .forEach(
            track =>
            track.stop()
        );

        stream =
        null;

    }


    video.srcObject =
    null;


    iniciar.style.display =
    "inline-block";


    detener.style.display =
    "none";


    estado.innerHTML =
    "Scanner detenido";

}


// =====================================================
// CAPTURAR IMAGEN
// =====================================================

async function capturarImagen(){

    if(
        !scannerActivo ||
        procesando
    ){

        return;

    }


    if(
        video.readyState <
        2
    ){

        return;

    }


    const width =
    video.videoWidth;

    const height =
    video.videoHeight;


    if(
        !width ||
        !height
    ){

        return;

    }


    canvas.width =
    width;

    canvas.height =
    height;


    const ctx =
    canvas.getContext(
        "2d"
    );


    ctx.drawImage(
        video,
        0,
        0,
        width,
        height
    );


    const imagen =
    canvas.toDataURL(
        "image/jpeg",
        .95
    );


    await analizarImagen(
        imagen
    );

}


// =====================================================
// OCR
// =====================================================

async function analizarImagen(
    imagen
){

    procesando =
    true;


    estado.innerHTML =
    "🔎 Analizando etiqueta...";


    progreso.style.display =
    "block";


    progressFill.style.width =
    "10%";


    progressText.innerText =
    "Preparando reconocimiento de texto...";


    try{


        const resultadoOCR =
        await Tesseract.recognize(

            imagen,

            "spa",

            {

                logger:
                function(info){

                    if(
                        info.status ===
                        "recognizing text"
                    ){

                        const porcentaje =
                        Math.round(
                            info.progress *
                            100
                        );


                        progressFill.style.width =
                        porcentaje + "%";


                        progressText.innerText =
                        "Leyendo etiqueta... "
                        +
                        porcentaje
                        +
                        "%";

                    }

                }

            }

        );


        const texto =
        resultadoOCR.data.text
        .trim();


        console.log(
            "OCR COMPLETO:",
            texto
        );


        if(
            !texto ||
            texto.length <
            20
        ){

            throw new Error(
                "No se detectó suficiente texto"
            );

        }


        textoOCR.value =
        texto;


        progressFill.style.width =
        "100%";


        progressText.innerText =
        "✅ OCR terminado";


        detenerScanner();


        sonidoOK();


        procesarDatos(
            texto
        );


    }catch(error){


        console.error(
            "Error OCR:",
            error
        );


        sonidoError();


        estado.innerHTML =
        "❌ No se pudo leer claramente la etiqueta. Intentando nuevamente...";


        procesando =
        false;

    }

}


// =====================================================
// PROCESAR DATOS
// =====================================================

function procesarDatos(
    texto
){

    const textoLimpio =
    texto
    .replace(
        /\r/g,
        ""
    );


    const lineas =
    textoLimpio
    .split("\n")
    .map(
        linea =>
        linea.trim()
    )
    .filter(
        linea =>
        linea.length > 0
    );


    const datos = {

        codigoBarras:
        detectarCodigo(
            textoLimpio
        ),

        numeroOrden:
        detectarOrden(
            textoLimpio
        ),

        fechaEmision:
        detectarFecha(
            textoLimpio
        ),

        peso:
        detectarPeso(
            textoLimpio
        ),

        bultos:
        detectarBultos(
            textoLimpio
        ),

        numeroBulto:
        detectarNumeroBulto(
            textoLimpio
        ),

        remitente:
        detectarCampo(
            textoLimpio,
            [
                "Remitente"
            ]
        ),

        destinatario:
        detectarDestinatario(
            textoLimpio
        ),

        telefono:
        detectarTelefono(
            textoLimpio
        ),

        direccion:
        detectarDireccion(
            textoLimpio
        ),

        codigoPostal:
        detectarCodigoPostal(
            textoLimpio
        ),

        localidad:
        detectarLocalidad(
            textoLimpio
        )

    };


    document.getElementById(
        "codigoInterno"
    ).innerText =
    generarCodigoInterno();


    document.getElementById(
        "codigoBarras"
    ).value =
    datos.codigoBarras || "";


    document.getElementById(
        "numeroOrden"
    ).value =
    datos.numeroOrden || "";


    document.getElementById(
        "fechaEmision"
    ).value =
    datos.fechaEmision || "";


    document.getElementById(
        "fechaRecepcion"
    ).value =
    fechaActual();


    document.getElementById(
        "peso"
    ).value =
    datos.peso || "";


    document.getElementById(
        "bultos"
    ).value =
    datos.bultos || "";


    document.getElementById(
        "numeroBulto"
    ).value =
    datos.numeroBulto || "";


    document.getElementById(
        "remitente"
    ).value =
    datos.remitente || "";


    document.getElementById(
        "destinatario"
    ).value =
    datos.destinatario || "";


    document.getElementById(
        "telefono"
    ).value =
    datos.telefono || "";


    document.getElementById(
        "direccion"
    ).value =
    datos.direccion || "";


    document.getElementById(
        "codigoPostal"
    ).value =
    datos.codigoPostal || "";


    document.getElementById(
        "localidad"
    ).value =
    datos.localidad || "";


    document.getElementById(
        "zona"
    ).value =
    detectarZona(
        datos.localidad,
        datos.direccion
    );


    resultado.style.display =
    "block";


    const cantidadDetectada =
    Object.values(
        datos
    )
    .filter(
        valor =>
        valor &&
        valor.trim()
    )
    .length;


    if(
        cantidadDetectada >= 5
    ){

        document.getElementById(
            "alertaOk"
        ).style.display =
        "block";

        document.getElementById(
            "alertaError"
        ).style.display =
        "none";

    }else{

        document.getElementById(
            "alertaOk"
        ).style.display =
        "none";

        document.getElementById(
            "alertaError"
        ).style.display =
        "block";

    }


    procesando =
    false;

}


// =====================================================
// DETECTAR CODIGO
// =====================================================

function detectarCodigo(
    texto
){

    const encontrados =
    texto.match(
        /\b\d{6,12}\b/g
    );


    if(
        !encontrados
    ){

        return "";

    }


    return encontrados
    .sort(
        (
            a,
            b
        ) =>
        b.length -
        a.length
    )[0];

}


// =====================================================
// DETECTAR FECHA
// =====================================================

function detectarFecha(
    texto
){

    const fecha =
    texto.match(
        /\b\d{1,2}[\/\-]\d{1,2}[\/\-]\d{2,4}\b/
    );


    return fecha
    ?
    fecha[0]
    :
    "";

}


// =====================================================
// DETECTAR ORDEN
// =====================================================

function detectarOrden(
    texto
){

    const match =
    texto.match(
        /(?:Nro\.?\s*Ord|Nro\s*de\s*Orden|N[uú]mero\s*de\s*orden)\s*[:\-]?\s*(\d{4,10})/i
    );


    if(match){

        return match[1];

    }


    return "";

}


// =====================================================
// DETECTAR PESO
// =====================================================

function detectarPeso(
    texto
){

    const match =
    texto.match(
        /PESO[\s\S]{0,80}?(\d+(?:[.,]\d+)?)\s*(?:kg|kgs|kilos)?/i
    );


    return match
    ?
    match[1]
    :
    "";

}


// =====================================================
// DETECTAR BULTOS
// =====================================================

function detectarBultos(
    texto
){

    const match =
    texto.match(
        /BULTOS[\s\S]{0,80}?(\d{1,2})/i
    );


    return match
    ?
    match[1]
    :
    "";

}


// =====================================================
// DETECTAR NUMERO DE BULTO
// =====================================================

function detectarNumeroBulto(
    texto
){

    const match =
    texto.match(
        /(?:BULTO|BULTOS)\s*(?:N[°ºo]\.?\s*)?(\d{1,2})\s*(?:DE|\/)\s*(\d{1,2})/i
    );


    if(match){

        return (
            match[1]
            +
            " de "
            +
            match[2]
        );

    }


    const otro =
    texto.match(
        /\b(\d{1,2})\s+de\s+(\d{1,2})\b/i
    );


    return otro
    ?
    otro[1] +
    " de " +
    otro[2]
    :
    "";

}


// =====================================================
// DETECTAR CAMPO ETIQUETADO
// =====================================================

function detectarCampo(
    texto,
    nombres
){

    for(
        const nombre
        of nombres
    ){

        const regex =
        new RegExp(
            nombre +
            "\\s*:?\\s*(.+)",
            "i"
        );


        const match =
        texto.match(
            regex
        );


        if(match){

            return match[1]
            .trim();

        }

    }


    return "";

}


// =====================================================
// DESTINATARIO
// =====================================================

function detectarDestinatario(
    texto
){

    const match =
    texto.match(
        /Destinatario\s*:?\s*(.+)/i
    );


    if(
        !match
    ){

        return "";

    }


    return match[1]
    .replace(
        /\(\s*\d{7,15}\s*\)/g,
        ""
    )
    .trim();

}


// =====================================================
// TELEFONO
// =====================================================

function detectarTelefono(
    texto
){

    const match =
    texto.match(
        /\(?\s*(\d{10,15})\s*\)?/
    );


    return match
    ?
    match[1]
    :
    "";

}


// =====================================================
// DIRECCION
// =====================================================

function detectarDireccion(
    texto
){

    const lineas =
    texto
    .split("\n")
    .map(
        l =>
        l.trim()
    );


    for(
        let i=0;
        i<lineas.length;
        i++
    ){

        if(
            /Destinatario/i
            .test(
                lineas[i]
            )
        ){

            const siguiente =
            lineas[i+1];


            if(
                siguiente &&
                /\d/.test(
                    siguiente
                )
            ){

                return siguiente;

            }

        }

    }


    return "";

}


// =====================================================
// CODIGO POSTAL
// =====================================================

function detectarCodigoPostal(
    texto
){

    const match =
    texto.match(
        /(?:CP|C\.P\.|Código Postal)\s*:?\s*([A-Z]?\s*\d{4,8})/i
    );


    return match
    ?
    match[1]
    .trim()
    :
    "";

}


// =====================================================
// LOCALIDAD
// =====================================================

function detectarLocalidad(
    texto
){

    const match =
    texto.match(
        /(?:Localidad|Ciudad)\s*:?\s*([^\n]+)/i
    );


    if(match){

        return match[1]
        .trim();

    }


    const cp =
    texto.match(
        /CP\s*:?\s*([^\n]+)/i
    );


    if(cp){

        const valor =
        cp[1]
        .trim();


        const partes =
        valor.split(
            /\s+/
        );


        if(
            partes.length > 1
        ){

            return partes[0];

        }

    }


    return "";

}


// =====================================================
// ZONAS / BARRIOS
// =====================================================

function detectarZona(
    localidad,
    direccion
){

    const texto = (

        (
            localidad ||
            ""
        )
        +
        " "
        +
        (
            direccion ||
            ""
        )

    ).toLowerCase();


    const zonas = [

        "palermo",
        "recoleta",
        "belgrano",
        "nuñez",
        "núñez",
        "colegiales",
        "chacarita",
        "villa crespo",
        "caballito",
        "almagro",
        "boedo",
        "barracas",
        "la boca",
        "san telmo",
        "monserrat",
        "balvanera",
        "constitución",
        "san cristóbal",
        "flores",
        "floresta",
        "villa devoto",
        "villa del parque",
        "villa urquiza",
        "villa pueyrredón",
        "saavedra",
        "coghlan",
        "villa lugano",
        "villa soldati",
        "mataderos",
        "liniers",
        "versalles",
        "villa real",
        "villa luro",
        "parque patricios",
        "parque chacabuco",
        "puerto madero",
        "retiro",
        "san nicolás",
        "barrio norte",
        "microcentro"
    ];


    for(
        const zona
        of zonas
    ){

        if(
            texto.includes(
                zona
            )
        ){

            return zona;

        }

    }


    return "";

}


