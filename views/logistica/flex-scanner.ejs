<!DOCTYPE html>
<html lang="es">

<head>

<meta charset="UTF-8">

<meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
>

<title>Particular Scanner - AppCraft Pro</title>

<link
    rel="stylesheet"
    href="/css/panel.css"
>

<link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    background:#f4f6f9;
    font-family:Arial,Helvetica,sans-serif;
    color:#1e293b;
}

.header{
    background:#1e293b;
    color:white;
    padding:22px;
    box-shadow:0 3px 15px rgba(0,0,0,.15);
}

.header h1{
    font-size:26px;
    margin-bottom:7px;
}

.header p{
    opacity:.85;
    font-size:14px;
}

.container{
    width:100%;
    max-width:1100px;
    margin:auto;
    padding:20px;
}

.back{
    display:inline-flex;
    align-items:center;
    gap:8px;
    margin-bottom:20px;
    text-decoration:none;
    color:#2563eb;
    font-weight:bold;
}

.panel{
    background:white;
    border-radius:16px;
    padding:25px;
    box-shadow:0 5px 20px rgba(0,0,0,.08);
    margin-bottom:20px;
}

.panel h2{
    font-size:20px;
    margin-bottom:20px;
}

label{
    display:block;
    font-weight:bold;
    margin-bottom:8px;
}

select{
    width:100%;
    padding:14px;
    border:1px solid #d1d5db;
    border-radius:10px;
    font-size:16px;
    background:white;
}

.scanner{
    margin-top:20px;
    background:#0f172a;
    border-radius:16px;
    padding:20px;
    text-align:center;
    color:white;
}

#reader{
    width:100%;
    max-width:600px;
    margin:auto;
    border-radius:12px;
    overflow:hidden;
}

.btn{
    border:none;
    border-radius:10px;
    padding:14px 22px;
    font-size:16px;
    font-weight:bold;
    cursor:pointer;
    margin-top:15px;
    transition:.2s;
}

.btn:hover{
    transform:translateY(-2px);
}

.btn-primary{
    background:#2563eb;
    color:white;
}

.btn-success{
    background:#16a34a;
    color:white;
}

.btn-danger{
    background:#dc2626;
    color:white;
}

.btn-secondary{
    background:#64748b;
    color:white;
}

.btn-warning{
    background:#f59e0b;
    color:white;
}

.estado{
    background:#f1f5f9;
    padding:15px;
    border-radius:10px;
    margin-top:15px;
    line-height:24px;
}

.codigo{
    font-size:22px;
    font-weight:bold;
    color:#2563eb;
    margin-top:5px;
}

.resultado{
    display:none;
}

.procesando{
    display:none;
    margin-top:20px;
    padding:20px;
    background:#eff6ff;
    border-radius:12px;
    text-align:center;
    color:#1d4ed8;
    font-weight:bold;
}

.progress-container{
    width:100%;
    height:12px;
    background:#e2e8f0;
    border-radius:20px;
    margin-top:15px;
    overflow:hidden;
}

.progress-bar{
    width:0%;
    height:100%;
    background:#2563eb;
    transition:width .3s;
}

.form-grid{
    display:grid;
    grid-template-columns:repeat(
        auto-fit,
        minmax(220px,1fr)
    );
    gap:15px;
}

input,
textarea{
    width:100%;
    padding:12px;
    border:1px solid #d1d5db;
    border-radius:9px;
    font-size:15px;
}

input:focus,
textarea:focus,
select:focus{
    outline:none;
    border-color:#2563eb;
    box-shadow:0 0 0 3px rgba(37,99,235,.12);
}

textarea{
    min-height:90px;
    resize:vertical;
}

.ocr-text{
    margin-top:20px;
    display:none;
}

.ocr-text textarea{
    min-height:220px;
    font-family:monospace;
    font-size:13px;
}

.duplicado{
    display:none;
    margin-top:15px;
    padding:15px;
    background:#fee2e2;
    color:#991b1b;
    border-radius:10px;
    font-weight:bold;
}

.foto-preview{
    display:none;
    margin-top:20px;
    text-align:center;
}

.foto-preview img{
    max-width:100%;
    max-height:500px;
    border-radius:12px;
    box-shadow:0 3px 15px rgba(0,0,0,.15);
}

.captura-etiqueta{
    margin-top:20px;
    padding:20px;
    background:#eff6ff;
    border-radius:12px;
}

.codigo-detectado{
    margin-top:15px;
    padding:15px;
    background:#dcfce7;
    color:#166534;
    border-radius:10px;
    font-weight:bold;
    display:none;
}

.sin-codigo{
    margin-top:15px;
    padding:15px;
    background:#fef3c7;
    color:#92400e;
    border-radius:10px;
    font-weight:bold;
    display:none;
}

.debug-box{
    margin-top:20px;
    padding:15px;
    background:#111827;
    color:#d1d5db;
    border-radius:10px;
    display:none;
}

.debug-box pre{
    white-space:pre-wrap;
    word-break:break-word;
    font-size:12px;
    text-align:left;
    max-height:400px;
    overflow:auto;
}

@media(max-width:600px){

    .container{
        padding:12px;
    }

    .panel{
        padding:18px;
    }

    .header h1{
        font-size:22px;
    }

    .btn{
        width:100%;
    }

}

</style>

</head>


<body>


<header class="header">

    <h1>📷 Particular Scanner</h1>

    <p>
        Escaneo y lectura automática de etiquetas
        de paquetes particulares
    </p>

</header>


<div class="container">


<a
    href="/panel/logistica"
    class="back"
>

    <i class="fas fa-arrow-left"></i>

    Volver a Logística

</a>


<!-- CLIENTE -->

<div class="panel">

    <h2>👤 Cliente interno</h2>

    <label>
        Seleccionar cliente
    </label>

    <select id="cliente_id">

        <option value="">
            Seleccionar cliente...
        </option>

        <% clientes.forEach(cliente => { %>

            <option value="<%= cliente.id %>">

                <%= cliente.nombre %>

                <% if(cliente.empresa){ %>

                    - <%= cliente.empresa %>

                <% } %>

            </option>

        <% }) %>

    </select>

</div>


<!-- ESCANEO -->

<div class="panel">

    <h2>📷 Escanear etiqueta completa</h2>

    <p style="margin-bottom:15px;color:#64748b">

        El sistema intentará detectar automáticamente
        el código de barras y luego leerá todos los datos
        visibles de la etiqueta mediante OCR.

    </p>


    <div class="scanner">

        <div id="reader"></div>


        <button
            class="btn btn-primary"
            id="iniciarScanner"
        >

            <i class="fas fa-camera"></i>

            Iniciar cámara

        </button>


        <button
            class="btn btn-danger"
            id="detenerScanner"
            style="display:none"
        >

            <i class="fas fa-stop"></i>

            Detener cámara

        </button>


        <p
            id="scannerEstado"
            style="margin-top:15px;opacity:.8"
        >

            Scanner detenido

        </p>

    </div>


    <!-- CAPTURA -->

    <div
        class="captura-etiqueta"
        id="capturaEtiqueta"
    >

        <h3>
            📸 Capturar etiqueta completa
        </h3>

        <p style="margin-top:8px;margin-bottom:15px">

            Sacá una foto donde se vea la etiqueta completa.
            Puede tener código de barras o no.

        </p>


        <input
            type="file"
            id="fotoEtiqueta"
            accept="image/*"
            capture="environment"
            style="
                width:100%;
                padding:10px;
                background:white;
                border-radius:8px;
            "
        >

    </div>


    <!-- RESULTADO CODIGO -->

    <div
        class="codigo-detectado"
        id="codigoDetectado"
    >

        ✅ Código de barras detectado:

        <span id="codigoDetectadoTexto"></span>

    </div>


    <div
        class="sin-codigo"
        id="sinCodigo"
    >

        ℹ️ No se detectó código de barras.
        La etiqueta continúa igualmente al procesamiento OCR.

    </div>

</div>


<!-- PROCESANDO -->

<div
    class="procesando"
    id="procesando"
>

    <div>
        🔎 Analizando etiqueta...
    </div>


    <div class="progress-container">

        <div
            class="progress-bar"
            id="progressBar"
        ></div>

    </div>


    <div
        id="progressTexto"
        style="margin-top:10px"
    >

        Preparando OCR...

    </div>

</div>


<!-- RESULTADO -->

<div
    class="panel resultado"
    id="resultado"
>

    <h2>
        📦 Paquete detectado
    </h2>


    <!-- CODIGO INTERNO -->

    <div class="estado">

        Código interno generado:

        <div
            class="codigo"
            id="codigoInterno"
        >

            Generando...

        </div>

    </div>


    <!-- DUPLICADO -->

    <div
        class="duplicado"
        id="duplicado"
    >

        ⚠️ Atención: este código de paquete
        ya podría estar registrado.

    </div>


    <!-- CAMPOS -->

    <div
        class="form-grid"
        style="margin-top:20px"
    >


        <div>

            <label>
                Código de barras
            </label>

            <input
                type="text"
                id="codigoBarras"
            >

        </div>


        <div>

            <label>
                Número de orden
            </label>

            <input
                type="text"
                id="numeroOrden"
            >

        </div>


        <div>

            <label>
                Fecha emisión
            </label>

            <input
                type="text"
                id="fechaEmision"
            >

        </div>


        <div>

            <label>
                Peso
            </label>

            <input
                type="text"
                id="peso"
            >

        </div>


        <div>

            <label>
                Cantidad de bultos
            </label>

            <input
                type="text"
                id="bultos"
            >

        </div>


        <div>

            <label>
                Número de bulto
            </label>

            <input
                type="text"
                id="numeroBulto"
            >

        </div>


        <div>

            <label>
                Remitente
            </label>

            <input
                type="text"
                id="remitente"
            >

        </div>


        <div>

            <label>
                Destinatario
            </label>

            <input
                type="text"
                id="destinatario"
            >

        </div>


        <div>

            <label>
                Teléfono
            </label>

            <input
                type="text"
                id="telefono"
            >

        </div>


        <div>

            <label>
                Dirección
            </label>

            <input
                type="text"
                id="direccion"
            >

        </div>


        <div>

            <label>
                Localidad / Barrio
            </label>

            <input
                type="text"
                id="localidad"
            >

        </div>


        <div>

            <label>
                Zona / Barrio
            </label>

            <input
                type="text"
                id="zona"
            >

        </div>

    </div>


    <!-- FOTO -->

    <div
        class="foto-preview"
        id="fotoPreview"
    >

        <label>
            Imagen analizada
        </label>

        <img
            id="imagenEtiqueta"
            alt="Etiqueta capturada"
        >

    </div>


    <!-- OBSERVACIONES -->

    <div style="margin-top:20px">

        <label>
            Observaciones
        </label>

        <textarea
            id="observaciones"
        ></textarea>

    </div>


    <!-- OCR -->

    <div
        class="ocr-text"
        id="ocrContainer"
    >

        <label>
            Texto completo detectado por OCR
        </label>

        <textarea
            id="ocrTexto"
            readonly
        ></textarea>

    </div>


    <!-- DEBUG -->

    <div
        class="debug-box"
        id="debugBox"
    >

        <strong>
            🔧 Resultado OCR para depuración
        </strong>

        <pre id="debugTexto"></pre>

    </div>


    <!-- BOTONES -->

    <button
        class="btn btn-success"
        id="guardarPaquete"
    >

        <i class="fas fa-save"></i>

        Guardar paquete

    </button>


    <button
        class="btn btn-secondary"
        id="nuevoEscaneo"
    >

        <i class="fas fa-camera"></i>

        Escanear otro paquete

    </button>


</div>


</div>


<!-- LIBRERIAS -->

<script src="https://unpkg.com/html5-qrcode"></script>

<script src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js"></script>


<script>

let scanner = null;
let procesando = false;
let ultimoTextoOCR = "";
let codigoBarrasDetectado = "";

// =====================================================
// ELEMENTOS
// =====================================================

const iniciar = document.getElementById("iniciarScanner");
const detener = document.getElementById("detenerScanner");
const estado = document.getElementById("scannerEstado");

const resultado = document.getElementById("resultado");
const procesandoBox = document.getElementById("procesando");

const progressBar = document.getElementById("progressBar");
const progressTexto = document.getElementById("progressTexto");

const codigoBarras = document.getElementById("codigoBarras");
const ocrTexto = document.getElementById("ocrTexto");
const ocrContainer = document.getElementById("ocrContainer");

const codigoInterno = document.getElementById("codigoInterno");

const imagenEtiqueta = document.getElementById("imagenEtiqueta");
const fotoPreview = document.getElementById("fotoPreview");


// =====================================================
// INICIAR SCANNER
// =====================================================

iniciar.addEventListener("click", iniciarScanner);


async function iniciarScanner() {

    if (scanner) {
        return;
    }

    try {

        scanner = new Html5Qrcode("reader");

        const cameras = await Html5Qrcode.getCameras();

        if (!cameras || cameras.length === 0) {

            alert("No se encontró ninguna cámara.");

            scanner = null;

            return;
        }

        // Buscar cámara trasera
        let camera = cameras.find(c => {

            const nombre = (
                c.label || ""
            ).toLowerCase();

            return (
                nombre.includes("back") ||
                nombre.includes("rear") ||
                nombre.includes("trasera") ||
                nombre.includes("environment")
            );

        });

        const cameraId = camera
            ? camera.id
            : cameras[0].id;


        await scanner.start(

            cameraId,

            {

                fps: 10,

                qrbox: {
                    width: 320,
                    height: 220
                },

                aspectRatio: 1.7777778

            },

            async codigo => {

                if (procesando) {
                    return;
                }

                procesando = true;

                console.log(
                    "================================"
                );

                console.log(
                    "CÓDIGO DETECTADO POR CÁMARA:"
                );

                console.log(codigo);

                console.log(
                    "================================"
                );


                codigoBarrasDetectado = codigo;

                codigoBarras.value = codigo;


                // Mostrar resultado
                resultado.style.display = "block";


                // Generar código interno
                generarCodigoInterno();


                estado.innerHTML =
                    "✅ Código detectado. Ahora seleccioná la foto completa de la etiqueta.";


                await detenerScanner();


                procesando = false;


                mostrarCapturaEtiqueta();

            },

            error => {

                // Estos errores son normales mientras busca.
                // NO mostrar alertas.

            }

        );


        iniciar.style.display = "none";

        detener.style.display = "inline-block";


        estado.innerHTML =
            "📷 Cámara activa. Buscando código de barras o QR...";


    } catch (error) {

        console.error(
            "ERROR INICIANDO CÁMARA:",
            error
        );

        alert(
            "No se pudo iniciar la cámara.\n\n" +
            error.message
        );

        scanner = null;

    }

}


// =====================================================
// DETENER SCANNER
// =====================================================

detener.addEventListener(
    "click",
    detenerScanner
);


async function detenerScanner() {

    if (scanner) {

        try {

            await scanner.stop();

            scanner.clear();

        } catch (error) {

            console.error(
                "Error deteniendo scanner:",
                error
            );

        }

    }


    scanner = null;


    iniciar.style.display = "inline-block";

    detener.style.display = "none";


    estado.innerHTML =
        "Scanner detenido";

}


// =====================================================
// CAPTURA COMPLETA
// =====================================================

function mostrarCapturaEtiqueta() {

    let contenedor =
        document.getElementById(
            "capturaEtiqueta"
        );


    if (contenedor) {

        contenedor.style.display =
            "block";

        return;

    }


    contenedor =
        document.createElement(
            "div"
        );


    contenedor.id =
        "capturaEtiqueta";


    contenedor.style.marginTop =
        "20px";


    contenedor.innerHTML = `

        <div style="
            background:#eff6ff;
            padding:20px;
            border-radius:12px;
            color:#1e293b;
        ">

            <h3>
                📸 Capturar etiqueta completa
            </h3>

            <p style="
                margin-top:8px;
                margin-bottom:15px;
            ">

                Sacá una foto donde se vea
                toda la etiqueta completa.

                <br><br>

                Si tiene código de barras,
                el sistema intentará leerlo.

                Si no tiene código de barras,
                se utilizará OCR para leer
                todos los datos posibles.

            </p>

            <input
                type="file"
                id="fotoEtiqueta"
                accept="image/*"
                capture="environment"
                style="
                    width:100%;
                    padding:10px;
                    background:white;
                    border-radius:8px;
                "
            >

        </div>

    `;


    resultado.appendChild(
        contenedor
    );


    document
        .getElementById(
            "fotoEtiqueta"
        )
        .addEventListener(
            "change",
            procesarFotoOCR
        );

}


// =====================================================
// PROCESAR FOTO
// =====================================================

async function procesarFotoOCR(event) {

    const archivo =
        event.target.files[0];


    if (!archivo) {
        return;
    }


    procesando = true;


    procesandoBox.style.display =
        "block";


    progressBar.style.width =
        "5%";


    progressTexto.innerText =
        "Preparando imagen...";


    try {

        // =================================================
        // MOSTRAR IMAGEN
        // =================================================

        const url =
            URL.createObjectURL(
                archivo
            );


        imagenEtiqueta.src =
            url;


        fotoPreview.style.display =
            "block";


        // =================================================
        // INTENTAR LEER CÓDIGO
        // =================================================

        progressBar.style.width =
            "15%";


        progressTexto.innerText =
            "Buscando código de barras...";


        const codigoImagen =
            await detectarCodigoEnImagen(
                archivo
            );


        if (
            codigoImagen &&
            !codigoBarras.value.trim()
        ) {

            codigoBarras.value =
                codigoImagen;

            codigoBarrasDetectado =
                codigoImagen;

            console.log(
                "✅ CÓDIGO ENCONTRADO EN IMAGEN:",
                codigoImagen
            );

        } else {

            console.log(
                "ℹ️ No se encontró código de barras en la imagen."
            );

        }


        // =================================================
        // OCR
        // =================================================

        progressBar.style.width =
            "25%";


        progressTexto.innerText =
            "Leyendo todos los datos de la etiqueta...";


        console.log(
            "================================"
        );

        console.log(
            "INICIANDO OCR"
        );

        console.log(
            "================================"
        );


        const resultadoOCR =
            await Tesseract.recognize(

                archivo,

                "spa",

                {

                    logger: mensaje => {

                        if (
                            mensaje.status ===
                            "recognizing text"
                        ) {

                            const porcentaje =
                                Math.round(
                                    mensaje.progress *
                                    100
                                );


                            const progresoReal =
                                25 +
                                Math.round(
                                    porcentaje *
                                    0.70
                                );


                            progressBar.style.width =
                                progresoReal +
                                "%";


                            progressTexto.innerText =
                                "Leyendo etiqueta: "
                                +
                                porcentaje
                                +
                                "%";

                        }

                    }

                }

            );


        // =================================================
        // TEXTO COMPLETO
        // =================================================

        const texto =
            resultadoOCR.data.text;


        ultimoTextoOCR =
            texto;


        console.log(
            "================================"
        );

        console.log(
            "OCR COMPLETO:"
        );

        console.log(
            texto
        );

        console.log(
            "================================"
        );


        // Mostrar OCR
        ocrContainer.style.display =
            "block";


        ocrTexto.value =
            texto;


        // =================================================
        // EXTRAER DATOS
        // =================================================

        progressTexto.innerText =
            "Organizando los datos detectados...";


        extraerDatosEtiqueta(
            texto
        );


        progressBar.style.width =
            "100%";


        progressTexto.innerText =
            "✅ Lectura terminada.";


        estado.innerHTML =
            "✅ Etiqueta procesada. Revisá los datos antes de guardar.";


        console.log(
            "================================"
        );

        console.log(
            "DATOS FINALES EXTRAÍDOS:"
        );

        console.table(
            obtenerDatosFormulario()
        );

        console.log(
            "================================"
        );


    } catch (error) {

        console.error(
            "ERROR PROCESANDO ETIQUETA:",
            error
        );


        alert(
            "Error procesando la etiqueta.\n\n" +
            error.message
        );

    }


    finally {

        procesando = false;

    }

}


// =====================================================
// DETECTAR CÓDIGO DESDE IMAGEN
// =====================================================

async function detectarCodigoEnImagen(archivo) {

    try {

        const lector =
            new Html5Qrcode(
                "lectorTemporal"
            );


        const url =
            URL.createObjectURL(
                archivo
            );


        try {

            const resultado =
                await lector.scanFile(
                    archivo,
                    true
                );


            console.log(
                "Código detectado desde foto:",
                resultado
            );


            return resultado;

        } catch (error) {

            console.log(
                "No se detectó código en la foto."
            );

            return "";

        }

    } catch (error) {

        console.error(
            "Error leyendo código desde imagen:",
            error
        );

        return "";

    }

}


