background:#fef2f2;

}

textarea{

min-height:120px;

resize:vertical;

}

.estado-scanner{

margin-top:15px;

padding:14px;

border-radius:10px;

font-weight:bold;

}

.estado-esperando{

background:#334155;

color:white;

}

.estado-ok{

background:#166534;

color:white;

}

.estado-error{

background:#991b1b;

color:white;

}

.estado-warning{

background:#92400e;

color:white;

}

.datos-faltantes{

display:none;

margin-top:20px;

padding:18px;

border-radius:12px;

background:#fff7ed;

border:1px solid #fdba74;

}

.datos-faltantes h3{

color:#c2410c;

margin-bottom:10px;

}

.datos-faltantes ul{

padding-left:20px;

margin-top:10px;

}

.datos-faltantes li{

margin-bottom:5px;

}

.acciones{

display:flex;

flex-wrap:wrap;

gap:10px;

margin-top:20px;

}

.acciones .btn{

margin-top:0;

}

.ocr-panel{

margin-top:20px;

}

.ocr-panel summary{

cursor:pointer;

font-weight:bold;

padding:12px;

background:#f1f5f9;

border-radius:8px;

}

.ocr-texto{

margin-top:10px;

padding:15px;

background:#0f172a;

color:#e2e8f0;

border-radius:10px;

white-space:pre-wrap;

font-family:monospace;

font-size:13px;

line-height:20px;

max-height:400px;

overflow:auto;

}

.progreso{

display:none;

margin-top:20px;

}

.barra{

width:100%;

height:12px;

background:#e2e8f0;

border-radius:20px;

overflow:hidden;

}

.barra-interna{

width:0%;

height:100%;

background:#2563eb;

transition:width .3s;

}

.progreso-texto{

margin-top:8px;

font-size:14px;

font-weight:bold;

}

.badge{

display:inline-block;

padding:5px 10px;

border-radius:20px;

font-size:12px;

font-weight:bold;

margin-top:8px;

}

.badge-ok{

background:#dcfce7;

color:#166534;

}

.badge-warning{

background:#fef3c7;

color:#92400e;

}

.badge-error{

background:#fee2e2;

color:#991b1b;

}

.fecha-escaneo{

margin-top:10px;

font-size:14px;

color:#64748b;

}

@media(max-width:600px){

.container{

padding:12px;

}

.panel{

padding:18px;

}

.header h1{

font-size:22px;

}

.acciones{

flex-direction:column;

}

.acciones .btn{

width:100%;

}

}

</style>

</head>


<body>


<header class="header">

<h1>

📷 Particular Scanner

</h1>

<p>

Escaneo y lectura automática de etiquetas de paquetes particulares

</p>

</header>


<div class="container">


<a
href="/panel/logistica"
class="back"
>

<i class="fas fa-arrow-left"></i>

Volver a Logística

</a>


<!-- CLIENTE -->

<div class="panel">

<h2>

👤 Cliente interno

</h2>


<label>

Seleccionar cliente

</label>


<select id="cliente_id">

<option value="">

Seleccionar cliente...

</option>


<% clientes.forEach(cliente => { %>

<option value="<%= cliente.id %>">

<%= cliente.nombre %>

<% if(cliente.empresa){ %>

* <%= cliente.empresa %>

<% } %>

</option>

<% }) %>


</select>

</div>



<!-- SCANNER -->

<div class="panel">

<h2>

📷 Escanear etiqueta

</h2>


<div class="scanner">


<div id="reader"></div>


<button
class="btn btn-primary"
id="iniciarScanner"
>

<i class="fas fa-camera"></i>

Iniciar cámara

</button>


<button
class="btn btn-danger"
id="detenerScanner"
style="display:none"
>

<i class="fas fa-stop"></i>

Detener cámara

</button>


<div
id="scannerEstado"
class="estado-scanner estado-esperando"
>

Scanner detenido

</div>


</div>

</div>



<!-- PROGRESO OCR -->

<div
class="panel progreso"
id="progreso"
>

<h3>

🔎 Analizando etiqueta...

</h3>


<div class="barra">

<div
class="barra-interna"
id="barraInterna"
></div>

</div>


<div
class="progreso-texto"
id="progresoTexto"
>

Preparando análisis...

</div>

</div>



<!-- RESULTADO -->

<div
class="panel resultado"
id="resultado"
>


<h2>

📦 Resultado del escaneo

</h2>


<div class="estado">


<div>

Código interno generado:

</div>


<div
class="codigo"
id="codigoInterno"
>

PKG-000001

</div>


<div
class="fecha-escaneo"
id="fechaEscaneo"
>

</div>

</div>



<div
id="estadoDatos"
style="margin-top:15px"
>

</div>



<div
class="datos-faltantes"
id="datosFaltantes"
>

<h3>

⚠️ Faltan algunos datos

</h3>


<p>

El sistema no pudo detectar automáticamente los siguientes campos:

</p>


<ul
id="listaFaltantes"
>

</ul>


<p style="margin-top:15px">

Podés completarlos manualmente o volver a escanear la etiqueta.

</p>

</div>



<div class="form-grid">


<div>

<label>

Código de barras

</label>

<input
type="text"
id="codigoBarras"
