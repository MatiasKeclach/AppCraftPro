    }
);



/* =========================================================
GUARDAR PAQUETE
========================================================= */

document
.getElementById(
    "guardarPaquete"
)
.addEventListener(
    "click",
    async function(){

        const cliente =
        document
        .getElementById(
            "cliente_id"
        )
        .value;


        if(!cliente){

            alert(
                "Seleccioná un cliente interno."
            );

            return;

        }


        const datos =
        obtenerDatosFormulario();


        console.log(
            "PAQUETE COMPLETO:",
            datos
        );


        /*
        IMPORTANTE:

        YA NO EXIGIMOS CODIGO DE BARRAS.

        Puede ser una etiqueta con:
        - código de barras
        - QR
        - solo texto
        - etiqueta impresa
        - etiqueta manuscrita

        El sistema permite guardar
        todos los casos.
        */


        alert(

            "✅ Paquete preparado.\n\n"

            +

            "Código interno: "

            +

            datos.codigoInterno

            +

            "\nCódigo de barras: "

            +

            (
                datos.codigoBarras ||
                "No detectado"
            )

            +

            "\nDestinatario: "

            +

            (
                datos.destinatario ||
                "No detectado"
            )

            +

            "\nDirección: "

            +

            (
                datos.direccion ||
                "No detectada"
            )

            +

            "\nLocalidad: "

            +

            (
                datos.localidad ||
                "No detectada"
            )

        );

    }
);

