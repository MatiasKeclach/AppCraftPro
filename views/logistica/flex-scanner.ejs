}

.btn-secondary{

background:#64748b;

color:white;

}

.resultado{

display:none;

}

.estado{

background:#f1f5f9;

padding:15px;

border-radius:10px;

margin-top:15px;

}

.codigo{

font-size:22px;

font-weight:bold;

color:#2563eb;

margin-top:5px;

}

.form-grid{

display:grid;

grid-template-columns:
repeat(
auto-fit,
minmax(220px,1fr)
);

gap:15px;

margin-top:20px;

}

input,
textarea{

width:100%;

padding:12px;

border:1px solid #d1d5db;

border-radius:9px;

font-size:15px;

}

input.detectado{

border-color:#16a34a;

background:#f0fdf4;

}

input.faltante{

