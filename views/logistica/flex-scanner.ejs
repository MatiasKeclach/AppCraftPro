<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{

background:#f4f6f9;

font-family:
Arial,
Helvetica,
sans-serif;

color:#1e293b;

}

.header{

background:#1e293b;

color:white;

padding:22px;

box-shadow:
0 3px 15px
