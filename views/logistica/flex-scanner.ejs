<!DOCTYPE html>
<html lang="es">

<head>

<meta charset="UTF-8">

<meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
>

<title>Particular Scanner - AppCraft Pro</title>

<link
    rel="stylesheet"
    href="/css/panel.css"
>

<link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    background:#f4f6f9;
    font-family:Arial,Helvetica,sans-serif;
    color:#1e293b;
}

.header{
    background:#1e293b;
    color:white;
    padding:22px;
    box-shadow:0 3px 15px rgba(0,0,0,.15);
}

.header h1{
    font-size:26px;
    margin-bottom:7px;
}

.header p{
    opacity:.85;
    font-size:14px;
}

.container{
    width:100%;
    max-width:1100px;
    margin:auto;
    padding:20px;
}

.back{
    display:inline-flex;
    align-items:center;
    gap:8px;
    margin-bottom:20px;
    text-decoration:none;
    color:#2563eb;
    font-weight:bold;
}

.panel{
    background:white;
    border-radius:16px;
    padding:25px;
    box-shadow:0 5px 20px rgba(0,0,0,.08);
    margin-bottom:20px;
}

.panel h2{
    font-size:20px;
    margin-bottom:20px;
}

label{
    display:block;
    font-weight:bold;
    margin-bottom:8px;
}

select{
    width:100%;
    padding:14px;
    border:1px solid #d1d5db;
    border-radius:10px;
    font-size:16px;
    background:white;
}

.scanner{
    margin-top:20px;
    background:#0f172a;
    border-radius:16px;
    padding:20px;
    text-align:center;
    color:white;
}

#reader{
    width:100%;
    max-width:600px;
    margin:auto;
    border-radius:12px;
    overflow:hidden;
}

.btn{
    border:none;
    border-radius:10px;
    padding:14px 22px;
    font-size:16px;
    font-weight:bold;
    cursor:pointer;
    margin-top:15px;
    transition:.2s;
}

.btn:hover{
    transform:translateY(-2px);
}

.btn-primary{
    background:#2563eb;
    color:white;
}

.btn-success{
    background:#16a34a;
    color:white;
}

.btn-danger{
    background:#dc2626;
    color:white;
}

.btn-secondary{
    background:#64748b;
    color:white;
}

.btn-warning{
    background:#f59e0b;
    color:white;
}

.estado{
    background:#f1f5f9;
    padding:15px;
    border-radius:10px;
    margin-top:15px;
    line-height:24px;
}

.codigo{
    font-size:22px;
    font-weight:bold;
    color:#2563eb;
    margin-top:5px;
}

.resultado{
    display:none;
}

.procesando{
    display:none;
    margin-top:20px;
    padding:20px;
    background:#eff6ff;
    border-radius:12px;
    text-align:center;
    color:#1d4ed8;
    font-weight:bold;
}

.progress-container{
    width:100%;
    height:12px;
    background:#e2e8f0;
    border-radius:20px;
    margin-top:15px;
    overflow:hidden;
}

.progress-bar{
    width:0%;
    height:100%;
    background:#2563eb;
    transition:width .3s;
}

.form-grid{
    display:grid;
    grid-template-columns:repeat(
        auto-fit,
        minmax(220px,1fr)
    );
    gap:15px;
}

input,
textarea{
    width:100%;
    padding:12px;
    border:1px solid #d1d5db;
    border-radius:9px;
    font-size:15px;
}

input:focus,
textarea:focus,
select:focus{
    outline:none;
    border-color:#2563eb;
    box-shadow:0 0 0 3px rgba(37,99,235,.12);
}

textarea{
    min-height:90px;
    resize:vertical;
}

.ocr-text{
    margin-top:20px;
    display:none;
}

.ocr-text textarea{
    min-height:220px;
    font-family:monospace;
    font-size:13px;
}

.duplicado{
    display:none;
    margin-top:15px;
    padding:15px;
    background:#fee2e2;
    color:#991b1b;
    border-radius:10px;
    font-weight:bold;
}

.foto-preview{
    display:none;
    margin-top:20px;
    text-align:center;
}

.foto-preview img{
    max-width:100%;
    max-height:500px;
    border-radius:12px;
    box-shadow:0 3px 15px rgba(0,0,0,.15);
}

.captura-etiqueta{
    margin-top:20px;
    padding:20px;
    background:#eff6ff;
    border-radius:12px;
}

.codigo-detectado{
    margin-top:15px;
    padding:15px;
    background:#dcfce7;
    color:#166534;
    border-radius:10px;
    font-weight:bold;
    display:none;
}

.sin-codigo{
    margin-top:15px;
    padding:15px;
    background:#fef3c7;
    color:#92400e;
    border-radius:10px;
    font-weight:bold;
    display:none;
}

.debug-box{
    margin-top:20px;
    padding:15px;
    background:#111827;
    color:#d1d5db;
    border-radius:10px;
    display:none;
}

.debug-box pre{
    white-space:pre-wrap;
    word-break:break-word;
    font-size:12px;
    text-align:left;
    max-height:400px;
    overflow:auto;
}

@media(max-width:600px){

    .container{
        padding:12px;
    }

    .panel{
        padding:18px;
    }

    .header h1{
        font-size:22px;
    }

    .btn{
        width:100%;
    }

}

</style>

</head>


<body>


<header class="header">

    <h1>📷 Particular Scanner</h1>

    <p>
        Escaneo y lectura automática de etiquetas
        de paquetes particulares
    </p>

</header>


<div class="container">


<a
    href="/panel/logistica"
    class="back"
>

    <i class="fas fa-arrow-left"></i>

    Volver a Logística

</a>


<!-- CLIENTE -->

<div class="panel">

    <h2>👤 Cliente interno</h2>

    <label>
        Seleccionar cliente
    </label>

    <select id="cliente_id">

        <option value="">
            Seleccionar cliente...
        </option>

        <% clientes.forEach(cliente => { %>

            <option value="<%= cliente.id %>">

                <%= cliente.nombre %>

                <% if(cliente.empresa){ %>

                    - <%= cliente.empresa %>

                <% } %>

            </option>

        <% }) %>

    </select>

</div>


<!-- ESCANEO -->

<div class="panel">

    <h2>📷 Escanear etiqueta completa</h2>

    <p style="margin-bottom:15px;color:#64748b">

        El sistema intentará detectar automáticamente
        el código de barras y luego leerá todos los datos
        visibles de la etiqueta mediante OCR.

    </p>


    <div class="scanner">

        <div id="reader"></div>


        <button
            class="btn btn-primary"
            id="iniciarScanner"
        >

            <i class="fas fa-camera"></i>

            Iniciar cámara

        </button>


        <button
            class="btn btn-danger"
            id="detenerScanner"
            style="display:none"
        >

            <i class="fas fa-stop"></i>

            Detener cámara

        </button>


        <p
            id="scannerEstado"
            style="margin-top:15px;opacity:.8"
        >

            Scanner detenido

        </p>

    </div>


    <!-- CAPTURA -->

    <div
        class="captura-etiqueta"
        id="capturaEtiqueta"
    >

        <h3>
            📸 Capturar etiqueta completa
        </h3>

        <p style="margin-top:8px;margin-bottom:15px">

            Sacá una foto donde se vea la etiqueta completa.
            Puede tener código de barras o no.

        </p>


        <input
            type="file"
            id="fotoEtiqueta"
            accept="image/*"
            capture="environment"
            style="
                width:100%;
                padding:10px;
                background:white;
                border-radius:8px;
            "
        >

    </div>


    <!-- RESULTADO CODIGO -->

    <div
        class="codigo-detectado"
        id="codigoDetectado"
    >

        ✅ Código de barras detectado:

        <span id="codigoDetectadoTexto"></span>

    </div>


    <div
        class="sin-codigo"
        id="sinCodigo"
    >

        ℹ️ No se detectó código de barras.
        La etiqueta continúa igualmente al procesamiento OCR.

    </div>

</div>


<!-- PROCESANDO -->

<div
    class="procesando"
    id="procesando"
>

    <div>
        🔎 Analizando etiqueta...
    </div>


    <div class="progress-container">

        <div
            class="progress-bar"
            id="progressBar"
        ></div>

    </div>


    <div
        id="progressTexto"
        style="margin-top:10px"
    >

        Preparando OCR...

    </div>

</div>


<!-- RESULTADO -->

<div
    class="panel resultado"
    id="resultado"
>

    <h2>
        📦 Paquete detectado
    </h2>


    <!-- CODIGO INTERNO -->

    <div class="estado">

        Código interno generado:

        <div
            class="codigo"
            id="codigoInterno"
        >

            Generando...

        </div>

    </div>


    <!-- DUPLICADO -->

    <div
        class="duplicado"
        id="duplicado"
    >

        ⚠️ Atención: este código de paquete
        ya podría estar registrado.

    </div>


    <!-- CAMPOS -->

    <div
        class="form-grid"
        style="margin-top:20px"
    >


        <div>

            <label>
                Código de barras
            </label>

            <input
                type="text"
                id="codigoBarras"
            >

        </div>


        <div>

            <label>
                Número de orden
            </label>

            <input
                type="text"
                id="numeroOrden"
            >

        </div>


        <div>

            <label>
                Fecha emisión
            </label>

            <input
                type="text"
                id="fechaEmision"
            >

        </div>


        <div>

            <label>
                Peso
            </label>

            <input
                type="text"
                id="peso"
            >

        </div>


        <div>

            <label>
                Cantidad de bultos
            </label>

            <input
                type="text"
                id="bultos"
            >

        </div>


        <div>

            <label>
                Número de bulto
            </label>

            <input
                type="text"
                id="numeroBulto"
            >

        </div>


        <div>

            <label>
                Remitente
            </label>

            <input
                type="text"
                id="remitente"
            >

        </div>


        <div>

            <label>
                Destinatario
            </label>

            <input
                type="text"
                id="destinatario"
            >

        </div>


        <div>

            <label>
                Teléfono
            </label>

            <input
                type="text"
                id="telefono"
            >

        </div>


        <div>

            <label>
                Dirección
            </label>

            <input
                type="text"
                id="direccion"
            >

        </div>


        <div>

            <label>
                Localidad / Barrio
            </label>

            <input
                type="text"
                id="localidad"
            >

        </div>


        <div>

            <label>
                Zona / Barrio
            </label>

            <input
                type="text"
                id="zona"
            >

        </div>

    </div>


    <!-- FOTO -->

    <div
        class="foto-preview"
        id="fotoPreview"
    >

        <label>
            Imagen analizada
        </label>

        <img
            id="imagenEtiqueta"
            alt="Etiqueta capturada"
        >

    </div>


    <!-- OBSERVACIONES -->

    <div style="margin-top:20px">

        <label>
            Observaciones
        </label>

        <textarea
            id="observaciones"
        ></textarea>

    </div>


    <!-- OCR -->

    <div
        class="ocr-text"
        id="ocrContainer"
    >

        <label>
            Texto completo detectado por OCR
        </label>

        <textarea
            id="ocrTexto"
            readonly
        ></textarea>

    </div>


    <!-- DEBUG -->

    <div
        class="debug-box"
        id="debugBox"
    >

        <strong>
            🔧 Resultado OCR para depuración
        </strong>

        <pre id="debugTexto"></pre>

    </div>


    <!-- BOTONES -->

    <button
        class="btn btn-success"
        id="guardarPaquete"
    >

        <i class="fas fa-save"></i>

        Guardar paquete

    </button>


    <button
        class="btn btn-secondary"
        id="nuevoEscaneo"
    >

        <i class="fas fa-camera"></i>

        Escanear otro paquete

    </button>


</div>


</div>


<!-- LIBRERIAS -->

<script src="https://unpkg.com/html5-qrcode"></script>

<script src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js"></script>


<script>

let scanner = null;
let procesando = false;
let ultimoTextoOCR = "";
let codigoBarrasDetectado = "";

const iniciar =
document.getElementById("iniciarScanner");

const detener =
document.getElementById("detenerScanner");

const estado =
document.getElementById("scannerEstado");

const resultado =
document.getElementById("resultado");

const procesandoBox =
document.getElementById("procesando");

const progressBar =
document.getElementById("progressBar");

const progressTexto =
document.getElementById("progressTexto");

const codigoBarras =
document.getElementById("codigoBarras");

const ocrTexto =
document.getElementById("ocrTexto");

const ocrContainer =
document.getElementById("ocrContainer");

const codigoInterno =
document.getElementById("codigoInterno");

const imagenEtiqueta =
document.getElementById("imagenEtiqueta");

const fotoPreview =
document.getElementById("fotoPreview");



/* =========================================================
SONIDOS
========================================================= */

function sonidoExito(){

    try{

        const ctx =
        new (
            window.AudioContext ||
            window.webkitAudioContext
        )();

        const osc =
        ctx.createOscillator();

        const gain =
        ctx.createGain();

        osc.connect(gain);

        gain.connect(ctx.destination);

        osc.frequency.value = 900;

        gain.gain.setValueAtTime(
            0.2,
            ctx.currentTime
        );

        gain.gain.exponentialRampToValueAtTime(
            0.01,
            ctx.currentTime + 0.3
        );

        osc.start();

        osc.stop(
            ctx.currentTime + 0.3
        );

    }catch(error){

        console.log(
            "No se pudo reproducir sonido",
            error
        );

    }

}



function sonidoProcesado(){

    try{

        const ctx =
        new (
            window.AudioContext ||
            window.webkitAudioContext
        )();

        const osc =
        ctx.createOscillator();

        const gain =
        ctx.createGain();

        osc.connect(gain);

        gain.connect(ctx.destination);

        osc.frequency.value = 600;

        gain.gain.setValueAtTime(
            0.2,
            ctx.currentTime
        );

        osc.start();

        osc.frequency.exponentialRampToValueAtTime(
            1000,
            ctx.currentTime + 0.15
        );

        gain.gain.exponentialRampToValueAtTime(
            0.01,
            ctx.currentTime + 0.4
        );

        osc.stop(
            ctx.currentTime + 0.4
        );

    }catch(error){}

}



/* =========================================================
INICIAR
========================================================= */

iniciar.addEventListener(
    "click",
    iniciarScanner
);



async function iniciarScanner(){

    if(scanner){

        return;

    }

    try{

        scanner =
        new Html5Qrcode("reader");

        const cameras =
        await Html5Qrcode.getCameras();

        if(
            !cameras ||
            cameras.length === 0
        ){

            alert(
                "No se encontró ninguna cámara."
            );

            scanner = null;

            return;

        }

        let cameraId =
        cameras[0].id;


        const trasera =
        cameras.find(
            camera => {

                const nombre =
                (
                    camera.label ||
                    ""
                ).toLowerCase();

                return (

                    nombre.includes("back") ||

                    nombre.includes("rear") ||

                    nombre.includes("trasera")

                );

            }
        );


        if(trasera){

            cameraId =
            trasera.id;

        }


        await scanner.start(

            cameraId,

            {

                fps:10,

                qrbox:{
                    width:320,
                    height:220
                },

                aspectRatio:1.7777778

            },


            async codigo => {

                if(procesando){

                    return;

                }


                procesando =
                true;


                console.log(
                    "================================="
                );

                console.log(
                    "CÓDIGO DETECTADO"
                );

                console.log(
                    codigo
                );

                console.log(
                    "================================="
                );


                codigoBarrasDetectado =
                codigo;


                codigoBarras.value =
                codigo;


                sonidoExito();


                resultado.style.display =
                "block";


                generarCodigoInterno();


                estado.innerHTML =
                "✅ Código detectado. Capturando etiqueta completa...";


                await capturarImagenDesdeScanner();


            },


            error => {

                /*
                Los errores de búsqueda son normales.
                No mostramos alert.
                */

            }

        );


        iniciar.style.display =
        "none";


        detener.style.display =
        "inline-block";


        estado.innerHTML =
        "📷 Cámara activa. Mostrá la etiqueta completa y enfocá el código.";


    }

    catch(error){

        console.error(
            "ERROR INICIANDO SCANNER:",
            error
        );


        alert(
            "Error iniciando cámara:\n" +
            error.message
        );


        scanner =
        null;

    }

}



/* =========================================================
DETENER
========================================================= */

detener.addEventListener(
    "click",
    detenerScanner
);



async function detenerScanner(){

    if(scanner){

        try{

            await scanner.stop();

        }

        catch(error){

            console.error(
                "Error deteniendo scanner:",
                error
            );

        }


        try{

            scanner.clear();

        }

        catch(error){}

    }


    scanner =
    null;


    iniciar.style.display =
    "inline-block";


    detener.style.display =
    "none";


    estado.innerHTML =
    "Scanner detenido";

}



/* =========================================================
CAPTURAR IMAGEN DEL SCANNER
========================================================= */

async function capturarImagenDesdeScanner(){

    procesandoBox.style.display =
    "block";


    progressBar.style.width =
    "5%";


    progressTexto.innerText =
    "Preparando captura de etiqueta...";


    try{

        /*
        Detenemos scanner
        */

        await detenerScanner();


        /*
        IMPORTANTE:

        Como Html5Qrcode no nos entrega
        directamente el frame capturado,
        mostramos una captura de archivo/cámara.

        En PC permite elegir imagen.

        En celular abre cámara.
        */


        mostrarCapturaEtiqueta();


        estado.innerHTML =
        "📸 Ahora capturá la etiqueta COMPLETA.";


        progressBar.style.width =
        "10%";


        progressTexto.innerText =
        "Esperando imagen completa de la etiqueta...";


        procesando =
        false;


    }

    catch(error){

        console.error(
            "Error capturando etiqueta:",
            error
        );


        procesando =
        false;

    }

}



/* =========================================================
MOSTRAR CAPTURA
========================================================= */

function mostrarCapturaEtiqueta(){

    let contenedor =
    document.getElementById(
        "capturaEtiqueta"
    );


    if(contenedor){

        contenedor.style.display =
        "block";

        return;

    }


    contenedor =
    document.createElement(
        "div"
    );


    contenedor.id =
    "capturaEtiqueta";


    contenedor.style.marginTop =
    "20px";


    contenedor.innerHTML = `

        <div style="
            background:#eff6ff;
            padding:20px;
            border-radius:12px;
            color:#1e293b;
        ">

            <h3>
                📸 Capturá la etiqueta completa
            </h3>

            <p style="
                margin-top:8px;
                margin-bottom:15px;
            ">

                IMPORTANTE: la foto debe incluir
                toda la etiqueta.

                No importa si tiene o no
                código de barras.

            </p>

            <input
                type="file"
                id="fotoEtiqueta"
                accept="image/*"
                capture="environment"
                style="
                    width:100%;
                    padding:10px;
                    background:white;
                    border-radius:8px;
                "
            >

        </div>

    `;


    resultado.appendChild(
        contenedor
    );


    document
    .getElementById(
        "fotoEtiqueta"
    )
    .addEventListener(
        "change",
        procesarFotoOCR
    );

}



/* =========================================================
PROCESAR FOTO
========================================================= */

async function procesarFotoOCR(event){

    const archivo =
    event.target.files[0];


    if(!archivo){

        return;

    }


    if(procesando){

        return;

    }


    procesando =
    true;


    procesandoBox.style.display =
    "block";


    progressBar.style.width =
    "5%";


    progressTexto.innerText =
    "Cargando imagen...";


    try{

        console.log(
            "================================="
        );

        console.log(
            "INICIANDO PROCESAMIENTO"
        );

        console.log(
            "Archivo:",
            archivo.name
        );

        console.log(
            "Tamaño:",
            archivo.size
        );

        console.log(
            "Tipo:",
            archivo.type
        );


        /*
        MOSTRAR IMAGEN
        */

        const url =
        URL.createObjectURL(
            archivo
        );


        imagenEtiqueta.src =
        url;


        fotoPreview.style.display =
        "block";


        progressBar.style.width =
        "15%";


        progressTexto.innerText =
        "Imagen cargada. Iniciando OCR...";


        /*
        OCR
        */

        console.log(
            "INICIANDO TESSERACT..."
        );


        const resultadoOCR =
        await Tesseract.recognize(

            archivo,

            "spa",

            {

                logger:
                mensaje => {

                    console.log(
                        "TESSERACT:",
                        mensaje
                    );


                    if(
                        mensaje.status ===
                        "recognizing text"
                    ){

                        const porcentaje =
                        Math.round(
                            mensaje.progress *
                            100
                        );


                        const progresoReal =
                        15 +
                        (
                            porcentaje *
                            0.75
                        );


                        progressBar.style.width =
                        progresoReal +
                        "%";


                        progressTexto.innerText =
                        "Leyendo texto: "
                        +
                        porcentaje
                        +
                        "%";

                    }

                }

            }

        );


        console.log(
            "RESULTADO TESSERACT:",
            resultadoOCR
        );


        /*
        EXTRAER TEXTO
        */

        const texto =
        resultadoOCR &&
        resultadoOCR.data
        ?
        resultadoOCR.data.text
        :
        "";


        console.log(
            "================================="
        );

        console.log(
            "OCR COMPLETO:"
        );

        console.log(
            texto
        );

        console.log(
            "LONGITUD OCR:",
            texto.length
        );

        console.log(
            "================================="
        );


        ultimoTextoOCR =
        texto;


        /*
        MOSTRAR OCR
        */

        ocrContainer.style.display =
        "block";


        ocrTexto.value =
        texto ||
        "⚠️ Tesseract no detectó texto.";


        /*
        SI NO HAY TEXTO
        */

        if(
            !texto.trim()
        ){

            estado.innerHTML =
            "⚠️ La imagen fue procesada pero OCR no detectó texto. Revisá la foto.";


            progressBar.style.width =
            "100%";


            progressTexto.innerText =
            "⚠️ No se detectó texto.";


            sonidoProcesado();


            return;

        }


        /*
        EXTRAER DATOS
        */

        console.log(
            "EXTRAYENDO DATOS..."
        );


        extraerDatosEtiqueta(
            texto
        );


        progressBar.style.width =
        "100%";


        progressTexto.innerText =
        "✅ Lectura terminada.";


        estado.innerHTML =
        "✅ Etiqueta analizada. Revisá los datos antes de guardar.";


        sonidoProcesado();


        console.log(
            "DATOS FINALES:",
            obtenerDatosFormulario()
        );


    }

    catch(error){

        console.error(
            "================================="
        );

        console.error(
            "ERROR PROCESANDO OCR"
        );

        console.error(
            error
        );

        console.error(
            "================================="
        );


        estado.innerHTML =
        "❌ Error procesando la etiqueta.";


        alert(
            "Error procesando la etiqueta.\n\n" +
            error.message
        );

    }

    finally{

        procesando =
        false;

    }

}



/* =========================================================
EXTRAER DATOS
========================================================= */

function extraerDatosEtiqueta(texto){

    console.log(
        "TEXTO RECIBIDO POR EXTRACTOR:",
        texto
    );


    const limpio =
    normalizarTexto(
        texto
    );


    console.log(
        "TEXTO NORMALIZADO:",
        limpio
    );


    /*
    CÓDIGO DE BARRAS

    Si ya tenemos uno,
    NO LO REEMPLAZAMOS.
    */

    if(
        !codigoBarras.value.trim()
    ){

        const codigo =
        extraerCodigoBarras(
            limpio
        );


        if(codigo){

            codigoBarras.value =
            codigo;

        }

    }


    /*
    CAMPOS
    */

    setValue(
        "numeroOrden",
        extraerNumeroOrden(
            limpio
        )
    );


    setValue(
        "fechaEmision",
        extraerFecha(
            limpio
        )
    );


    setValue(
        "peso",
        extraerPeso(
            limpio
        )
    );


    setValue(
        "bultos",
        extraerBultos(
            limpio
        )
    );


    setValue(
        "numeroBulto",
        extraerNumeroBulto(
            limpio
        )
    );


    setValue(
        "remitente",
        extraerCampoPorEtiqueta(
            limpio,
            [
                "Remitente",
                "Remitente:"
            ]
        )
    );


    setValue(
        "destinatario",
        extraerDestinatario(
            limpio
        )
    );


    setValue(
        "telefono",
        extraerTelefono(
            limpio
        )
    );


    setValue(
        "direccion",
        extraerDireccion(
            limpio
        )
    );


    const localidad =
    extraerLocalidad(
        limpio
    );


    setValue(
        "localidad",
        localidad
    );


    setValue(
        "zona",
        localidad
    );


    setValue(
        "observaciones",
        extraerObservaciones(
            limpio
        )
    );


    console.log(
        "================================="
    );

    console.log(
        "RESULTADO DE EXTRACCION"
    );

    console.log(
        obtenerDatosFormulario()
    );

    console.log(
        "================================="
    );

}



/* =========================================================
NORMALIZAR
========================================================= */

function normalizarTexto(texto){

    return (
        texto || ""
    )

    .replace(
        /\r/g,
        ""
    )

    .replace(
        /[ \t]+/g,
        " "
    )

    .split("\n")

    .map(
        linea =>
        linea.trim()
    )

    .filter(
        linea =>
        linea.length > 0
    )

    .join("\n");

}



/* =========================================================
CODIGO DE BARRAS
========================================================= */

function extraerCodigoBarras(texto){

    const patrones = [

        /(?:c[oó]digo\s*de\s*barras|barcode)\s*:?\s*([0-9]{6,30})/i,

        /(?:pack\s*id)\s*:?\s*([A-Z0-9\-]{6,30})/i,

        /(?:env[ií]o)\s*:?\s*([A-Z0-9\-]{6,30})/i,

        /\b([0-9]{8,30})\b/

    ];


    for(
        const patron
        of patrones
    ){

        const encontrado =
        texto.match(
            patron
        );


        if(encontrado){

            return (
                encontrado[1] ||
                ""
            ).trim();

        }

    }


    return "";

}



/* =========================================================
NUMERO ORDEN
========================================================= */

function extraerNumeroOrden(texto){

    const encontrado =
    texto.match(

        /(?:nro\.?\s*orden|n[uú]mero\s*de\s*orden|orden)\s*:?\s*([A-Z0-9\-]+)/i

    );


    return encontrado
    ?
    encontrado[1]
    :
    "";

}



/* =========================================================
FECHA
========================================================= */

function extraerFecha(texto){

    const encontrado =
    texto.match(

        /(?:fecha|fech[aá])\s*:?\s*(\d{1,2}[\/\-]\d{1,2}[\/\-]\d{2,4})/i

    );


    return encontrado
    ?
    encontrado[1]
    :
    "";

}



/* =========================================================
PESO
========================================================= */

function extraerPeso(texto){

    const encontrado =
    texto.match(

        /(?:peso)\s*:?\s*([0-9]+(?:[.,][0-9]+)?\s*(?:kg|kgs|kilos)?)/i

    );


    return encontrado
    ?
    encontrado[1].trim()
    :
    "";

}



/* =========================================================
BULTOS
========================================================= */

function extraerBultos(texto){

    const encontrado =
    texto.match(

        /(?:bultos?|piezas?)\s*:?\s*([0-9]+)/i

    );


    return encontrado
    ?
    encontrado[1]
    :
    "";

}



/* =========================================================
NUMERO BULTO
========================================================= */

function extraerNumeroBulto(texto){

    const patrones = [

        /(?:nro\.?\s*bulto|n[uú]mero\s*de\s*bulto)\s*:?\s*([0-9]+)/i,

        /bulto\s*:?\s*([0-9]+)\s*(?:de|\/)\s*([0-9]+)/i

    ];


    for(
        const patron
        of patrones
    ){

        const encontrado =
        texto.match(
            patron
        );


        if(encontrado){

            return encontrado[1];

        }

    }


    return "";

}



/* =========================================================
CAMPO POR ETIQUETA
========================================================= */

function extraerCampoPorEtiqueta(
    texto,
    etiquetas
){

    const lineas =
    texto.split("\n");


    for(
        let i = 0;
        i < lineas.length;
        i++
    ){

        const linea =
        lineas[i].trim();


        for(
            const etiqueta
            of etiquetas
        ){

            const regex =
            new RegExp(

                "^"
                +
                etiqueta
                +
                "\\s*:?\\s*(.*)$",

                "i"

            );


            const encontrado =
            linea.match(
                regex
            );


            if(encontrado){

                if(
                    encontrado[1] &&
                    encontrado[1].trim()
                ){

                    return limpiarValor(
                        encontrado[1]
                    );

                }


                if(
                    lineas[i + 1]
                ){

                    return limpiarValor(
                        lineas[i + 1]
                    );

                }

            }

        }

    }


    return "";

}



/* =========================================================
DESTINATARIO
========================================================= */

function extraerDestinatario(texto){

    return limpiarNombre(

        extraerCampoPorEtiqueta(

            texto,

            [
                "Destinatario",
                "Destinatário",
                "Destino"
            ]

        )

    );

}



/* =========================================================
TELEFONO
========================================================= */

function extraerTelefono(texto){

    const patrones = [

        /(?:tel[eé]fono|telefono|tel\.?|celular|cel\.?)\s*:?\s*([0-9+\-\s]{8,25})/i,

        /\b(?:011|15|54)?\s*\d{4}[\s\-]?\d{4}\b/

    ];


    for(
        const patron
        of patrones
    ){

        const encontrado =
        texto.match(
            patron
        );


        if(encontrado){

            return (

                encontrado[1] ||

                encontrado[0]

            )
            .replace(
                /\s+/g,
                " "
            )
            .trim();

        }

    }


    return "";

}



/* =========================================================
DIRECCION
========================================================= */

function extraerDireccion(texto){

    const lineas =
    texto.split("\n");


    for(
        let i = 0;
        i < lineas.length;
        i++
    ){

        const linea =
        lineas[i].trim();


        const directa =
        linea.match(

            /^(?:direcci[oó]n|direccion|domicilio)\s*:?\s*(.+)$/i

        );


        if(
            directa &&
            directa[1]
        ){

            return limpiarValor(
                directa[1]
            );

        }


        if(

            /^(?:direcci[oó]n|direccion|domicilio)\s*:?\s*$/i
            .test(
                linea
            )

        ){

            if(
                lineas[i + 1]
            ){

                return limpiarValor(
                    lineas[i + 1]
                );

            }

        }

    }


    for(
        const linea
        of lineas
    ){

        if(
            pareceDireccion(
                linea
            )
        ){

            return limpiarValor(
                linea
            );

        }

    }


    return "";

}



/* =========================================================
PARECE DIRECCION
========================================================= */

function pareceDireccion(linea){

    if(
        !linea ||
        linea.length < 5
    ){

        return false;

    }


    const texto =
    linea.toLowerCase();


    const prohibidas = [

        "destinatario",

        "remitente",

        "telefono",

        "teléfono",

        "fecha",

        "peso",

        "bulto",

        "orden",

        "caba",

        "cp",

        "código",

        "codigo",

        "localidad",

        "barrio"

    ];


    if(
        prohibidas.some(
            palabra =>
            texto.includes(
                palabra
            )
        )
    ){

        return false;

    }


    if(
        !/\d{2,5}/.test(
            linea
        )
    ){

        return false;

    }


    return true;

}



/* =========================================================
LOCALIDAD
========================================================= */

function extraerLocalidad(texto){

    const lineas =
    texto.split("\n");


    for(
        let i = 0;
        i < lineas.length;
        i++
    ){

        const encontrado =
        lineas[i].match(

            /^(?:localidad|barrio|ciudad)\s*:?\s*(.+)$/i

        );


        if(
            encontrado &&
            encontrado[1]
        ){

            return limpiarLocalidad(
                encontrado[1]
            );

        }

    }


    for(
        let i = 0;
        i < lineas.length;
        i++
    ){

        if(
            /^caba$/i.test(
                lineas[i]
            )
        ){

            if(
                lineas[i + 1] &&
                esPosibleLocalidad(
                    lineas[i + 1]
                )
            ){

                return limpiarLocalidad(
                    lineas[i + 1]
                );

            }

        }

    }


    for(
        const linea
        of lineas
    ){

        const encontrado =
        linea.match(

            /\bCABA\b\s*[-–|]\s*([A-Za-zÁÉÍÓÚáéíóúÑñ .]+)/i

        );


        if(
            encontrado &&
            encontrado[1]
        ){

            return limpiarLocalidad(
                encontrado[1]
            );

        }

    }


    const direccion =
    extraerDireccion(
        texto
    );


    if(direccion){

        const indice =
        lineas.findIndex(

            linea =>

            linea.toLowerCase()
            ===
            direccion.toLowerCase()

        );


        if(
            indice >= 0
        ){

            for(
                let i = indice + 1;

                i <
                Math.min(
                    indice + 4,
                    lineas.length
                );

                i++
            ){

                if(
                    esPosibleLocalidad(
                        lineas[i]
                    )
                ){

                    return limpiarLocalidad(
                        lineas[i]
                    );

                }

            }

        }

    }


    return "CABA";

}



/* =========================================================
POSIBLE LOCALIDAD
========================================================= */

function esPosibleLocalidad(linea){

    if(
        !linea ||
        linea.length < 3
    ){

        return false;

    }


    const texto =
    linea.toLowerCase();


    const excluir = [

        "dirección",

        "direccion",

        "domicilio",

        "destinatario",

        "remitente",

        "telefono",

        "teléfono",

        "fecha",

        "peso",

        "bulto",

        "caba",

        "cp",

        "orden",

        "código",

        "codigo"

    ];


    if(
        excluir.some(
            palabra =>
            texto.includes(
                palabra
            )
        )
    ){

        return false;

    }


    if(
        /^\d+$/.test(
            linea
        )
    ){

        return false;

    }


    if(
        /\d{2,5}/.test(
            linea
        )
    ){

        return false;

    }


    return /[A-Za-zÁÉÍÓÚáéíóúÑñ]/.test(
        linea
    );

}



/* =========================================================
LIMPIAR LOCALIDAD
========================================================= */

function limpiarLocalidad(valor){

    return (
        valor || ""
    )

    .replace(
        /\d{4,}/g,
        ""
    )

    .replace(
        /[-–|]/g,
        " "
    )

    .replace(
        /\s+/g,
        " "
    )

    .trim();

}



/* =========================================================
OBSERVACIONES
========================================================= */

function extraerObservaciones(texto){

    return extraerCampoPorEtiqueta(

        texto,

        [

            "Observaciones",

            "Observación",

            "Referencia"

        ]

    );

}



/* =========================================================
LIMPIAR VALOR
========================================================= */

function limpiarValor(valor){

    return (
        valor || ""
    )

    .replace(
        /^[\s:|-]+/,
        ""
    )

    .replace(
        /\s+/g,
        " "
    )

    .trim();

}



/* =========================================================
LIMPIAR NOMBRE
========================================================= */

function limpiarNombre(valor){

    return (
        valor || ""
    )

    .replace(
        /\([^)]*\)/g,
        ""
    )

    .replace(
        /\s+/g,
        " "
    )

    .trim();

}



/* =========================================================
SET VALUE
========================================================= */

function setValue(
    id,
    valor
){

    const elemento =
    document.getElementById(
        id
    );


    if(elemento){

        elemento.value =
        valor || "";

    }

}



/* =========================================================
GENERAR CODIGO INTERNO
========================================================= */

function generarCodigoInterno(){

    const numero =
    Date.now()
    .toString()
    .slice(-6);


    codigoInterno.innerText =
    "PKG-" +
    numero;

}



