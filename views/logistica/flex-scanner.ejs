    };

}



/* =========================================================
NUEVO ESCANEO
========================================================= */

document
.getElementById(
    "nuevoEscaneo"
)
.addEventListener(
    "click",
    function(){

        resultado.style.display =
        "none";


        procesandoBox.style.display =
        "none";


        codigoBarras.value =
        "";


        codigoBarrasDetectado =
        "";


        ocrTexto.value =
        "";


        ocrContainer.style.display =
        "none";


        fotoPreview.style.display =
        "none";


        imagenEtiqueta.src =
        "";


        ultimoTextoOCR =
        "";


