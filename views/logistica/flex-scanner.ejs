<script>

let stream = null;
let procesando = false;
let scannerActivo = false;
let intervaloCaptura = null;

const video = document.getElementById("video");
const canvas = document.getElementById("canvas");

const iniciar = document.getElementById("iniciarScanner");
const detener = document.getElementById("detenerScanner");

const estado = document.getElementById("scannerEstado");

const resultado = document.getElementById("resultado");
const progreso = document.getElementById("progreso");

const progressFill = document.getElementById("progressFill");
const progressText = document.getElementById("progressText");

const textoOCR = document.getElementById("textoOCR");


/* =========================================================
   SONIDOS
========================================================= */

function sonidoOK(){

    try{

        const audio = new AudioContext();

        const osc = audio.createOscillator();
        const gain = audio.createGain();

        osc.connect(gain);
        gain.connect(audio.destination);

        osc.frequency.value = 900;
        osc.type = "sine";

        gain.gain.setValueAtTime(
            0.3,
            audio.currentTime
        );

        gain.gain.exponentialRampToValueAtTime(
            0.01,
            audio.currentTime + 0.4
        );

        osc.start();

        osc.stop(
            audio.currentTime + 0.4
        );

    }catch(e){}

}


function sonidoError(){

    try{

        const audio = new AudioContext();

        const osc = audio.createOscillator();
        const gain = audio.createGain();

        osc.connect(gain);
        gain.connect(audio.destination);

        osc.frequency.value = 180;
        osc.type = "square";

        gain.gain.setValueAtTime(
            0.25,
            audio.currentTime
        );

        gain.gain.exponentialRampToValueAtTime(
            0.01,
            audio.currentTime + 0.4
        );

        osc.start();

        osc.stop(
            audio.currentTime + 0.4
        );

    }catch(e){}

}


/* =========================================================
   UTILIDADES
========================================================= */

function generarCodigoInterno(){

    return "PKG-" +
    Math.floor(
        100000 +
        Math.random() * 900000
    );

}


function fechaActual(){

    return new Date()
    .toLocaleString(
        "es-AR"
    );

}


function limpiarTexto(texto){

    if(!texto){

        return "";

    }

    return String(texto)

    .replace(
        /\r/g,
        ""
    )

    .replace(
        /[ \t]+/g,
        " "
    )

    .replace(
        /\n{3,}/g,
        "\n\n"
    )

    .trim();

}


function limpiarCampo(valor){

    if(!valor){

        return "";

    }

    return String(valor)

    .replace(
        /^[\s:;\-–—]+/,
        ""
    )

    .replace(
        /\s+/g,
        " "
    )

    .trim();

}


function lineasTexto(texto){

    return limpiarTexto(texto)

    .split(/\n/)

    .map(
        linea => limpiarCampo(linea)
    )

    .filter(
        Boolean
    );

}


function normalizarOCR(texto){

    return String(texto || "")

    .replace(
        /[|]/g,
        "I"
    )

    .replace(
        /[«»]/g,
        ""
    )

    .replace(
        /\r/g,
        ""
    )

    .replace(
        /[ \t]+/g,
        " "
    )

    .trim();

}


/* =========================================================
   CÁMARA
========================================================= */

iniciar.addEventListener(
"click",
async function(){

    try{

        if(
            !navigator.mediaDevices ||
            !navigator.mediaDevices.getUserMedia
        ){

            alert(
                "Tu navegador no permite acceder a la cámara."
            );

            return;

        }


        stream =
        await navigator.mediaDevices
        .getUserMedia({

            video:{

                facingMode:{
                    ideal:"environment"
                },

                width:{
                    ideal:1920
                },

                height:{
                    ideal:1080
                }

            },

            audio:false

        });


        video.srcObject =
        stream;


        await video.play();


        scannerActivo =
        true;

        procesando =
        false;


        iniciar.style.display =
        "none";

        detener.style.display =
        "inline-block";


        estado.innerHTML =
        "📷 Cámara activa. Mantené la etiqueta completa dentro del cuadro.";


        intervaloCaptura =
        setInterval(

            capturarImagen,

            5000

        );


    }catch(error){

        console.error(
            "ERROR CÁMARA:",
            error
        );

        alert(
            "No se pudo abrir la cámara: " +
            error.message
        );

    }

});


detener.addEventListener(
"click",
detenerScanner
);


function detenerScanner(){

    scannerActivo =
    false;


    if(intervaloCaptura){

        clearInterval(
            intervaloCaptura
        );

        intervaloCaptura =
        null;

    }


    if(stream){

        stream
        .getTracks()
        .forEach(
            track =>
            track.stop()
        );

        stream =
        null;

    }


    video.srcObject =
    null;


    iniciar.style.display =
    "inline-block";

    detener.style.display =
    "none";


    estado.innerHTML =
    "Scanner detenido";

}


/* =========================================================
   CAPTURA
========================================================= */

async function capturarImagen(){

    if(
        !scannerActivo ||
        procesando
    ){

        return;

    }


    if(
        video.readyState < 2
    ){

        return;

    }


    const width =
    video.videoWidth;

    const height =
    video.videoHeight;


    if(
        !width ||
        !height
    ){

        return;

    }


    canvas.width =
    width;

    canvas.height =
    height;


    const ctx =
    canvas.getContext(
        "2d",
        {
            willReadFrequently:true
        }
    );


    ctx.drawImage(
        video,
        0,
        0,
        width,
        height
    );


    const imagen =
    canvas.toDataURL(
        "image/jpeg",
        0.98
    );


    await analizarImagen(
        imagen
    );

}


/* =========================================================
   OCR PRINCIPAL
========================================================= */

async function analizarImagen(imagen){

    if(procesando){

        return;

    }


    procesando =
    true;


    estado.innerHTML =
    "🔎 Analizando etiqueta...";


    progreso.style.display =
    "block";


    progressFill.style.width =
    "5%";


    progressText.innerText =
    "Preparando reconocimiento...";


    try{

        const resultadoOCR =
        await Tesseract.recognize(

            imagen,

            "spa",

            {

                logger:
                info => {

                    if(
                        info.status ===
                        "recognizing text"
                    ){

                        const porcentaje =
                        Math.round(
                            info.progress *
                            100
                        );


                        progressFill.style.width =
                        porcentaje +
                        "%";


                        progressText.innerText =
                        "Leyendo etiqueta... " +
                        porcentaje +
                        "%";

                    }

                }

            }

        );


        let texto =
        resultadoOCR
        .data
        .text;


        texto =
        normalizarOCR(
            texto
        );


        console.log(
            "================================"
        );

        console.log(
            "OCR COMPLETO"
        );

        console.log(
            texto
        );

        console.log(
            "================================"
        );


        if(
            !texto ||
            texto.length < 5
        ){

            throw new Error(
                "No se obtuvo texto suficiente"
            );

        }


        /*
        IMPORTANTE:

        YA NO EXIGIMOS 4 CAMPOS.

        Una etiqueta puede tener solamente:

        Destinatario
        Dirección

        o

        Nombre
        Teléfono

        o

        Código de barras

        y aun así debe poder guardarse.
        */


        const datos =
        procesarDatos(
            texto
        );


        console.log(
            "DATOS DETECTADOS:",
            datos
        );


        textoOCR.value =
        texto;


        progressFill.style.width =
        "100%";


        progressText.innerText =
        "✅ OCR terminado";


        detenerScanner();


        sonidoOK();


        mostrarResultado(
            datos,
            texto
        );


    }catch(error){

        console.error(
            "ERROR OCR:",
            error
        );


        sonidoError();


        estado.innerHTML =
        "❌ No se pudo leer correctamente la etiqueta. Intentá acercar la cámara y mantener la etiqueta completa visible.";


        procesando =
        false;

    }

}


/* =========================================================
   PROCESAMIENTO GENERAL
========================================================= */

function procesarDatos(texto){

    let datos = {

        codigoBarras:
        detectarCodigoBarras(
            texto
        ),

        numeroOrden:
        detectarOrden(
            texto
        ),

        fechaEmision:
        detectarFecha(
            texto
        ),

        peso:
        detectarPeso(
            texto
        ),

        bultos:
        detectarBultos(
            texto
        ),

        numeroBulto:
        detectarNumeroBulto(
            texto
        ),

        remitente:
        detectarRemitente(
            texto
        ),

        destinatario:
        detectarDestinatario(
            texto
        ),

        telefono:
        detectarTelefono(
            texto
        ),

        direccion:
        detectarDireccion(
            texto
        ),

        codigoPostal:
        detectarCodigoPostal(
            texto
        ),

        localidad:
        detectarLocalidad(
            texto
        )

    };


    /*
    Si tenemos una dirección, intentamos
    buscar localidad y barrio usando
    todo el contexto.
    */


    datos.zona =
    detectarZona(

        texto,

        datos.localidad,

        datos.direccion

    );


    /*
    Si encontramos un teléfono que es
    idéntico al código de barras,
    eliminamos el teléfono.

    Es preferible dejar teléfono vacío
    antes que asignar incorrectamente
    el código de barras como teléfono.
    */


    if(

        datos.telefono &&
        datos.codigoBarras &&

        limpiarNumero(
            datos.telefono
        ) ===
        limpiarNumero(
            datos.codigoBarras
        )

    ){

        datos.telefono =
        detectarTelefonoAlternativo(
            texto,
            datos.codigoBarras
        );

    }


    /*
    Si el código de barras encontrado
    parece en realidad un teléfono,
    intentamos descartarlo.
    */


    if(
        datos.codigoBarras &&
        esTelefonoProbable(
            datos.codigoBarras,
            texto
        )
    ){

        const otroCodigo =
        detectarCodigoBarrasAlternativo(
            texto,
            datos.telefono
        );


        datos.codigoBarras =
        otroCodigo;

    }


    return datos;

}


/* =========================================================
   CÓDIGO DE BARRAS
========================================================= */

function limpiarNumero(valor){

    return String(
        valor || ""
    )
    .replace(
        /\D/g,
        ""
    );

}


function detectarCodigoBarras(texto){

    const lineas =
    lineasTexto(
        texto
    );


    const candidatos = [];


    for(
        const linea of lineas
    ){

        let limpia =
        linea.replace(
            /[^0-9]/g,
            ""
        );


        /*
        Los códigos de barras suelen
        aparecer solos en una línea.

        Aceptamos 8 a 14 dígitos.
        */


        if(
            /^\d{8,14}$/.test(
                limpia
            )
        ){

            candidatos.push(
                limpia
            );

        }

    }


    /*
    Buscar códigos precedidos
    por palabras conocidas.
    */


    const match =
    texto.match(

        /(?:EAN|UPC|GTIN|Código\s*de\s*barras|Codigo\s*de\s*barras)\s*:?\s*(\d{8,14})/i

    );


    if(match){

        return match[1];

    }


    /*
    De momento no tomamos automáticamente
    un número de 10-14 dígitos como código
    si aparece junto a "Teléfono".
    */


    const candidatosFiltrados =
    candidatos.filter(

        numero => {

            const posicion =
            texto.indexOf(
                numero
            );


            const contexto =
            texto.substring(

                Math.max(
                    0,
                    posicion - 40
                ),

                posicion + numero.length + 40

            );


            return !/tel[eé]fono|tel\.?|celular|cel\.?/i
            .test(
                contexto
            );

        }

    );


    if(
        candidatosFiltrados.length
    ){

        return candidatosFiltrados
        .sort(

            (a,b) =>
            b.length -
            a.length

        )[0];

    }


    return "";

}


function detectarCodigoBarrasAlternativo(
    texto,
    telefono
){

    const numeros =
    texto.match(
        /\b\d{8,14}\b/g
    ) || [];


    for(
        const numero of numeros
    ){

        if(
            numero !== telefono
        ){

            return numero;

        }

    }


    return "";

}


/* =========================================================
   FECHA
========================================================= */

function detectarFecha(texto){

    const match =
    texto.match(

        /\b\d{1,2}[\/\-]\d{1,2}[\/\-]\d{2,4}\b/

    );


    return match
    ?
    match[0]
    :
    "";

}


/* =========================================================
   NÚMERO DE ORDEN
========================================================= */

function detectarOrden(texto){

    const lineas =
    lineasTexto(
        texto
    );


    for(
        let i = 0;
        i < lineas.length;
        i++
    ){

        if(

            /Nro\.?\s*Ord|N°\s*Ord|Orden/i

            .test(
                lineas[i]
            )

        ){

            const bloque =
            lineas
            .slice(
                i,
                i + 3
            )
            .join(
                " "
            );


            const numeros =
            bloque.match(
                /\b\d{4,10}\b/g
            );


            if(
                numeros &&
                numeros.length
            ){

                return numeros[
                    numeros.length - 1
                ];

            }

        }

    }


    return "";

}


/* =========================================================
   PESO
========================================================= */

function detectarPeso(texto){

    const match =
    texto.match(

        /PESO\s*:?\s*(\d+(?:[.,]\d+)?)\s*(?:KG|KGS|KILOS)?/i

    );


    if(match){

        return match[1];

    }


    return "";

}


/* =========================================================
   BULTOS
========================================================= */

function detectarBultos(texto){

    const match =
    texto.match(

        /BULTOS?\s*:?\s*(\d{1,3})/i

    );


    return match
    ?
    match[1]
    :
    "";

}


/* =========================================================
   NÚMERO DE BULTO
========================================================= */

function detectarNumeroBulto(texto){

    const match =
    texto.match(

        /\b(\d{1,3})\s*(?:DE|\/)\s*(\d{1,3})\b/i

    );


    if(match){

        return (

            match[1] +
            " de " +
            match[2]

        );

    }


    return "";

}


/* =========================================================
   REMITENTE
========================================================= */

function detectarRemitente(texto){

    const lineas =
    lineasTexto(
        texto
    );


    for(
        let i = 0;
        i < lineas.length;
        i++
    ){

        if(
            /^Remitente\b/i
            .test(
                lineas[i]
            )
        ){

            const inline =
            lineas[i].match(

                /^Remitente\s*:?\s*(.+)$/i

            );


            if(
                inline &&
                inline[1]
            ){

                return limpiarCampo(
                    inline[1]
                );

            }


            if(
                lineas[i + 1]
            ){

                return limpiarCampo(
                    lineas[i + 1]
                );

            }

        }

    }


    return "";

}


/* =========================================================
   DESTINATARIO
========================================================= */

function detectarDestinatario(texto){

    const lineas =
    lineasTexto(
        texto
    );


    for(
        let i = 0;
        i < lineas.length;
        i++
    ){

        if(
            /^Destinatario\b/i
            .test(
                lineas[i]
            )
        ){

            const inline =
            lineas[i].match(

                /^Destinatario\s*:?\s*(.+)$/i

            );


            if(
                inline &&
                inline[1]
            ){

                return limpiarNombre(
                    inline[1]
                );

            }


            /*
            Si la línea siguiente es
            "Teléfono", "Dirección", etc.,
            no es el destinatario.
            */


            for(

                let j = i + 1;

                j < Math.min(
                    i + 3,
                    lineas.length
                );

                j++

            ){

                const siguiente =
                lineas[j];


                if(
                    /^(Tel[eé]fono|Tel|Cel|Direcci[oó]n|Domicilio|CP|C\.P\.|Código Postal)/i
                    .test(
                        siguiente
                    )
                ){

                    continue;

                }


                if(
                    siguiente.length > 2
                ){

                    return limpiarNombre(
                        siguiente
                    );

                }

            }

        }

    }


    return "";

}


function limpiarNombre(nombre){

    return limpiarCampo(

        String(nombre || "")

        .replace(
            /\(\s*\d[\d\s\-]{7,}\)/g,
            ""
        )

        .replace(
            /\bTel[eé]fono\b.*$/i,
            ""
        )

    );

}


/* =========================================================
   TELÉFONO
========================================================= */

function detectarTelefono(texto){

    const lineas =
    lineasTexto(
        texto
    );


    /*
    PRIMERA PRIORIDAD:

    Buscar teléfono explícitamente
    etiquetado.
    */


    for(
        let i = 0;
        i < lineas.length;
        i++
    ){

        const match =
        lineas[i].match(

            /(?:Tel[eé]fono|Tel|Celular|Cel)\s*:?\s*(.*)$/i

        );


        if(match){

            const numero =
            extraerTelefono(
                match[1]
            );


            if(numero){

                return numero;

            }


            if(
                lineas[i + 1]
            ){

                const siguiente =
                extraerTelefono(
                    lineas[i + 1]
                );


                if(siguiente){

                    return siguiente;

                }

            }

        }

    }


    /*
    SEGUNDA PRIORIDAD:

    Número entre paréntesis.
    */


    const parentesis =
    texto.match(

        /\(\s*(\d[\d\s\-]{7,15})\s*\)/

    );


    if(parentesis){

        return limpiarNumero(
            parentesis[1]
        );

    }


    /*
    TERCERA PRIORIDAD:

    Números telefónicos separados.
    */


    const candidatos =
    texto.match(

        /\b(?:0?11[\s\-]?)?\d{4}[\s\-]?\d{4}\b/g

    ) || [];


    for(
        const candidato of candidatos
    ){

        const numero =
        limpiarNumero(
            candidato
        );


        if(
            numero.length >= 8 &&
            numero.length <= 13
        ){

            return numero;

        }

    }


    return "";

}


function extraerTelefono(texto){

    if(!texto){

        return "";

    }


    const numeros =
    texto.match(
        /\d[\d\s\-\(\)]{7,18}\d/g
    );


    if(
        !numeros
    ){

        return "";

    }


    for(
        const numero of numeros
    ){

        const limpio =
        limpiarNumero(
            numero
        );


        if(
            limpio.length >= 8 &&
            limpio.length <= 15
        ){

            return limpio;

        }

    }


    return "";

}


function detectarTelefonoAlternativo(
    texto,
    codigo
){

    const lineas =
    lineasTexto(
        texto
    );


    for(
        let i = 0;
        i < lineas.length;
        i++
    ){

        if(
            /tel[eé]fono|tel\.?|celular|cel\.?/i
            .test(
                lineas[i]
            )
        ){

            const numero =
            extraerTelefono(
                lineas[i]
            );


            if(
                numero &&
                numero !== codigo
            ){

                return numero;

            }


            if(
                lineas[i + 1]
            ){

                const siguiente =
                extraerTelefono(
                    lineas[i + 1]
                );


                if(
                    siguiente &&
                    siguiente !== codigo
                ){

                    return siguiente;

                }

            }

        }

    }


    return "";

}


function esTelefonoProbable(
    numero,
    texto
){

    const pos =
    texto.indexOf(
        numero
    );


    if(
        pos < 0
    ){

        return false;

    }


    const contexto =
    texto.substring(

        Math.max(
            0,
            pos - 50
        ),

        pos + numero.length + 50

    );


    return /tel[eé]fono|tel\.?|celular|cel\.?/i
    .test(
        contexto
    );

}


/* =========================================================
   DIRECCIÓN
========================================================= */

function detectarDireccion(texto){

    const lineas =
    lineasTexto(
        texto
    );


    /*
    PRIMERA PRIORIDAD:

    Dirección explícita.
    */


    for(
        let i = 0;
        i < lineas.length;
        i++
    ){

        const match =
        lineas[i].match(

            /^(?:Direcci[oó]n|Domicilio)\s*:?\s*(.*)$/i

        );


        if(match){

            if(
                match[1] &&
                pareceDireccion(
                    match[1]
                )
            ){

                return limpiarCampo(
                    match[1]
                );

            }


            for(

                let j = i + 1;

                j < Math.min(
                    i + 4,
                    lineas.length
                );

                j++

            ){

                if(
                    pareceDireccion(
                        lineas[j]
                    )
                ){

                    return limpiarCampo(
                        lineas[j]
                    );

                }

            }

        }

    }


    /*
    SEGUNDA PRIORIDAD:

    Buscar una calle + número.

    Ejemplo:

    Bolivar 1640
    Corrientes 1234
    Av. Rivadavia 500
    */


    for(
        const linea of lineas
    ){

        if(
            pareceDireccion(
                linea
            )
        ){

            return limpiarCampo(
                linea
            );

        }

    }


    return "";

}


function pareceDireccion(linea){

    if(!linea){

        return false;

    }


    const texto =
    limpiarCampo(
        linea
    );


    if(
        texto.length < 5
    ){

        return false;

    }


    /*
    Excluir campos que contienen
    números pero no son direcciones.
    */


    if(

        /^(PESO|BULTOS?|NRO|N°|ORDEN|C\.?P\.?|CÓDIGO|CODIGO|TEL|TELÉFONO|CELULAR)/i

        .test(
            texto
        )

    ){

        return false;

    }


    /*
    Dirección clásica:

    Calle 1234
    Av. Rivadavia 1234
    Bolivar 1640
    */


    if(

        /\b[A-Za-zÁÉÍÓÚáéíóúÑñ.°]+\s+\d{2,5}\b/

        .test(
            texto
        )

    ){

        return true;

    }


    /*
    También acepta:

    Av. Corrientes 1234
    Juan B Justo 500
    */


    if(

        /\b\d{2,5}\b/.test(texto) &&
        /[A-Za-zÁÉÍÓÚáéíóúÑñ]/.test(texto)

    ){

        return true;

    }


    return false;

}


/* =========================================================
   CÓDIGO POSTAL
========================================================= */

function detectarCodigoPostal(texto){

    /*
    Caso:

    C.P.: Capital Federal = 1141
    */


    let match =
    texto.match(

        /(?:C\.?\s*P\.?|C[oó]digo\s*Postal)\s*:?\s*.*?(\d{4,8})\b/i

    );


    if(match){

        return match[1];

    }


    /*
    Caso:

    CP 1141
    */


    match =
    texto.match(

        /\bCP\s*:?\s*(\d{4,8})\b/i

    );


    if(match){

        return match[1];

    }


    return "";

}


/* =========================================================
   LOCALIDAD
========================================================= */

function detectarLocalidad(texto){

    const lineas =
    lineasTexto(
        texto
    );


    /*
    PRIMERA PRIORIDAD:

    Localidad explícita.
    */


    for(
        let i = 0;
        i < lineas.length;
        i++
    ){

        const match =
        lineas[i].match(

            /^(?:Localidad|Ciudad|Localidad\/Ciudad)\s*:?\s*(.+)$/i

        );


        if(match){

            return limpiarCampo(
                match[1]
            );

        }

    }


    /*
    CASO:

    C.P.: Capital Federal = 1141

    Resultado:

    Capital Federal
    */


    for(
        const linea of lineas
    ){

        const match =
        linea.match(

            /C\.?\s*P\.?\s*:?\s*(.*?)\s*=\s*\d{4,8}/i

        );


        if(
            match &&
            match[1]
        ){

            return limpiarCampo(
                match[1]
            );

        }

    }


    /*
    CASO:

    C.P.: Capital Federal - 1141
    */


    for(
        const linea of lineas
    ){

        const match =
        linea.match(

            /C\.?\s*P\.?\s*:?\s*([A-Za-zÁÉÍÓÚáéíóúÑñ ]+?)\s*[-=]\s*\d{4,8}/i

        );


        if(
            match &&
            match[1]
        ){

            return limpiarCampo(
                match[1]
            );

        }

    }


    return "";

}


