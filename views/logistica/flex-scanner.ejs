<!DOCTYPE html>

<html lang="es">

<head>

<meta charset="UTF-8">

<meta
name="viewport"
content="width=device-width, initial-scale=1.0"

>

<title>Flex Scanner - AppCraft Pro</title>

<link
    rel="stylesheet"
    href="/css/panel.css"
>

<link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{

    background:#f4f6f9;

    font-family:
    Arial,
    Helvetica,
    sans-serif;

    color:#1e293b;

}

.header{

    background:#1e293b;

    color:white;

    padding:22px;

    box-shadow:
    0 3px 15px
    rgba(0,0,0,.15);

}

.header h1{

    font-size:26px;

    margin-bottom:7px;

}

.header p{

    opacity:.85;

    font-size:14px;

}

.container{

    width:100%;

    max-width:1000px;

    margin:auto;

    padding:20px;

}

.back{

    display:inline-flex;

    align-items:center;

    gap:8px;

    margin-bottom:20px;

    text-decoration:none;

    color:#2563eb;

    font-weight:bold;

}

.panel{

    background:white;

    border-radius:16px;

    padding:25px;

    box-shadow:
    0 5px 20px
    rgba(0,0,0,.08);

    margin-bottom:20px;

}

.panel h2{

    font-size:20px;

    margin-bottom:20px;

}

label{

    display:block;

    font-weight:bold;

    margin-bottom:8px;

}

select{

    width:100%;

    padding:14px;

    border:1px solid #d1d5db;

    border-radius:10px;

    font-size:16px;

    background:white;

}

.scanner{

    margin-top:20px;

    background:#0f172a;

    border-radius:16px;

    padding:20px;

    text-align:center;

    color:white;

}

.camera-box{

    width:100%;

    max-width:500px;

    margin:auto;

}

#video{

    width:100%;

    display:block;

    border-radius:12px;

    background:#000;

}

#canvas{

    display:none;

}

.btn{

    border:none;

    border-radius:10px;

    padding:14px 22px;

    font-size:16px;

    font-weight:bold;

    cursor:pointer;

    margin-top:15px;

}

.btn-primary{

    background:#2563eb;

    color:white;

}

.btn-success{

    background:#16a34a;

    color:white;

}

.btn-danger{

    background:#dc2626;

    color:white;

}

.btn-secondary{

    background:#64748b;

    color:white;

}

.btn-warning{

    background:#f59e0b;

    color:white;

}

.resultado{

    display:none;

}

.form-grid{

    display:grid;

    grid-template-columns:
    repeat(
        auto-fit,
        minmax(220px,1fr)
    );

    gap:15px;

}

input,
textarea{

    width:100%;

    padding:12px;

    border:1px solid #d1d5db;

    border-radius:9px;

    font-size:15px;

}

textarea{

    min-height:90px;

    resize:vertical;

}

.estado{

    background:#f1f5f9;

    padding:15px;

    border-radius:10px;

    margin-top:15px;

}

.codigo{

    font-size:22px;

    font-weight:bold;

    color:#2563eb;

    margin-top:5px;

}

.progreso{

    display:none;

    margin-top:20px;

    background:#1e293b;

    border-radius:10px;

    padding:15px;

}

.progress-bar{

    width:100%;

    height:12px;

    background:#334155;

    border-radius:20px;

    overflow:hidden;

    margin-top:10px;

}

.progress-fill{

    width:0%;

    height:100%;

    background:#22c55e;

    transition:.3s;

}

.ocr-text{

    display:none;

    margin-top:20px;

    background:#f8fafc;

    border:1px solid #e2e8f0;

    border-radius:10px;

    padding:15px;

}

.ocr-text h3{

    margin-bottom:10px;

}

.ocr-text pre{

    white-space:pre-wrap;

    word-break:break-word;

    font-size:13px;

    line-height:1.5;

    color:#334155;

}

.info{

    margin-top:15px;

    padding:12px;

    background:#eff6ff;

    color:#1d4ed8;

    border-radius:10px;

    font-size:14px;

}

.success{

    margin-top:15px;

    padding:12px;

    background:#f0fdf4;

    color:#166534;

    border-radius:10px;

    display:none;

}

.error{

    margin-top:15px;

    padding:12px;

    background:#fef2f2;

    color:#991b1b;

    border-radius:10px;

    display:none;

}

.mobile-buttons{

    display:flex;

    gap:10px;

    justify-content:center;

    flex-wrap:wrap;

}

@media(max-width:600px){

    .container{

        padding:12px;

    }

    .panel{

        padding:18px;

    }

    .header h1{

        font-size:22px;

    }

    .btn{

        width:100%;

    }

}

</style>

</head>

