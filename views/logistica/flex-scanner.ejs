/* =========================================================
   MOSTRAR RESULTADO
========================================================= */

function mostrarResultado(
    datos,
    texto
){

    document.getElementById(
        "codigoInterno"
    ).innerText =
    generarCodigoInterno();


    const campos = {

        codigoBarras:
        datos.codigoBarras,

        numeroOrden:
        datos.numeroOrden,

        fechaEmision:
        datos.fechaEmision,

        peso:
        datos.peso,

        bultos:
        datos.bultos,

        numeroBulto:
        datos.numeroBulto,

        remitente:
        datos.remitente,

        destinatario:
        datos.destinatario,

        telefono:
        datos.telefono,

        direccion:
        datos.direccion,

        codigoPostal:
        datos.codigoPostal,

        localidad:
        datos.localidad,

        zona:
        datos.zona

    };


    for(
        const id in campos
    ){

        const input =
        document.getElementById(
            id
        );


        if(input){

            const valor =
            campos[id] || "";


            input.value =
            valor;


            input.classList.toggle(
                "detectado",
                Boolean(
                    valor
                )
            );


            input.classList.toggle(
                "faltante",
                !valor
            );

        }

    }


    document.getElementById(
        "fechaRecepcion"
    ).value =
    fechaActual();


    document.getElementById(
        "observaciones"
    ).value =
    texto;


    textoOCR.value =
    texto;


    resultado.style.display =
    "block";


    /*
    Contar solamente campos importantes.

    El código de barras NO es obligatorio.

    Tampoco obligamos a que todos los
    campos existan.
    */


    const importantes = [

        datos.destinatario,

        datos.direccion,

        datos.localidad,

        datos.telefono

    ];


    const encontrados =
    importantes.filter(
        valor =>
        valor &&
        String(valor).trim()
    ).length;


    if(
        encontrados >= 3
    ){

        document.getElementById(
            "alertaOk"
        ).style.display =
        "block";


        document.getElementById(
            "alertaError"
        ).style.display =
        "none";

    }else{

        document.getElementById(
            "alertaOk"
        ).style.display =
        "none";


        document.getElementById(
            "alertaError"
        ).style.display =
        "block";

    }


    procesando =
    false;

}


/* =========================================================
   VOLVER A ESCANEAR
