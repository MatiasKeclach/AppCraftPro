<!-- LIBRERÍAS -->

<script
src="https://unpkg.com/html5-qrcode"
></script>


<script
src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js"
></script>



<script>


/* =======================================================
   VARIABLES
======================================================= */


let scanner = null;

let procesando = false;

let ultimoCodigo = null;

let ultimoTiempo = 0;

let canvas = null;


/* =======================================================
   ELEMENTOS
======================================================= */


const iniciar =
document.getElementById(
"iniciarScanner"
);


const detener =
document.getElementById(
"detenerScanner"
);


const estado =
document.getElementById(
"scannerEstado"
);


const resultado =
document.getElementById(
"resultado"
);


const progreso =
document.getElementById(
"progreso"
);


const barraInterna =
document.getElementById(
"barraInterna"
);


const progresoTexto =
document.getElementById(
"progresoTexto"
);


const codigoBarras =
document.getElementById(
"codigoBarras"
);


const textoOCR =
document.getElementById(
"textoOCR"
);


const datosFaltantes =
document.getElementById(
"datosFaltantes"
);


const listaFaltantes =
document.getElementById(
"listaFaltantes"
);



/* =======================================================
   SONIDOS
======================================================= */


function sonidoFrecuencia(
frecuencia,
duracion
){

try{


const AudioContext =
window.AudioContext ||
window.webkitAudioContext;


const audio =
new AudioContext();


const oscilador =
audio.createOscillator();


const ganancia =
audio.createGain();


oscilador.connect(
ganancia
);


ganancia.connect(
audio.destination
);


oscilador.frequency.value =
frecuencia;


ganancia.gain.setValueAtTime(
0.15,
audio.currentTime
);


oscilador.start();


oscilador.stop(
audio.currentTime +
duracion
);


}catch(error){

console.log(
"Audio no disponible"
);

}

}


function sonidoOK(){

sonidoFrecuencia(
880,
0.15
);

}


function sonidoWarning(){

sonidoFrecuencia(
500,
0.15
);

setTimeout(
()=>sonidoFrecuencia(
500,
0.15
),
200
);

}


function sonidoError(){

sonidoFrecuencia(
250,
0.2
);

setTimeout(
()=>sonidoFrecuencia(
180,
0.25
),
250
);

}



/* =======================================================
   ESTADO
======================================================= */


function cambiarEstado(
texto,
tipo
){

estado.innerHTML =
texto;


estado.className =
"estado-scanner";


if(tipo === "ok"){

estado.classList.add(
"estado-ok"
);

}

else if(tipo === "error"){

estado.classList.add(
"estado-error"
);

}

else if(tipo === "warning"){

estado.classList.add(
"estado-warning"
);

}

else{

estado.classList.add(
"estado-esperando"
);

}

}



/* =======================================================
   INICIAR SCANNER
======================================================= */


iniciar.addEventListener(
"click",
async function(){


try{


if(scanner){

return;

}


scanner =
new Html5Qrcode(
"reader"
);


const cameras =
await Html5Qrcode.getCameras();


if(
!cameras ||
!cameras.length
){

alert(
"No se encontró ninguna cámara."
);

return;

}


let cameraId =
cameras[0].id;


const trasera =
cameras.find(
camera => {

const nombre =
(
camera.label ||
""
).toLowerCase();


return (

nombre.includes("back")

||

nombre.includes("rear")

||

nombre.includes("trasera")

);

}

);


if(trasera){

cameraId =
trasera.id;

}


await scanner.start(

cameraId,

{

fps:10,

qrbox:{

width:300,

height:200

}

},


codigoDetectado,


error => {

}


);


iniciar.style.display =
"none";


detener.style.display =
"inline-block";


cambiarEstado(
"📷 Cámara activa. Apuntá a la etiqueta completa.",
""
);


}catch(error){


console.error(
"Error iniciando scanner:",
error
);


sonidoError();


alert(
"Error iniciando cámara: "
+
error.message
);


}

});



/* =======================================================
   CÓDIGO DETECTADO
======================================================= */


async function codigoDetectado(
codigo
){


if(procesando){

return;

}


const ahora =
Date.now();


if(
codigo === ultimoCodigo
&&
ahora - ultimoTiempo < 10000
){

return;

}


ultimoCodigo =
codigo;


ultimoTiempo =
ahora;


procesando =
true;


console.log(
"📷 Código detectado:",
codigo
);


sonidoOK();


cambiarEstado(
"✅ Etiqueta detectada. Capturando información...",
"ok"
);


codigoBarras.value =
codigo;


resultado.style.display =
"block";


await detenerScanner();


setTimeout(
()=>{

capturarEtiqueta();

},
500
);

}



/* =======================================================
   DETENER SCANNER
======================================================= */


detener.addEventListener(
"click",
detenerScanner
);


async function detenerScanner(){


if(!scanner){

return;

}


try{


await scanner.stop();


scanner.clear();


}catch(error){


console.error(
"Error deteniendo scanner:",
error
);


}


scanner =
null;


iniciar.style.display =
"inline-block";


detener.style.display =
"none";

}



/* =======================================================
   CAPTURAR ETIQUETA
======================================================= */


async function capturarEtiqueta(){


try{


progreso.style.display =
"block";


resultado.style.display =
"none";


actualizarProgreso(
10,
"Preparando imagen..."
);


const video =
document.querySelector(
"#reader video"
);


if(!video){


console.error(
"No se encontró video."
);


return;

}


canvas =
document.createElement(
"canvas"
);


canvas.width =
video.videoWidth;


canvas.height =
video.videoHeight;


const contexto =
canvas.getContext(
"2d"
);


contexto.drawImage(

video,

0,

0,

canvas.width,

canvas.height

);


actualizarProgreso(
20,
"Procesando imagen..."
);


const imagen =
canvas.toDataURL(
"image/jpeg",
0.95
);


await procesarOCR(
imagen
);


}catch(error){


console.error(
"Error capturando etiqueta:",
error
);


sonidoError();


cambiarEstado(
"❌ No se pudo analizar la etiqueta.",
"error"
);


alert(
"No se pudo analizar la etiqueta. Volvé a escanear."
);


procesando =
false;

}

}



/* =======================================================
   OCR
======================================================= */


async function procesarOCR(
imagen
){


actualizarProgreso(
30,
"Ejecutando OCR..."
);


const resultadoOCR =
await Tesseract.recognize(

imagen,

"spa",

{

logger:
info => {

if(
info.status ===
"recognizing text"
){

const porcentaje =
Math.round(
info.progress * 100
);


actualizarProgreso(

30 +
Math.round(
porcentaje * 0.6
),

"Reconociendo texto... "
+
porcentaje
+
"%"

);

}

}

}

);


const texto =
resultadoOCR.data.text;


console.log(
"===== OCR ====="
);


console.log(
texto
);


textoOCR.textContent =
texto;


actualizarProgreso(
95,
"Analizando campos..."
);


const datos =
extraerDatos(
texto
);


mostrarDatos(
datos,
texto
);


actualizarProgreso(
100,
"Análisis terminado."
);


setTimeout(
()=>{

progreso.style.display =
"none";

},
1000
);


procesando =
false;

}



/* =======================================================
   EXTRAER DATOS
======================================================= */


function extraerDatos(
texto
){


const lineas =
texto
.split("\n")
.map(
linea =>
linea.trim()
)
.filter(
linea =>
linea.length > 0
);


const resultado = {

fechaEmision:"",
peso:"",
bultos:"",
numeroBulto:"",
numeroOrden:"",
remitente:"",
destinatario:"",
telefono:"",
direccion:"",
codigoPostal:"",
localidad:"",
zona:"",
codigoBarras:""

};



/* FECHA */


const fecha =
texto.match(
/(\d{1,2}[\/\-]\d{1,2}[\/\-]\d{2,4})/
);


if(fecha){

resultado.fechaEmision =
fecha[1];

}



/* PESO */


const peso =
texto.match(

/PESO\s*[:\-]?\s*(\d+(?:[.,]\d+)?)\s*(?:KG|KGS)?/i

);


if(peso){

resultado.peso =
peso[1];

}



/* BULTOS */


const bultos =
texto.match(

/BULTOS?\s*[:\-]?\s*(\d+)/i

);


if(bultos){

resultado.bultos =
bultos[1];

}



/* NÚMERO DE ORDEN */


const orden =
texto.match(

/N(?:ro|º|°|o)?\.?\s*ORD(?:EN)?\.?\s*[:\-]?\s*(\d+)/i

);


if(orden){

resultado.numeroOrden =
orden[1];

}



/* REMITENTE */


const remitente =
texto.match(

/REMITENTE\s*[:\-]?\s*(.+)/i

);


if(remitente){

resultado.remitente =
limpiarLinea(
remitente[1]
);

}



/* DESTINATARIO + TELÉFONO */


const destinatario =
texto.match(

/DESTINATARIO\s*[:\-]?\s*(.+)/i

);


if(destinatario){


let valor =
limpiarLinea(
destinatario[1]
);


const telefono =
valor.match(
/\(?(\d{8,15})\)?/
);


if(telefono){

resultado.telefono =
telefono[1];


valor =
valor.replace(
telefono[0],
""
);

}


resultado.destinatario =
valor
.replace(
/[\(\)]/g,
""
)
.trim();

}



/* TELÉFONO EXPLÍCITO */


if(
!resultado.telefono
){


const telefono =
texto.match(

/TEL(?:ÉFONO|EFONO)?\s*[:\-]?\s*(\d{8,15})/i

);


if(telefono){

resultado.telefono =
telefono[1];

}

}



/* DIRECCIÓN */


const direccion =
texto.match(

/(?:DIRECCI[ÓO]N)\s*[:\-]?\s*(.+)/i

);


if(direccion){

resultado.direccion =
limpiarLinea(
direccion[1]
);

}



/* CÓDIGO POSTAL */


const cp =
texto.match(

/(?:CP|C\.P\.|C[ÓO]DIGO POSTAL)\s*[:\-]?\s*([A-Z]?\s*\d{4,8})/i

);


if(cp){

resultado.codigoPostal =
cp[1].trim();

}



/* CÓDIGO DE BARRAS */


const posiblesCodigos =
texto.match(
/\b\d{6,15}\b/g
);


if(posiblesCodigos){

const candidatos =
posiblesCodigos
.filter(
numero =>
numero !== resultado.telefono
&&
numero !== resultado.numeroOrden
&&
numero !== resultado.codigoPostal
);


if(candidatos.length){

resultado.codigoBarras =
candidatos[
candidatos.length - 1
];

}

}



/* DIRECCIÓN SIN ETIQUETA */


if(
!resultado.direccion
){


const indiceDest =
lineas.findIndex(
linea =>
/DESTINATARIO/i.test(
linea
)
);


if(indiceDest >= 0){


for(
let i =
indiceDest + 1;

i <
Math.min(
indiceDest + 5,
lineas.length
);

i++
){


const linea =
lineas[i];


if(

/\d{2,5}/.test(
linea
)

&&

!/(CP|CABA|BUENOS AIRES)/i.test(
linea
)

){


resultado.direccion =
linea;

break;

}

}

}

}



/* LOCALIDAD */


const posiblesLocalidades = [

"CABA",

"CAPITAL FEDERAL",

"RECOLETA",

"PALERMO",

"BELGRANO",

"ALMAGRO",

"BOEDO",

"CABALLITO",

"FLORES",

"FLORESTA",

"VILLA CRESPO",

"VILLA DEVOTO",

"VILLA DEL PARQUE",

"VILLA URQUIZA",

"VILLA PUEYRREDON",

"VILLA LURO",

"LINIERS",

"MATADEROS",

"NUÑEZ",

"COGHLAN",

"SAAVEDRA",

"COLEGIALES",

"CHACARITA",

"PARQUE PATRICIOS",

"CONSTITUCION",

"MONTSERRAT",

"MICROCENTRO",

"RETIRO",

"ONCE",

"BALVANERA",

"BOCA",

"BARRACAS",

"PARQUE CHACABUCO",

"PARQUE AVELLANEDA",

"VILLA SOLDATI",

"VILLA LUGANO",

"VILLA RIACHUELO"

];


for(
const localidad
of posiblesLocalidades
){


const regex =
new RegExp(
"\\b" +
localidad +
"\\b",
"i"
);


if(
regex.test(
texto
)
){


resultado.localidad =
localidad;

break;

}

}



/* ZONA */


if(
resultado.localidad
){

resultado.zona =
resultado.localidad;

}


return resultado;

}



/* =======================================================
   LIMPIAR TEXTO
======================================================= */


function limpiarLinea(
texto
){

return texto

.replace(
/^[\s:;\-]+/,
""
)

.replace(
/\s+/g,
" "
)

.trim();

}



/* =======================================================
   MOSTRAR DATOS
======================================================= */


function mostrarDatos(
datos,
texto
){


const campos = {

codigoBarras:
datos.codigoBarras || codigoBarras.value,

numeroOrden:
datos.numeroOrden,

fechaEmision:
datos.fechaEmision,

peso:
datos.peso,

bultos:
datos.bultos,

numeroBulto:
datos.numeroBulto,

remitente:
datos.remitente,

destinatario:
datos.destinatario,

telefono:
datos.telefono,

direccion:
datos.direccion,

codigoPostal:
datos.codigoPostal,

localidad:
datos.localidad,

zona:
datos.zona

};



for(
const campo
in campos
){


const elemento =
document.getElementById(
campo
);


if(
elemento
){


elemento.value =
campos[campo] || "";


elemento.classList.remove(
"detectado",
"faltante"
);


if(
campos[campo]
){

elemento.classList.add(
"detectado"
);

}else{

elemento.classList.add(
"faltante"
);

}

}

}



/* CÓDIGO INTERNO */


const numero =
Math.floor(
100000 +
Math.random() *
900000
);


document.getElementById(
"codigoInterno"
).textContent =

"PKG-" +
numero;



/* FECHA DE ESCANEO */


const ahora =
new Date();


document.getElementById(
"fechaEscaneo"
).textContent =

"🕐 Escaneado: " +

ahora.toLocaleString(
"es-AR"
);



/* DATOS FALTANTES */


const nombres = {

numeroOrden:
"Número de orden",

fechaEmision:
"Fecha de emisión",

peso:
"Peso",

bultos:
"Cantidad de bultos",

numeroBulto:
"Número de bulto",

remitente:
"Remitente",

destinatario:
"Destinatario",

telefono:
"Teléfono",

direccion:
"Dirección",

codigoPostal:
"Código postal",

localidad:
"Localidad",

zona:
"Zona / Barrio"

};


const faltantes = [];


for(
const campo
in nombres
){


if(
!campos[campo]
){

faltantes.push(
nombres[campo]
);

}

}



listaFaltantes.innerHTML =
"";


if(
faltantes.length
){


datosFaltantes.style.display =
"block";


faltantes.forEach(
dato => {


const li =
document.createElement(
"li"
);


li.textContent =
dato;


listaFaltantes.appendChild(
li
);

});


document.getElementById(
"estadoDatos"
).innerHTML =

'<span class="badge badge-warning">' +

'⚠️ Faltan ' +

faltantes.length +

' datos. Podés completarlos manualmente.'

+

'</span>';


sonidoWarning();


}else{


datosFaltantes.style.display =
"none";


document.getElementById(
"estadoDatos"
).innerHTML =

'<span class="badge badge-ok">' +

'✅ Todos los datos principales fueron detectados.'

+

'</span>';


sonidoOK();

}


resultado.style.display =
"block";

}



/* =======================================================
   PROGRESO
======================================================= */


function actualizarProgreso(
porcentaje,
texto
){


barraInterna.style.width =
porcentaje +
"%";


progresoTexto.textContent =
texto;

}



/* =======================================================
   VOLVER A ESCANEAR
======================================================= */


document
.getElementById(
"reescanear"
)
.addEventListener(
"click",
async function(){


resultado.style.display =
"none";


progreso.style.display =
"none";


codigoBarras.value =
"";


ultimoCodigo =
null;


procesando =
false;


cambiarEstado(
"📷 Preparado para escanear otra etiqueta.",
""
);


await iniciar.click();

});



/* =======================================================
   GUARDAR
======================================================= */


document
.getElementById(
"guardarPaquete"
)
.addEventListener(
"click",
function(){


const cliente =
document
.getElementById(
"cliente_id"
)
.value;


if(
!cliente
){

alert(
