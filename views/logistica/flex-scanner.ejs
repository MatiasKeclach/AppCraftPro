// =====================================================
// NORMALIZAR
// =====================================================

function normalizarTexto(texto) {

    return (
        texto || ""
    )

    .replace(
        /\r/g,
        ""
    )

    .replace(
        /[ \t]+/g,
        " "
    )

    .split("\n")

    .map(
        linea =>
            linea.trim()
    )

    .filter(
        linea =>
            linea.length > 0
    )

    .join("\n");

}


// =====================================================
// CÓDIGO
// =====================================================

function extraerCodigoBarras(texto) {

    const patrones = [

        /(?:c[oó]digo\s*de\s*barras|barcode)\s*:?\s*([0-9]{6,30})/i,

        /(?:pack\s*id)\s*:?\s*([A-Z0-9\-]{6,30})/i,

        /(?:env[ií]o)\s*:?\s*([A-Z0-9\-]{6,30})/i,

        /\b([0-9]{8,30})\b/

    ];


    for (
        const patron
        of patrones
    ) {

        const encontrado =
            texto.match(
                patron
            );


        if (encontrado) {

            return encontrado[1];

        }

    }


    return "";

}


// =====================================================
// ORDEN
// =====================================================

function extraerNumeroOrden(texto) {

    const encontrado =
        texto.match(

            /(?:nro\.?\s*orden|n[uú]mero\s*de\s*orden|orden)\s*:?\s*([A-Z0-9\-]+)/i

        );


    return encontrado
        ? encontrado[1]
        : "";

}


// =====================================================
// FECHA
// =====================================================

function extraerFecha(texto) {

    const encontrado =
        texto.match(

            /(?:fecha|fech[aá])\s*:?\s*(\d{1,2}[\/\-]\d{1,2}[\/\-]\d{2,4})/i

        );


    return encontrado
        ? encontrado[1]
        : "";

}


// =====================================================
// PESO
// =====================================================

function extraerPeso(texto) {

    const encontrado =
        texto.match(

            /(?:peso)\s*:?\s*([0-9]+(?:[.,][0-9]+)?\s*(?:kg|kgs|kilos)?)/i

        );


    return encontrado
        ? encontrado[1].trim()
        : "";

}


// =====================================================
// BULTOS
// =====================================================

function extraerBultos(texto) {

    const encontrado =
        texto.match(

            /(?:bultos?|piezas?)\s*:?\s*([0-9]+)/i

        );


    return encontrado
        ? encontrado[1]
        : "";

}


// =====================================================
// NUMERO BULTO
// =====================================================

function extraerNumeroBulto(texto) {

    const patrones = [

        /(?:nro\.?\s*bulto|n[uú]mero\s*de\s*bulto)\s*:?\s*([0-9]+)/i,

        /bulto\s*:?\s*([0-9]+)\s*(?:de|\/)\s*([0-9]+)/i

    ];


    for (
        const patron
        of patrones
    ) {

        const encontrado =
            texto.match(
                patron
            );


        if (encontrado) {

            return encontrado[1];

        }

    }


    return "";

}


// =====================================================
// CAMPO POR ETIQUETA
// =====================================================

function extraerCampoPorEtiqueta(
    texto,
    etiquetas
) {

    const lineas =
        texto.split("\n");


    for (
        let i = 0;
        i < lineas.length;
        i++
    ) {

        const linea =
            lineas[i].trim();


        for (
            const etiqueta
            of etiquetas
        ) {

            const regex =
                new RegExp(

                    "^"
                    +
                    etiqueta
                    +
                    "\\s*:?\\s*(.*)$",

                    "i"

                );


            const encontrado =
                linea.match(
                    regex
                );


            if (encontrado) {

                if (
                    encontrado[1] &&
                    encontrado[1].trim()
                ) {

                    return limpiarValor(
                        encontrado[1]
                    );

                }


                if (
                    lineas[i + 1]
                ) {

                    return limpiarValor(
                        lineas[i + 1]
                    );

                }

            }

        }

    }


    return "";

}


// =====================================================
// DESTINATARIO
// =====================================================

function extraerDestinatario(texto) {

    return limpiarNombre(

        extraerCampoPorEtiqueta(

            texto,

            [
                "Destinatario",
                "Destinatário"
            ]

        )

    );

}


// =====================================================
// TELEFONO
// =====================================================

function extraerTelefono(texto) {

    const patrones = [

        /(?:tel[eé]fono|telefono|tel\.?|celular|cel\.?)\s*:?\s*([0-9+\-\s]{8,25})/i,

        /\b(?:011|15|54)?\s*\d{4}[\s\-]?\d{4}\b/

    ];


    for (
        const patron
        of patrones
    ) {

        const encontrado =
            texto.match(
                patron
            );


        if (encontrado) {

            return (

                encontrado[1] ||
                encontrado[0]

            )

            .replace(
                /\s+/g,
                " "
            )

            .trim();

        }

    }


    return "";

}


// =====================================================
// DIRECCION
// =====================================================

function extraerDireccion(texto) {

    const lineas =
        texto.split("\n");


    for (
        let i = 0;
        i < lineas.length;
        i++
    ) {

        const linea =
            lineas[i].trim();


        const directa =
            linea.match(

                /^(?:direcci[oó]n|direccion)\s*:?\s*(.+)$/i

            );


        if (
            directa &&
            directa[1]
        ) {

            return limpiarValor(
                directa[1]
            );

        }


        if (

            /^(?:direcci[oó]n|direccion)\s*:?\s*$/i
            .test(
                linea
            )

        ) {

            if (
                lineas[i + 1]
            ) {

                return limpiarValor(
                    lineas[i + 1]
                );

            }

        }

    }


    // Buscar dirección por patrón
    for (
        const linea
        of lineas
    ) {

        if (
            pareceDireccion(
                linea
            )
        ) {

            return limpiarValor(
                linea
            );

        }

    }


    return "";

}


// =====================================================
// PARECE DIRECCIÓN
// =====================================================

function pareceDireccion(linea) {

    if (
        !linea ||
        linea.length < 5
    ) {

        return false;

    }


    const texto =
        linea.toLowerCase();


    const prohibidas = [

        "destinatario",
        "remitente",
        "telefono",
        "teléfono",
        "fecha",
        "peso",
        "bulto",
        "orden",
        "caba",
        "cp",
        "código",
        "codigo"

    ];


    if (

        prohibidas.some(
            palabra =>
                texto.includes(
                    palabra
                )
        )

    ) {

        return false;

    }


    if (
        !/\d{2,5}/.test(
            linea
        )
    ) {

        return false;

    }


    return true;

}


// =====================================================
// LOCALIDAD
// =====================================================

function extraerLocalidad(texto) {

    const lineas =
        texto.split("\n");


    for (
        let i = 0;
        i < lineas.length;
        i++
    ) {

        const encontrado =
            lineas[i].match(

                /^(?:localidad|barrio|ciudad)\s*:?\s*(.+)$/i

            );


        if (
            encontrado &&
            encontrado[1]
        ) {

            return limpiarLocalidad(
                encontrado[1]
            );

        }

    }


    // CABA + barrio
    for (
        let i = 0;
        i < lineas.length;
        i++
    ) {

        if (
            /^caba$/i.test(
                lineas[i]
            )
        ) {

            if (
                lineas[i + 1] &&
                esPosibleLocalidad(
                    lineas[i + 1]
                )
            ) {

                return limpiarLocalidad(
                    lineas[i + 1]
                );

            }

        }

    }


    // CABA - Barrio
    for (
        const linea
        of lineas
    ) {

        const encontrado =
            linea.match(

                /\bCABA\b\s*[-–|]\s*([A-Za-zÁÉÍÓÚáéíóúÑñ .]+)/i

            );


        if (
            encontrado &&
            encontrado[1]
        ) {

            return limpiarLocalidad(
                encontrado[1]
            );

        }

    }


    return "CABA";

}


// =====================================================
// POSIBLE LOCALIDAD
// =====================================================

function esPosibleLocalidad(linea) {

    if (
        !linea ||
        linea.length < 3
    ) {

        return false;

    }


    const texto =
        linea.toLowerCase();


    const excluir = [

        "dirección",
        "direccion",
        "destinatario",
        "remitente",
        "telefono",
        "teléfono",
        "fecha",
        "peso",
        "bulto",
        "caba",
        "cp",
        "orden",
        "código",
        "codigo"

    ];


    if (

        excluir.some(
            palabra =>
                texto.includes(
                    palabra
                )
        )

    ) {

        return false;

    }


    if (
        /^\d+$/.test(
            linea
        )
    ) {

        return false;

    }


    if (
        /\d{2,5}/.test(
            linea
        )
    ) {

        return false;

    }


    return /[A-Za-zÁÉÍÓÚáéíóúÑñ]/.test(
        linea
    );

}


// =====================================================
// LIMPIAR LOCALIDAD
// =====================================================

function limpiarLocalidad(valor) {

    return (
        valor || ""
    )

    .replace(
        /\d{4,}/g,
        ""
    )

    .replace(
        /[-–|]/g,
        " "
    )

    .replace(
        /\s+/g,
        " "
    )

    .trim();

}


// =====================================================
// OBSERVACIONES
// =====================================================

function extraerObservaciones(texto) {

    return extraerCampoPorEtiqueta(

        texto,

        [
            "Observaciones",
            "Observación",
            "Referencia"
        ]

    );

}


// =====================================================
// LIMPIAR
// =====================================================

function limpiarValor(valor) {

    return (
        valor || ""
    )

    .replace(
        /^[\s:|-]+/,
        ""
    )

    .replace(
        /\s+/g,
        " "
    )

    .trim();

}


function limpiarNombre(valor) {

    return (
        valor || ""
    )

    .replace(
        /\([^)]*\)/g,
        ""
    )

    .replace(
        /\s+/g,
        " "
    )

    .trim();

}


// =====================================================
// SET VALUE
// =====================================================

function setValue(id, valor) {

    const elemento =
        document.getElementById(
            id
        );


    if (elemento) {

        elemento.value =
            valor || "";

    }

}


