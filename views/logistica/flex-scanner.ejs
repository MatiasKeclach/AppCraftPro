        ).value.trim(),

        bultos:
        document.getElementById(
            "bultos"
        ).value.trim(),

        numeroBulto:
        document.getElementById(
            "numeroBulto"
        ).value.trim(),

        remitente:
        document.getElementById(
            "remitente"
        ).value.trim(),

        destinatario:
        document.getElementById(
            "destinatario"
        ).value.trim(),

        telefono:
        document.getElementById(
            "telefono"
        ).value.trim(),

        direccion:
        document.getElementById(
            "direccion"
        ).value.trim(),

        localidad:
        document.getElementById(
