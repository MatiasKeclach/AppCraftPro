<!-- TESSERACT OCR -->

<script
    src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js"
></script>

<script>


let stream = null;

let codigoInternoActual = null;

let ultimoTextoOCR = "";



/* ==============================

   ELEMENTOS

============================== */


const video =
    document.getElementById(
        "video"
    );


const canvas =
    document.getElementById(
        "canvas"
    );


const iniciar =
    document.getElementById(
        "iniciarScanner"
    );


const capturar =
    document.getElementById(
        "capturarFoto"
    );


const detener =
    document.getElementById(
        "detenerScanner"
    );


const estado =
    document.getElementById(
        "scannerEstado"
    );


const resultado =
    document.getElementById(
        "resultado"
    );


const progreso =
    document.getElementById(
        "progreso"
    );


const progresoTexto =
    document.getElementById(
        "progresoTexto"
    );


const progressFill =
    document.getElementById(
        "progressFill"
    );


const mensajeExito =
    document.getElementById(
        "mensajeExito"
    );


const mensajeError =
    document.getElementById(
        "mensajeError"
    );



/* ==============================

   GENERAR CODIGO INTERNO

============================== */


function generarCodigoInterno(){

    const numero =
        Date.now()
        .toString()
        .slice(-6);

    return "PKG-" + numero;

}



/* ==============================

   INICIAR CAMARA

============================== */


iniciar.addEventListener(

    "click",

    async function(){

        try{

            stream =
                await navigator.mediaDevices
                .getUserMedia({

                    video:{

                        facingMode:{
                            ideal:"environment"
                        },

                        width:{
                            ideal:1920
                        },

                        height:{
                            ideal:1080
                        }

                    },

                    audio:false

                });


            video.srcObject =
                stream;


            iniciar.style.display =
                "none";


            capturar.style.display =
                "inline-block";


            detener.style.display =
                "inline-block";


            estado.innerHTML =
                "📷 Cámara activa. Enfocá la etiqueta completa.";


        }catch(error){

            console.error(
                "Error cámara:",
                error
            );


            alert(
                "No se pudo acceder a la cámara. Verificá los permisos del navegador."
            );

        }

    }

);



/* ==============================

   DETENER CAMARA

============================== */


detener.addEventListener(

    "click",

    detenerCamara

);



function detenerCamara(){

    if(stream){

        stream
        .getTracks()
        .forEach(
            track =>
            track.stop()
        );

    }


    stream = null;


    video.srcObject = null;


    iniciar.style.display =
        "inline-block";


    capturar.style.display =
        "none";


    detener.style.display =
        "none";


    estado.innerHTML =
        "Scanner detenido";

}



/* ==============================

   CAPTURAR FOTO

============================== */


capturar.addEventListener(

    "click",

    async function(){


        if(!stream){

            alert(
                "Primero iniciá la cámara."
            );

            return;

        }


        const width =
            video.videoWidth;


        const height =
            video.videoHeight;


        canvas.width =
            width;


        canvas.height =
            height;


        const ctx =
            canvas.getContext(
                "2d"
            );


        ctx.drawImage(

            video,

            0,

            0,

            width,

            height

        );


        estado.innerHTML =
            "📸 Imagen capturada. Analizando etiqueta...";


        await procesarImagen();


    }

);



/* ==============================

   PROCESAR IMAGEN OCR

============================== */


async function procesarImagen(){


    progreso.style.display =
        "block";


    mensajeExito.style.display =
        "none";


    mensajeError.style.display =
        "none";


    resultado.style.display =
        "block";


    progressFill.style.width =
        "5%";


    progresoTexto.innerHTML =
        "🔍 Preparando OCR...";


    codigoInternoActual =
        generarCodigoInterno();


    document
    .getElementById(
        "codigoInterno"
    )
    .textContent =
        codigoInternoActual;



    try{


        progresoTexto.innerHTML =
            "🔍 Leyendo texto de la etiqueta...";


        const result =
            await Tesseract.recognize(

                canvas,

                "spa+eng",

                {

                    logger:
                    function(info){

                        if(
                            info.status ===
                            "recognizing text"
                        ){

                            const porcentaje =
                                Math.round(
                                    info.progress *
                                    100
                                );


                            progressFill.style.width =
                                porcentaje + "%";


                            progresoTexto.innerHTML =

                                "🔍 OCR leyendo etiqueta: "
                                +
                                porcentaje
                                +
                                "%";

                        }

                    }

                }

            );


        ultimoTextoOCR =
            result.data.text;


        console.log(
            "========== OCR =========="
        );


        console.log(
            ultimoTextoOCR
        );


        console.log(
            "=========================="
        );


        progressFill.style.width =
            "100%";


        progresoTexto.innerHTML =
            "✅ Lectura completada";


        document
        .getElementById(
            "ocrTexto"
        )
        .textContent =
            ultimoTextoOCR;


        document
        .getElementById(
            "ocrContainer"
        )
        .style.display =
            "block";



        /* EXTRAER DATOS */

        extraerDatos(
            ultimoTextoOCR
        );


        mensajeExito.style.display =
            "block";


        estado.innerHTML =
            "✅ Etiqueta analizada";


    }catch(error){


        console.error(
            "Error OCR:",
            error
        );


        mensajeError.style.display =
            "block";


        progresoTexto.innerHTML =
            "❌ Error procesando etiqueta";


        estado.innerHTML =
            "❌ No se pudo leer la etiqueta";


    }

}



/* ==============================

   EXTRAER DATOS

============================== */


function extraerDatos(texto){


    const lineas =

        texto

        .split("\n")

        .map(
            linea =>
            linea
            .trim()
        )

        .filter(
            linea =>
            linea.length > 0
        );



    const textoNormalizado =

        texto

        .replace(
            /\r/g,
            ""
        )

        .toUpperCase();



    /* ==========================

       CODIGO DE BARRAS

    ========================== */


    const codigos =

        texto

        .match(
            /\b\d{6,20}\b/g
        );


    if(codigos){

        const posibles =

            codigos

            .filter(
                codigo =>
                codigo !==
                codigoInternoActual
            );


        if(posibles.length){

            document
            .getElementById(
                "codigoBarras"
            )
            .value =
                posibles[
                    posibles.length - 1
                ];

        }

    }



    /* ==========================

       NUMERO ORDEN

    ========================== */


    let orden =
        buscarDespuesDeEtiqueta(

            lineas,

            [

                "NUMERO DE ORDEN",

                "NÚMERO DE ORDEN",

                "ORDER",

                "ORDER ID",

                "ORDEN"

            ]

        );


    if(orden){

        document
        .getElementById(
            "numeroOrden"
        )
        .value =
            orden;

    }



    /* ==========================

       FECHA

    ========================== */


    const fecha =

        texto.match(

            /\b\d{1,2}[\/\-]\d{1,2}[\/\-]\d{2,4}\b/

        );


    if(fecha){

        document
        .getElementById(
            "fechaEmision"
        )
        .value =
            fecha[0];

    }



    /* ==========================

       PESO

    ========================== */


    const peso =

        texto.match(

            /\b\d+(?:[.,]\d+)?\s*(?:KG|KGS|G|GR|GRAMOS)\b/i

        );


    if(peso){

        document
        .getElementById(
            "peso"
        )
        .value =
            peso[0];

    }



    /* ==========================

       BULTOS

    ========================== */


    const bultos =

        textoNormalizado.match(

            /(?:BULTOS?|TOTAL\s+BULTOS?)\s*[:\-]?\s*(\d+)/

        );


    if(bultos){

        document
        .getElementById(
            "bultos"
        )
        .value =
            bultos[1];

    }



    /* ==========================

       NUMERO DE BULTO

    ========================== */


    const numeroBulto =

        textoNormalizado.match(

            /BULTO\s*(\d+)(?:\s*(?:DE|\/)\s*(\d+))?/

        );


    if(numeroBulto){

        if(numeroBulto[2]){

            document
            .getElementById(
                "numeroBulto"
            )
            .value =

                numeroBulto[1]
                +
                " de "
                +
                numeroBulto[2];

        }else{

            document
            .getElementById(
                "numeroBulto"
            )
            .value =
                numeroBulto[1];

        }

    }



    /* ==========================

       REMITENTE

    ========================== */


    const remitente =

        buscarDespuesDeEtiqueta(

            lineas,

            [

                "REMITENTE",

                "SHIPPER",

                "FROM"

            ]

        );


    if(remitente){

        document
        .getElementById(
            "remitente"
        )
        .value =
            remitente;

    }



    /* ==========================

       DESTINATARIO

    ========================== */


    const destinatario =

        buscarDespuesDeEtiqueta(

            lineas,

            [

                "DESTINATARIO",

                "RECIPIENT",

                "TO"

            ]

        );


    if(destinatario){

        document
        .getElementById(
            "destinatario"
        )
        .value =
            destinatario;

    }



    /* ==========================

       TELEFONO

    ========================== */


    const telefono =

        texto.match(

            /(?:\+?54\s*)?(?:\(?\d{2,4}\)?[\s\-]*)?\d{4}[\s\-]?\d{4}/

        );


    if(telefono){

        document
        .getElementById(
            "telefono"
        )
        .value =
            telefono[0];

    }



    /* ==========================

       LOCALIDAD / BARRIO

    ========================== */


    const zonasCABA = [

        "RECOLETA",

        "PALERMO",

        "BELGRANO",

        "BARRACAS",

        "BOEDO",

        "CABALLITO",

        "FLORES",

        "FLORESTA",

        "VILLA CRESPO",

        "VILLA DEVOTO",

        "VILLA DEL PARQUE",

        "VILLA URQUIZA",

        "VILLA LURO",

        "VILLA PUEYRREDON",

        "COLEGIALES",

        "ALMAGRO",

        "BALVANERA",

        "SAN TELMO",

        "MONSERRAT",

        "SAN NICOLAS",

        "RETIRO",

        "NUÑEZ",

        "SAAVEDRA",

        "MATADEROS",

        "LINIERS",

        "PARQUE PATRICIOS",

        "CONSTITUCION",

        "LA BOCA",

        "PUERTO MADERO",

        "CHACARITA",

        "PATERNAL",

        "AGRONOMIA",

        "VILLA ORTUZAR",

        "PARQUE CHAS",

        "VERSALLES",

        "VILLA REAL",

        "MONTE CASTRO",

        "VELEZ SARSFIELD",

        "PARQUE AVELLANEDA",

        "NUEVA POMPEYA",

        "VILLA SOLDATI",

        "VILLA LUGANO",

        "VILLA RIACHUELO"

    ];



    let zonaEncontrada = null;


    for(
        const zona
        of zonasCABA
    ){

        if(
            textoNormalizado
            .includes(zona)
        ){

            zonaEncontrada =
                zona;

            break;

        }

    }



    if(zonaEncontrada){

        document
        .getElementById(
            "zona"
        )
        .value =
            zonaEncontrada;

    }



    /* ==========================

       DIRECCION

    ========================== */


    const direccion =

        buscarDireccion(
            lineas
        );


    if(direccion){

        document
        .getElementById(
            "direccion"
        )
        .value =
            direccion;

    }



    /* ==========================

       LOCALIDAD

    ========================== */


    const localidad =

        buscarLocalidad(

            textoNormalizado,

            zonaEncontrada

        );


    if(localidad){

        document
        .getElementById(
            "localidad"
        )
        .value =
            localidad;

    }



    /* ==========================

       OBSERVACIONES

    ========================== */


    document
    .getElementById(
        "observaciones"
    )
    .value =

        "OCR detectado automáticamente. Revisar datos antes de guardar.";


}



/* ==============================

   BUSCAR TEXTO DESPUES DE ETIQUETA

============================== */


function buscarDespuesDeEtiqueta(

    lineas,

    etiquetas

){


    for(
        let i = 0;
        i < lineas.length;
        i++
    ){


        const linea =

            lineas[i]
            .toUpperCase();



        for(
            const etiqueta
            of etiquetas
        ){


            if(
                linea
                .startsWith(
                    etiqueta
                )
            ){


                const resto =

                    lineas[i]

                    .substring(
                        etiqueta.length
                    )

                    .replace(
                        /^[:\-\s]+/,
                        ""
                    )

                    .trim();



                if(resto){

                    return resto;

                }



                if(
                    lineas[i + 1]
                ){

                    return lineas[i + 1];

                }

            }

        }

    }


    return "";

}



/* ==============================

   BUSCAR DIRECCION

============================== */


function buscarDireccion(

    lineas

){


    const patrones = [

        /\b(AV\.?|AVENIDA|CALLE|PASAJE|PJE\.?)\b/i,

        /\b[A-ZÁÉÍÓÚÑa-záéíóúñ\s]+\s+\d{2,5}\b/

    ];



    for(
        const linea
        of lineas
    ){


        const limpia =
            linea.trim();



        if(
            patrones[0]
            .test(limpia)
        ){

            return limpia;

        }



        if(
            patrones[1]
            .test(limpia)
        ){

            return limpia;

        }

    }


    return "";

}



/* ==============================

   BUSCAR LOCALIDAD

============================== */


function buscarLocalidad(

    texto,

    zona

){


    if(zona){

        return "CABA";

    }



    if(
        texto.includes(
            "CABA"
        )
    ){

        return "CABA";

    }



    if(
        texto.includes(
            "CAPITAL FEDERAL"
        )
    ){

        return "CABA";

    }



    return "";

}



