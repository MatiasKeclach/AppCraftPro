<!DOCTYPE html>

<html lang="es">

<head>

<meta charset="UTF-8">

<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<title>Particular Scanner - AppCraft Pro</title>

<link
rel="stylesheet"
href="/css/panel.css"
>

<link
rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
>

<script src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js"></script>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    background:#f4f6f9;
    font-family:Arial,Helvetica,sans-serif;
    color:#1e293b;
}

.header{
    background:#1e293b;
    color:white;
    padding:22px;
    box-shadow:0 3px 15px rgba(0,0,0,.15);
}

.header h1{
    font-size:26px;
    margin-bottom:7px;
}

.header p{
    opacity:.85;
    font-size:14px;
}

.container{
    width:100%;
    max-width:1000px;
    margin:auto;
    padding:20px;
}

.back{
    display:inline-flex;
    align-items:center;
    gap:8px;
    margin-bottom:20px;
    text-decoration:none;
    color:#2563eb;
    font-weight:bold;
}

.panel{
    background:white;
    border-radius:16px;
    padding:25px;
    box-shadow:0 5px 20px rgba(0,0,0,.08);
    margin-bottom:20px;
}

.panel h2{
    font-size:20px;
    margin-bottom:20px;
}

label{
    display:block;
    font-weight:bold;
    margin-bottom:8px;
}

select,
input,
textarea{
    width:100%;
    padding:12px;
    border:1px solid #d1d5db;
    border-radius:9px;
    font-size:15px;
    background:white;
}

textarea{
    min-height:100px;
    resize:vertical;
}

.form-grid{
    display:grid;
    grid-template-columns:
    repeat(
        auto-fit,
        minmax(220px,1fr)
    );
    gap:15px;
}

.btn{
    border:none;
    border-radius:10px;
    padding:14px 22px;
    font-size:16px;
    font-weight:bold;
    cursor:pointer;
    margin-top:15px;
}

.btn-primary{
    background:#2563eb;
    color:white;
}

.btn-success{
    background:#16a34a;
    color:white;
}

.btn-danger{
    background:#dc2626;
    color:white;
}

.btn-warning{
    background:#d97706;
    color:white;
}

.btn-secondary{
    background:#64748b;
    color:white;
}

.btn:disabled{
    opacity:.5;
    cursor:not-allowed;
}

.scanner{
    margin-top:20px;
    background:#0f172a;
    border-radius:16px;
    padding:20px;
    text-align:center;
    color:white;
}

.camera-wrapper{
    position:relative;
    width:100%;
    max-width:650px;
    margin:auto;
    overflow:hidden;
    border-radius:12px;
    background:#020617;
}

#video{
    display:block;
    width:100%;
    max-height:600px;
    object-fit:cover;
}

.scan-frame{
    position:absolute;
    top:5%;
    left:4%;
    width:92%;
    height:90%;
    border:3px solid #22c55e;
    border-radius:12px;
    pointer-events:none;
    box-shadow:
    0 0 0 9999px rgba(0,0,0,.25);
}

.estado{
    background:#f1f5f9;
    padding:15px;
    border-radius:10px;
    margin-top:15px;
}

.estado-scanner{
    margin-top:15px;
    padding:14px;
    border-radius:10px;
    background:#1e293b;
    color:white;
    font-weight:bold;
}

.resultado{
    display:none;
}

.codigo{
    font-size:22px;
    font-weight:bold;
    color:#2563eb;
}

.progreso{
    display:none;
    margin-top:20px;
}

.progress-bar{
    width:100%;
    height:14px;
    background:#e2e8f0;
    border-radius:10px;
    overflow:hidden;
}

.progress-fill{
    width:0%;
    height:100%;
    background:#2563eb;
    transition:width .3s ease;
}

.progress-text{
    margin-top:8px;
    font-size:14px;
    color:#475569;
}

.ocr-box{
    margin-top:20px;
}

.ocr-box textarea{
    background:#0f172a;
    color:#e2e8f0;
    font-family:monospace;
    min-height:260px;
}

.alerta{
    display:none;
    padding:15px;
    border-radius:10px;
    margin-top:15px;
    font-weight:bold;
}

.alerta-ok{
    background:#dcfce7;
    color:#166534;
}

.alerta-error{
    background:#fee2e2;
    color:#991b1b;
}

.detectado{
    border:2px solid #16a34a;
}

.faltante{
    border:2px solid #f59e0b;
}

@media(max-width:600px){

    .container{
        padding:12px;
    }

    .panel{
        padding:18px;
    }

    .header h1{
        font-size:22px;
    }

    .btn{
        width:100%;
    }

}

</style>

</head>

<body>

<header class="header">

<h1>
📷 Particular Scanner
</h1>

<p>
Escaneo automático de etiquetas de paquetes particulares
</p>

</header>

<div class="container">

<a
href="/panel/logistica"
class="back"

>

<i class="fas fa-arrow-left"></i>

Volver a Logística

</a>

<div class="panel">

<h2>
