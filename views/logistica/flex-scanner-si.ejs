<script>

let stream = null;

let procesando = false;

let scannerActivo = false;

let intervaloCaptura = null;

let ultimoTextoProcesado = "";


const video =
document.getElementById("video");

const canvas =
document.getElementById("canvas");

const iniciar =
document.getElementById("iniciarScanner");

const detener =
document.getElementById("detenerScanner");

const estado =
document.getElementById("scannerEstado");

const resultado =
document.getElementById("resultado");

const progreso =
document.getElementById("progreso");

const progressFill =
document.getElementById("progressFill");

const progressText =
document.getElementById("progressText");

const textoOCR =
document.getElementById("textoOCR");


function sonidoOK(){

    try{

        const audio =
        new AudioContext();

        const osc =
        audio.createOscillator();

        const gain =
        audio.createGain();

        osc.connect(gain);

        gain.connect(
            audio.destination
        );

        osc.frequency.value =
        900;

        osc.type =
        "sine";

        gain.gain.setValueAtTime(
            .3,
            audio.currentTime
        );

        gain.gain.exponentialRampToValueAtTime(
            .01,
            audio.currentTime + .4
        );

        osc.start();

        osc.stop(
            audio.currentTime + .4
        );

    }catch(e){}

}


function sonidoError(){

    try{

        const audio =
        new AudioContext();

        const osc =
        audio.createOscillator();

        const gain =
        audio.createGain();

        osc.connect(gain);

        gain.connect(
            audio.destination
        );

        osc.frequency.value =
        180;

        osc.type =
        "square";

        gain.gain.setValueAtTime(
            .25,
            audio.currentTime
        );

        gain.gain.exponentialRampToValueAtTime(
            .01,
            audio.currentTime + .4
        );

        osc.start();

        osc.stop(
            audio.currentTime + .4
        );

    }catch(e){}

}


function generarCodigoInterno(){

    return "PKG-" +
    Math.floor(
        100000 +
        Math.random() *
        900000
    );

}


function fechaActual(){

    return new Date()
    .toLocaleString(
        "es-AR"
    );

}


iniciar.addEventListener(
"click",
async function(){

    try{

        stream =
        await navigator.mediaDevices
        .getUserMedia({

            video:{
                facingMode:{
                    ideal:"environment"
                },

                width:{
                    ideal:1920
                },

                height:{
                    ideal:1080
                }

            },

            audio:false

        });


        video.srcObject =
        stream;


        await video.play();


        scannerActivo =
        true;

        procesando =
        false;


        iniciar.style.display =
        "none";

        detener.style.display =
        "inline-block";


        estado.innerHTML =
        "📷 Cámara activa. Mantené la etiqueta completa dentro del cuadro.";


        intervaloCaptura =
        setInterval(

            capturarImagen,

            4500

        );

    }catch(error){

        console.error(error);

        alert(
            "No se pudo abrir la cámara: "
            +
            error.message
        );

    }

});


detener.addEventListener(
"click",
detenerScanner
);


function detenerScanner(){

    scannerActivo =
    false;


    if(intervaloCaptura){

        clearInterval(
            intervaloCaptura
        );

        intervaloCaptura =
        null;

    }


    if(stream){

        stream
        .getTracks()
        .forEach(
            track =>
            track.stop()
        );

        stream =
        null;

    }


    video.srcObject =
    null;


    iniciar.style.display =
    "inline-block";

    detener.style.display =
    "none";


    estado.innerHTML =
    "Scanner detenido";

}


async function capturarImagen(){

    if(
        !scannerActivo ||
        procesando
    ){

        return;

    }


    if(
        video.readyState <
        2
    ){

        return;

    }


    const width =
    video.videoWidth;

    const height =
    video.videoHeight;


    if(
        !width ||
        !height
    ){

        return;

    }


    canvas.width =
    width;

    canvas.height =
    height;


    const ctx =
    canvas.getContext(
        "2d",
        {
            willReadFrequently:true
        }
    );


    ctx.drawImage(
        video,
        0,
        0,
        width,
        height
    );


    const imagen =
    canvas.toDataURL(
        "image/jpeg",
        .98
    );


    await analizarImagen(
        imagen
    );

}


async function analizarImagen(
    imagen
){

    if(procesando){

        return;

    }


    procesando =
    true;


    estado.innerHTML =
    "🔎 Analizando etiqueta...";


    progreso.style.display =
    "block";


    progressFill.style.width =
    "5%";


    progressText.innerText =
    "Preparando OCR...";


    try{

        const resultadoOCR =
        await Tesseract.recognize(

            imagen,

            "spa",

            {

                logger:
                info => {

                    if(
                        info.status ===
                        "recognizing text"
                    ){

                        const porcentaje =
                        Math.round(
                            info.progress *
                            100
                        );


                        progressFill.style.width =
                        porcentaje +
                        "%";


                        progressText.innerText =
                        "Leyendo etiqueta... "
                        +
                        porcentaje
                        +
                        "%";

                    }

                }

            }

        );


        const texto =
        resultadoOCR
        .data
        .text
        .trim();


        console.log(
            "OCR COMPLETO:",
            texto
        );


        if(
            !texto ||
            texto.length <
            35
        ){

            throw new Error(
                "Lectura insuficiente"
            );

        }


        const datos =
        procesarDatos(
            texto
        );


        const cantidad =
        Object.values(
            datos
        )
        .filter(
            valor =>
            valor &&
            String(valor)
            .trim()
        )
        .length;


        if(
            cantidad <
            4
        ){

            throw new Error(
                "La etiqueta no fue reconocida correctamente"
            );

        }


        textoOCR.value =
        texto;


        progressFill.style.width =
        "100%";


        progressText.innerText =
        "✅ OCR terminado";


        detenerScanner();


        sonidoOK();


        mostrarResultado(
            datos,
            texto
        );


    }catch(error){

        console.error(
            "OCR:",
            error
        );


        sonidoError();


        estado.innerHTML =
        "❌ No se pudo reconocer correctamente la etiqueta. Volvé a enfocar la etiqueta completa.";


        procesando =
        false;

    }

}


function procesarDatos(
    texto
){

    const datos = {

        codigoBarras:
        detectarCodigoBarras(
            texto
        ),

        numeroOrden:
        detectarOrden(
            texto
        ),

        fechaEmision:
        detectarFecha(
            texto
        ),

        peso:
        detectarPeso(
            texto
        ),

        bultos:
        detectarBultos(
            texto
        ),

        numeroBulto:
        detectarNumeroBulto(
            texto
        ),

        remitente:
        detectarRemitente(
            texto
        ),

        destinatario:
        detectarDestinatario(
            texto
        ),

        telefono:
        detectarTelefono(
            texto
        ),

        direccion:
        detectarDireccion(
            texto
        ),

        codigoPostal:
        detectarCodigoPostal(
            texto
        ),

        localidad:
        detectarLocalidad(
            texto
        )

    };


    datos.zona =
    detectarZona(
        texto,
        datos.localidad,
        datos.direccion
    );


    return datos;

}


function mostrarResultado(
    datos,
    texto
){

    document.getElementById(
        "codigoInterno"
    ).innerText =
    generarCodigoInterno();


    const campos = {

        codigoBarras:
        datos.codigoBarras,

        numeroOrden:
        datos.numeroOrden,

        fechaEmision:
        datos.fechaEmision,

        peso:
        datos.peso,

        bultos:
        datos.bultos,

        numeroBulto:
        datos.numeroBulto,

        remitente:
        datos.remitente,

        destinatario:
        datos.destinatario,

        telefono:
        datos.telefono,

        direccion:
        datos.direccion,

        codigoPostal:
        datos.codigoPostal,

        localidad:
        datos.localidad,

        zona:
        datos.zona

    };


    for(
        const id in campos
    ){

        const input =
        document.getElementById(
            id
        );


        if(input){

            input.value =
            campos[id] ||
            "";

            input.classList.toggle(
                "detectado",
                Boolean(
                    campos[id]
                )
            );

            input.classList.toggle(
                "faltante",
                !campos[id]
            );

        }

    }


    document.getElementById(
        "fechaRecepcion"
    ).value =
    fechaActual();


    document.getElementById(
        "observaciones"
    ).value =
    texto;


    textoOCR.value =
    texto;


    resultado.style.display =
    "block";


    const faltantes =
    Object.values(
        campos
    )
    .filter(
        valor =>
        !valor
    )
    .length;


    if(
        faltantes === 0
    ){

        document.getElementById(
            "alertaOk"
        ).style.display =
        "block";

        document.getElementById(
            "alertaError"
        ).style.display =
        "none";

    }else{

        document.getElementById(
            "alertaOk"
        ).style.display =
        "none";

        document.getElementById(
            "alertaError"
        ).style.display =
        "block";

    }


    procesando =
    false;

}


function lineasTexto(
    texto
){

    return texto
    .split(/\r?\n/)
    .map(
        linea =>
        linea
        .replace(
            /\s+/g,
            " "
        )
        .trim()
    )
    .filter(
        Boolean
    );

}


function detectarCodigoBarras(
    texto
){

    const lineas =
    lineasTexto(
        texto
    );


    const candidatos = [];


    for(
        const linea
        of lineas
    ){

        const limpia =
        linea.replace(
            /\s/g,
            ""
        );


        if(
            /^\d{6,14}$/
            .test(
                limpia
            )
        ){

            candidatos.push(
                limpia
            );

        }

    }


    if(
        candidatos.length
    ){

        return candidatos
        .sort(
            (
                a,
                b
            ) =>
            b.length -
            a.length
        )[0];

    }


    return "";

}


function detectarFecha(
    texto
){

    const match =
    texto.match(
        /\b\d{1,2}[\/\-]\d{1,2}[\/\-]\d{2,4}\b/
    );


    return match
    ?
    match[0]
    :
    "";

}


function detectarOrden(
    texto
){

    const lineas =
    lineasTexto(
        texto
    );


    for(
        let i=0;
        i<lineas.length;
        i++
    ){

        if(
            /Nro\.?\s*Ord/i
            .test(
                lineas[i]
            )
        ){

            const numeros =
            lineas
            .slice(
                i,
                i+3
            )
            .join(" ")
            .match(
                /\b\d{4,8}\b/g
            );


            if(
                numeros &&
                numeros.length
            ){

                return numeros[
                    numeros.length - 1
                ];

            }

        }

    }


    return "";

}


function detectarPeso(
    texto
){

    const lineas =
    lineasTexto(
        texto
    );


    for(
        let i=0;
        i<lineas.length;
        i++
    ){

        if(
            /PESO/i
            .test(
                lineas[i]
            )
        ){

            const bloque =
            lineas
            .slice(
                i,
                i+3
            )
            .join(" ");


            const match =
            bloque.match(
                /PESO.*?(\d+(?:[.,]\d+)?)/i
            );


            if(match){

                return match[1];

            }


            const siguiente =
            lineas[i+1];


            if(
                siguiente
            ){

                const nums =
                siguiente.match(
                    /\b\d+(?:[.,]\d+)?\b/g
                );


                if(
                    nums &&
                    nums.length
                ){

                    return nums[0];

                }

            }

        }

    }


    return "";

}


function detectarBultos(
    texto
){

    const lineas =
    lineasTexto(
        texto
    );


    for(
        let i=0;
        i<lineas.length;
        i++
    ){

        if(
            /BULTOS/i
            .test(
                lineas[i]
            )
        ){

            const bloque =
            lineas
            .slice(
                i,
                i+3
            )
            .join(" ");


            const match =
            bloque.match(
                /BULTOS.*?(\d{1,2})/i
            );


            if(match){

                return match[1];

            }


            const siguiente =
            lineas[i+1];


            if(
                siguiente
            ){

                const nums =
                siguiente.match(
                    /\b\d{1,2}\b/g
                );


                if(
                    nums &&
                    nums.length >= 2
                ){

                    return nums[1];

                }

            }

        }

    }


    return "";

}


function detectarNumeroBulto(
    texto
){

    const match =
    texto.match(
        /\b(\d{1,2})\s*(?:de|\/)\s*(\d{1,2})\b/i
    );


    if(match){

        return (
            match[1]
            +
            " de "
            +
            match[2]
        );

    }


    const match2 =
    texto.match(
        /\b(\d{1,2})\s+de\s+(\d{1,2})\b/i
    );


    return match2
    ?
    match2[1]
    +
    " de "
    +
    match2[2]
    :
    "";

}


function detectarRemitente(
    texto
){

    const match =
    texto.match(
        /Remitente\s*:?\s*([^\n]+)/i
    );


    return match
    ?
    limpiarCampo(
        match[1]
    )
    :
    "";

}


function detectarDestinatario(
    texto
){

    const lineas =
    lineasTexto(
        texto
    );


    for(
        let i=0;
        i<lineas.length;
        i++
    ){

        if(
            /^Destinatario\s*:?\s*$/i
            .test(
                lineas[i]
            )
        ){

            const siguiente =
            lineas[i+1];


            if(
                siguiente
            ){

                return siguiente
                .replace(
                    /\(\s*\d[\d\s\-]{7,}\)/g,
                    ""
                )
                .trim();

            }

        }


        const inline =
        lineas[i].match(
            /^Destinatario\s*:?\s*(.+)$/i
        );


        if(inline){

            return inline[1]
            .replace(
                /\(\s*\d[\d\s\-]{7,}\)/g,
                ""
            )
            .trim();

        }

    }


    return "";

}


function detectarTelefono(
    texto
){

    const match =
    texto.match(
        /\(\s*(\d{8,15})\s*\)/
    );


    if(match){

        return match[1];

    }


    const numeros =
    texto.match(
        /\b\d{10,15}\b/g
    );


    if(
        numeros &&
        numeros.length
    ){

        return numeros[0];

    }


    return "";

}


function detectarDireccion(
    texto
){

    const lineas =
    lineasTexto(
        texto
    );


    for(
        let i=0;
        i<lineas.length;
        i++
    ){

        if(
            /^Destinatario/i
            .test(
                lineas[i]
            )
        ){

            for(
                let j=i+1;
                j<
                Math.min(
                    i+4,
                    lineas.length
                );
                j++
            ){

                const linea =
                lineas[j];


                if(
                    /\d{3,}/.test(
                        linea
                    ) &&
                    !/CP|CABA|código postal/i
                    .test(
                        linea
                    )
                ){

                    return linea;

                }

            }

        }

    }


    for(
        const linea
        of lineas
    ){

        if(
            /\b[A-Za-zÁÉÍÓÚáéíóúÑñ]+\s+\d{2,5}\b/
            .test(
                linea
            )
        ){

            if(
                !/PESO|BULTOS|NRO|ORD|CP|CABA/i
                .test(
                    linea
                )
            ){

                return linea;

            }

        }

    }


    return "";

}


function detectarCodigoPostal(
    texto
){

    const match =
    texto.match(
        /(?:CP|C\.P\.|Código Postal)\s*:?\s*(?:[A-Za-z]+\s*)?(\d{4,8})/i
    );


    return match
    ?
    match[1]
    :
    "";

}


function detectarLocalidad(
    texto
){

    const lineas =
    lineasTexto(
        texto
    );


    for(
        let i=0;
        i<lineas.length;
        i++
    ){

        if(
            /^CP\b/i
            .test(
                lineas[i]
            )
        ){

            const valor =
            lineas[i]
            .replace(
                /^CP\s*:?\s*/i,
                ""
            )
            .trim();


            if(valor){

                return valor;

            }

        }

    }


    const match =
    texto.match(
        /(?:Localidad|Ciudad)\s*:?\s*([^\n]+)/i
    );


    return match
    ?
    match[1].trim()
    :
    "";

}


function detectarZona(
