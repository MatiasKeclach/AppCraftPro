    progreso.style.display =
    "none";

    textoOCR.value =
    "";

    document
    .querySelectorAll(
        "#resultado input"
    )
    .forEach(
        input => {

            input.value =
            "";

            input.classList.remove(
                "detectado",
                "faltante"
            );

        }
    );


    document.getElementById(
        "alertaOk"
    ).style.display =
    "none";


    document.getElementById(
        "alertaError"
    ).style.display =
    "none";


    procesando =
    false;


    if(
        !scannerActivo
    ){

        iniciar.click();

    }

});


document
.getElementById(
"guardarPaquete"
)
.addEventListener(
"click",
function(){

    const cliente =
    document
    .getElementById(
        "cliente_id"
    )
    .value;


    const codigo =
    document
    .getElementById(
        "codigoBarras"
    )
    .value
    .trim();


    if(
        !cliente
    ){

        alert(
            "Seleccioná un cliente interno."
        );

        return;

    }


    if(
        !codigo
    ){

        alert(
            "No se detectó el código de barras. Podés ingresarlo manualmente."
        );

        return;

    }


    alert(
        "Los datos fueron preparados correctamente. El siguiente paso será conectar este formulario con la ruta de guardado en la base de datos."
    );

});

