type="text"
id="fechaRecepcion"
readonly

>

</div>

<div>

<label>
Peso
</label>

<input
type="text"
id="peso"

>

</div>

<div>

<label>
Cantidad de bultos
</label>

<input
type="text"
id="bultos"

>

</div>

<div>

<label>
Número de bulto
</label>

<input
type="text"
id="numeroBulto"

>

</div>

<div>

<label>
Remitente
</label>

<input
type="text"
id="remitente"

>

</div>

<div>

<label>
Destinatario
</label>

