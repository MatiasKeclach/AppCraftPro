</h2>

<label>
Seleccionar cliente
</label>

<select id="cliente_id">

<option value="">
Seleccionar cliente...
</option>

<% clientes.forEach(cliente => { %>

<option value="<%= cliente.id %>">

<%= cliente.nombre %>

<% if(cliente.empresa){ %>

* <%= cliente.empresa %>

<% } %>

</option>

<% }) %>

</select>

</div>

<div class="panel">

<h2>
📷 Escanear etiqueta
</h2>

<div class="scanner">

