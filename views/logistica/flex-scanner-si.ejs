    return "";

}


function limpiarCampo(
    valor
){

    return valor
    .replace(
        /^[\s:;\-]+/,
        ""
    )
    .replace(
        /\s+/g,
        " "
    )
    .trim();

}


document
.getElementById(
"escanearOtro"
)
.addEventListener(
"click",
function(){

    resultado.style.display =
