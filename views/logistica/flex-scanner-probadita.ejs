}


/* =========================================================
   CAMPO GENERICO
========================================================= */

function extraerCampoPorEtiqueta(
    texto,
    etiquetas
){

    const lineas =
    texto
    .replace(/\r/g,"")
    .split("\n");


    for(
        let i=0;
        i<lineas.length;
        i++
    ){

        const linea =
        lineas[i].trim();


        for(
            const etiqueta
            of etiquetas
        ){

            const regex =
            new RegExp(

                "^\\s*"
                +
                etiqueta
                +
                "\\s*:?\\s*(.*)$",

                "i"

            );


            const encontrado =
            linea.match(
                regex
            );


            if(encontrado){

                /*
                SI EL VALOR ESTA
                EN LA MISMA LINEA
                */

                if(
                    encontrado[1] &&
                    encontrado[1].trim().length > 1
                ){

                    return limpiarValor(
                        encontrado[1]
                    );

                }


                /*
                SI ESTA EN LA LINEA SIGUIENTE
                */

                for(
                    let j=i+1;
                    j<lineas.length;
                    j++
                ){

                    const siguiente =
                    lineas[j].trim();


                    if(
                        siguiente.length > 2
                    ){

                        return limpiarValor(
                            siguiente
                        );

                    }

                }

            }

        }

    }


    return "";

}


/* =========================================================
   DESTINATARIO
========================================================= */

function extraerDestinatario(texto){

    const valor =
    extraerCampoPorEtiqueta(

        texto,

        [
            "Destinatario",
            "Destinatário"
        ]

    );


    return limpiarNombre(
        valor
    );

}


/* =========================================================
   TELEFONO
========================================================= */

function extraerTelefono(texto){

    const patrones = [

        /(?:tel[eé]fono|telefono|tel\.?)[:\s]*([0-9+\-\s]{8,20})/i,

        /(?:celular|cel\.?)[:\s]*([0-9+\-\s]{8,20})/i

    ];


    for(
        const patron
        of patrones
    ){

        const encontrado =
        texto.match(
            patron
        );


        if(encontrado){

            return encontrado[1]
            .replace(
                /\s+/g,
                " "
            )
            .trim();

        }

    }


    /*
    SI OCR NO DETECTO LA PALABRA
    TELEFONO, BUSCAMOS NUMERO LARGO
    */

    const numeros =
    texto.match(
        /\b(?:54)?11\d{8}\b/g
    );


    if(numeros){

        return numeros[0];

    }


    return "";

}


/* =========================================================
   DIRECCION
========================================================= */

function extraerDireccion(texto){

    const lineas =
    texto
    .replace(/\r/g,"")
    .split("\n")
    .map(
        l =>
        l.trim()
    )
    .filter(
        l =>
        l.length > 0
    );


    for(
        let i=0;
        i<lineas.length;
        i++
    ){

        const linea =
        lineas[i];


        /*
        DIRECCION EN MISMA LINEA
        */

        const mismaLinea =
        linea.match(

            /^[-•]?\s*(?:direcci[oó]n|direccion)\s*:?\s*(.+)$/i

        );


        if(
            mismaLinea &&
            mismaLinea[1]
        ){

            return limpiarValor(
                mismaLinea[1]
            );

        }


        /*
        DIRECCION EN LINEA SIGUIENTE
        */

        if(
            /^(?:direcci[oó]n|direccion)\s*:?\s*$/i
            .test(linea)
        ){

            if(
                lineas[i+1]
            ){

                return limpiarValor(
                    lineas[i+1]
                );

            }

        }

    }


    /*
    DETECCION INTELIGENTE

    Si no dice "Dirección",
    buscamos una línea que parezca
    una dirección.

    Ejemplo:

    Gaspar Melchor de Jovellanos 1135

    Avenida Sir Alexander Fleming 1443

    Calle Luna 1909

    */

    for(
        const linea
        of lineas
    ){

        if(
            pareceDireccion(
                linea
            )
        ){

            return linea;

        }

    }


    return "";

}


/* =========================================================
   DETECTAR DIRECCION
========================================================= */

function pareceDireccion(linea){

    if(
        !linea ||
        linea.length < 5
    ){

        return false;

    }


    /*
    EVITAR CAMPOS QUE NO SON DIRECCION
    */

    const prohibidas = [

        "destinatario",

        "remitente",

        "telefono",

        "teléfono",

        "observaciones",

        "peso",

        "bultos",

        "fecha",

        "pack id",

        "envio",

        "envío",

        "nro orden",

        "nro. orden",

        "c.p.",

        "cp:"

    ];


    const minuscula =
    linea.toLowerCase();


    if(
        prohibidas.some(
            palabra =>
            minuscula.includes(
                palabra
            )
        )
    ){

        return false;

    }


    /*
    DEBE CONTENER NUMERO

    Y PARECER UNA DIRECCION
    */

    const tieneNumero =
    /\d{2,5}/.test(
        linea
    );


    const palabrasDireccion = [

        "calle",

        "avenida",

        "av.",

        "av ",

        "pasaje",

        "pje.",

        "ruta",

        "boulevard",

        "boul.",

        "jovellanos",

        "luna"

    ];


    const pareceNombreCalle =
    palabrasDireccion.some(
        palabra =>
        minuscula.includes(
            palabra
        )
    );


    return (
        tieneNumero &&
        pareceNombreCalle
    );

}


/* =========================================================
   LOCALIDAD / BARRIO
========================================================= */

function extraerLocalidad(texto){

    const lineas =
    texto
    .replace(/\r/g,"")
    .split("\n")
    .map(
        l =>
        l.trim()
    )
    .filter(
        l =>
        l.length > 0
    );


    /*
    PRIMERO:

    BUSCAR LINEAS CON:

    Localidad:
    Barrio:
    Ciudad:
    */

    for(
        let i=0;
        i<lineas.length;
        i++
    ){

        const encontrado =
        lineas[i].match(

            /^(?:localidad|barrio|ciudad)\s*:?\s*(.+)$/i

        );


        if(
            encontrado &&
            encontrado[1]
        ){

            return limpiarLocalidad(
                encontrado[1]
            );

        }

    }


    /*
    SEGUNDO:

    BUSCAR LOCALIDAD EN LINEAS
    CERCANAS A CP / CABA
    */

    for(
        let i=0;
        i<lineas.length;
        i++
    ){

        const linea =
        lineas[i];


        if(
            /caba/i.test(
                linea
            )
        ){

            /*
            EJEMPLO:

            CP: 1437
            CABA
            Barracas

            */

            for(
                let j=i+1;
                j<Math.min(
                    i+4,
                    lineas.length
                );
                j++
            ){

                const posible =
                lineas[j];


                if(
                    esPosibleLocalidad(
                        posible
                    )
                ){

                    return limpiarLocalidad(
                        posible
                    );

                }

            }

        }

    }


    /*
    TERCERO:

    BUSCAR LOCALIDAD EN UNA LINEA
    QUE CONTENGA CABA

    EJEMPLO:

    CABA - Barracas - 1269

    */

    for(
        const linea
        of lineas
    ){

        const encontrado =
        linea.match(

            /CABA\s*[-–]\s*([A-Za-zÁÉÍÓÚáéíóúÑñ .]+)/i

        );


        if(
            encontrado &&
            encontrado[1]
        ){

            return limpiarLocalidad(
                encontrado[1]
            );

        }

    }


    /*
    CUARTO:

    BUSCAR PATRON:

    CABA
    BARRACAS

    */

    for(
        let i=0;
        i<lineas.length;
        i++
    ){

        if(
            /^caba$/i.test(
                lineas[i]
            )
        ){

            if(
                lineas[i+1] &&
                esPosibleLocalidad(
                    lineas[i+1]
                )
            ){

                return limpiarLocalidad(
                    lineas[i+1]
                );

            }

        }

    }


    /*
    SI NO ENCUENTRA BARRIO
    */

    return "CABA";

}


/* =========================================================
   VALIDAR POSIBLE LOCALIDAD
========================================================= */

function esPosibleLocalidad(linea){

    if(
        !linea ||
        linea.length < 3
    ){

        return false;

    }


    const texto =
    linea.toLowerCase();


    /*
    NO DEBE SER ESTOS CAMPOS
    */

    const excluir = [

        "dirección",

        "direccion",

        "destinatario",

        "remitente",

        "telefono",

        "teléfono",

        "fecha",

        "peso",

        "bultos",

        "observaciones",

        "caba",

        "cp",

        "c.p.",

        "pack id",

        "envio",

        "envío",

        "orden"

    ];


    if(
        excluir.some(
            palabra =>
            texto.includes(
                palabra
            )
        )
    ){

        return false;

    }


    /*
    NO DEBE SER SOLO NUMEROS
    */

    if(
        /^\d+$/.test(
            linea
        )
    ){

        return false;

    }


    /*
    DEBE TENER LETRAS
    */

    return /[A-Za-zÁÉÍÓÚáéíóúÑñ]/.test(
        linea
    );

}


/* =========================================================
   LIMPIAR LOCALIDAD
========================================================= */

function limpiarLocalidad(valor){

    return valor

    .replace(
        /\d{4,}/g,
        ""
    )

    .replace(
        /[-–|]/g,
        " "
    )

    .replace(
        /\s+/g,
        " "
    )

    .trim();

}


/* =========================================================
   OBSERVACIONES
========================================================= */

function extraerObservaciones(texto){

    const valor =
    extraerCampoPorEtiqueta(

        texto,

        [
            "Observaciones",
            "Observación",
            "Referencia"
        ]

    );


    return valor || "";

}


/* =========================================================
   LIMPIAR VALOR
========================================================= */

function limpiarValor(valor){

    return (
        valor || ""
    )

    .replace(
        /^[\s:|-]+/,
        ""
    )

    .replace(
        /\s+/g,
        " "
    )

    .trim();

}


/* =========================================================
   LIMPIAR NOMBRE
========================================================= */

function limpiarNombre(valor){

    return (
        valor || ""
    )

    .replace(
        /\([^)]*\)/g,
        ""
    )

    .replace(
        /\s+/g,
        " "
    )

    .trim();

}


