/* =========================================================
   EXTRAER CODIGO DE BARRAS DESDE OCR
========================================================= */

function extraerCodigoBarras(texto){

    const patrones = [

        /(?:c[oó]digo\s*de\s*barras|barcode)[:\s]*([0-9]{8,20})/i,

        /(?:pack\s*id)[:\s]*([0-9]{8,20})/i,

        /(?:env[ií]o)[:\s]*([0-9]{8,20})/i

    ];


    for(
        const patron
        of patrones
    ){

        const encontrado =
        texto.match(
            patron
        );


        if(encontrado){

            return encontrado[1];

        }

    }


    return "";

}


/* =========================================================
   NUMERO DE ORDEN
========================================================= */

function extraerNumeroOrden(texto){

    const patrones = [

        /nro\.?\s*orden[:\s]*([0-9]+)/i,

        /número\s*de\s*orden[:\s]*([0-9]+)/i,

        /numero\s*de\s*orden[:\s]*([0-9]+)/i,

        /orden[:\s]*([0-9]+)/i

    ];


    for(
        const patron
        of patrones
    ){

        const encontrado =
        texto.match(
            patron
        );


        if(encontrado){

            return encontrado[1];

        }

    }


    return "";

}


/* =========================================================
   FECHA
========================================================= */

function extraerFecha(texto){

    const encontrado =
    texto.match(

        /(?:fecha|fech[aá])[:\s]*([0-9]{1,2}[\/\-][0-9]{1,2}[\/\-][0-9]{2,4})/i

    );


    if(encontrado){

        return encontrado[1];

    }


    return "";

}


/* =========================================================
   PESO
========================================================= */

function extraerPeso(texto){

    const encontrado =
    texto.match(

        /(?:peso)[:\s]*([0-9]+(?:[.,][0-9]+)?\s*(?:kg|kgs|kilos)?)/i

    );


    if(encontrado){

        return encontrado[1].trim();

    }


    return "";

}


/* =========================================================
   BULTOS
========================================================= */

function extraerBultos(texto){

    const encontrado =
    texto.match(

        /(?:bultos?|piezas?|paquetes?)[:\s]*([0-9]+)/i

    );


    if(encontrado){

        return encontrado[1];

    }


    return "";

}


/* =========================================================
   NUMERO DE BULTO
========================================================= */

function extraerNumeroBulto(texto){

    const patrones = [

        /(?:nro\.?\s*bulto|número\s*de\s*bulto|numero\s*de\s*bulto)[:\s]*([0-9]+)/i,

        /bulto[:\s]*([0-9]+)\s*(?:de|\/)\s*[0-9]+/i

    ];


    for(
