<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Logística - AppCraft Pro</title>

<link rel="stylesheet" href="/css/panel.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
background:#f4f6f9;
font-family:Arial,Helvetica,sans-serif;
}

.header{
background:#1e293b;
color:#fff;
padding:25px;
box-shadow:0 3px 15px rgba(0,0,0,.15);
}

.header h1{
font-size:30px;
margin-bottom:8px;
}

.header p{
opacity:.9;
}

.container{
padding:20px;
max-width:1400px;
margin:auto;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(240px,1fr));
gap:20px;
}

.card{
background:#fff;
border-radius:15px;
padding:30px 20px;
text-align:center;
box-shadow:0 5px 20px rgba(0,0,0,.08);
transition:.3s;
cursor:pointer;
}

.card:hover{
transform:translateY(-8px);
box-shadow:0 15px 30px rgba(0,0,0,.15);
}

.card i{
font-size:55px;
color:#2563eb;
margin-bottom:20px;
}

.card h3{
margin-bottom:10px;
color:#1e293b;
}

.card p{
color:#666;
font-size:14px;
line-height:22px;
}

/* TABLET */

@media(min-width:768px){

.header{
padding:30px 40px;
}

.container{
padding:35px;
}

}

/* PC */

@media(min-width:1200px){

.grid{
grid-template-columns:repeat(3,1fr);
}

}

</style>

</head>

<body>

<header class="header">

<h1>📦 Módulo Logística</h1>

<p>
Bienvenido
<strong><%= username %></strong>
</p>

</header>

<div class="container">

<div class="grid">

    <div class="card" onclick="location.href='/panel/logistica/clientes'">
<i class="fas fa-users"></i>
<h3>Clientes</h3>
<p>Administrar clientes y depósitos.</p>
</div>
 
<div class="card" onclick="location.href='/panel/logistica/colectas'">
    <i class="fas fa-truck-loading"></i>
<h3>Colectas</h3>
<p>Registrar colectas diarias.</p>
</div>

<div class="card" onclick="location.href='/panel/logistica/paquetes'">
<i class="fas fa-box"></i>
<h3>Paquetes</h3>
<p>Todos los paquetes registrados.</p>
</div>

<div class="card" onclick="location.href='/panel/logistica/choferes'">
<i class="fas fa-truck"></i>
<h3>Choferes</h3>
<p>Administrar choferes.</p>
</div>

<div class="card">
<i class="fas fa-clipboard-list"></i>
<h3>Asignaciones</h3>
<p>Asignar paquetes a cada chofer.</p>
</div>

<div class="card">
<i class="fas fa-chart-line"></i>
<h3>Reportes</h3>
<p>Estadísticas y exportaciones.</p>
</div>

</div>

</div>

</body>
</html>