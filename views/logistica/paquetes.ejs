<!DOCTYPE html>
<html lang="es">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Paquetes - Logística</title>

<link rel="stylesheet" href="/css/panel.css">


<style>

:root{
    --primary:#2563eb;
    --dark:#0f172a;
    --bg:#f1f5f9;
    --card:#ffffff;
    --border:#e2e8f0;
    --text:#334155;
}


*{
    box-sizing:border-box;
}


body{

    margin:0;

    background:var(--bg);

    font-family:
    Inter,
    Arial,
    sans-serif;

    color:var(--text);

}



/* HEADER */

.header{

    background:
    linear-gradient(135deg,#0f172a,#1d4ed8);

    color:white;

    padding:25px 20px;

}


.header h2{

    margin:0;

}


.header p{

    margin:8px 0 0;

    opacity:.8;

}



/* CONTENEDOR */

.container{

    width:100%;

    max-width:1200px;

    margin:auto;

    padding:20px;

}



/* BOX */

.box{

    background:white;

    border-radius:18px;

    padding:22px;

    margin-bottom:25px;

    border:1px solid var(--border);

    box-shadow:
    0 10px 25px rgba(0,0,0,.06);

}


.box h3{

    margin-top:0;

    color:var(--dark);

}



/* FORM */

form{

    display:flex;

    flex-direction:column;

    gap:12px;

}


input,
select,
textarea{

    width:100%;

    padding:14px;

    border-radius:12px;

    border:1px solid #cbd5e1;

    font-size:15px;

}


textarea{

    resize:none;

    height:90px;

}



button{

    background:var(--primary);

    color:white;

    border:none;

    padding:14px;

    border-radius:12px;

    cursor:pointer;

    font-weight:bold;

    font-size:16px;

}



/* TABLA */

.table-container{

    width:100%;

    overflow-x:auto;

}


table{

    width:100%;

    min-width:900px;

    border-collapse:collapse;

}


th,
td{

    padding:14px;

    border-bottom:1px solid var(--border);

    text-align:left;

}


th{

    background:#f8fafc;

}



.qr{

    width:70px;

    height:70px;

}



.codigo{

    color:#2563eb;

    font-weight:bold;

}



.estado{

    background:#dcfce7;

    color:#166534;

    padding:6px 12px;

    border-radius:20px;

    font-size:13px;

}




@media(min-width:768px){

    form{

        display:grid;

        grid-template-columns:repeat(2,1fr);

    }


    textarea,
    button{

        grid-column:span 2;

    }

}



@media(min-width:1100px){

    .container{

        padding:35px;

    }

}



</style>


</head>



<body>



<div class="header">


<h2>
📦 Paquetes Logística
</h2>


<p>
Usuario: <%= username %>
</p>


</div>





<div class="container">





<div class="box">


<h3>
➕ Registrar paquete
</h3>




<form method="POST" action="/panel/logistica/paquetes">



<select name="cliente_id" required>


<option value="">
Seleccionar cliente
</option>



<% clientes.forEach(cliente => { %>


<option value="<%= cliente.id %>">

<%= cliente.nombre %>

</option>


<% }) %>



</select>





<select name="tipo">


<option value="flex">
FLEX
</option>


<option value="particular">
PARTICULAR
</option>


</select>





<input

type="text"

name="codigo_externo"

placeholder="Código externo Mercado Libre / Cliente"

/>





<input

type="text"

name="descripcion"

placeholder="Descripción del paquete"

/>





<textarea

name="observaciones"

placeholder="Observaciones"

></textarea>





<button type="submit">

📦 Crear paquete + QR

</button>



</form>



</div>









<div class="box">


<h3>
📋 Paquetes registrados
</h3>




<div class="table-container">



<table>



<thead>


<tr>

<th>ID</th>

<th>Cliente</th>

<th>Tipo</th>

<th>Código externo</th>

<th>Código interno</th>

<th>QR</th>

<th>Estado</th>

</tr>


</thead>



<tbody>



<% if(paquetes.length === 0){ %>


<tr>

<td colspan="7">

No hay paquetes registrados

</td>

</tr>


<% } %>





<% paquetes.forEach(paquete => { %>



<tr>



<td>

<%= paquete.id %>

</td>




<td>

<%= paquete.cliente_nombre %>

</td>




<td>

<%= paquete.tipo.toUpperCase() %>

</td>




<td>

<%= paquete.codigo_externo || "-" %>

</td>




<td class="codigo">

<%= paquete.codigo_interno %>

</td>




<td>


<img

class="qr"

src="<%= paquete.qr_codigo %>"

alt="QR"



>



</td>




<td>


<span class="estado">

<%= paquete.estado %>

</span>


</td>



</tr>



<% }) %>




</tbody>


</table>



</div>



</div>







</div>



</body>


</html>